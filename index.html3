      </div>
      <div onclick="showPage('formalizador')" style="cursor:pointer;background:white;border:1px solid var(--border);border-left:4px solid var(--green);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;">🗣️ Formalizador</div>
        <p style="font-size:.83rem;color:var(--slate);">Traduce argumentos del español a lógica simbólica paso a paso.</p>
      </div>
      <div onclick="showPage('verificador')" style="cursor:pointer;background:white;border:1px solid var(--border);border-left:4px solid var(--green);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;">✔️ Verificador de Argumentos</div>
        <p style="font-size:.83rem;color:var(--slate);">Escribe tus premisas y conclusión — el sistema verifica la validez automáticamente.</p>
      </div>
      <div onclick="showPage('examen')" style="cursor:pointer;background:white;border:1px solid var(--border);border-left:4px solid var(--green);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;">📄 Generador de Examen</div>
        <p style="font-size:.83rem;color:var(--slate);">Crea exámenes listos para imprimir con clave de respuestas.</p>
      </div>
    </div>
  </div>

  <!-- JUEGOS -->
  <div style="margin-bottom:2rem;">
    <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem;">
      <div style="background:var(--accent);color:white;border-radius:6px;padding:.2rem .7rem;font-size:.75rem;font-weight:700;">🎮 JUEGOS</div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:.85rem;">
      <div onclick="showPage('flashcards')" style="cursor:pointer;background:white;border:1px solid var(--border);border-left:4px solid var(--accent);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;">🃏 Flashcards</div>
        <p style="font-size:.83rem;color:var(--slate);">Voltea tarjetas para memorizar cada regla. Individual.</p>
      </div>
      <div onclick="showPage('valido')" style="cursor:pointer;background:white;border:1px solid var(--border);border-left:4px solid var(--accent);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;">⚖️ Válido o Inválido</div>
        <p style="font-size:.83rem;color:var(--slate);">Detecta falacias entre 20 argumentos mezclados. Individual.</p>
      </div>
      <div onclick="showPage('supervivencia')" style="cursor:pointer;background:white;border:1px solid var(--border);border-left:4px solid var(--accent);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;">❤️ Modo Supervivencia</div>
        <p style="font-size:.83rem;color:var(--slate);">Selecciona las reglas que quieres practicar. Aguanta con tus vidas. Individual.</p>
      </div>
      <div onclick="showPage('contrarreloj')" style="cursor:pointer;background:white;border:1px solid var(--border);border-left:4px solid var(--accent);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;">⏱️ Contrarreloj</div>
        <p style="font-size:.83rem;color:var(--slate);">Responde el mayor número de preguntas antes de que el tiempo se acabe. Individual.</p>
      </div>
      <div onclick="showPage('misterio')" style="cursor:pointer;background:white;border:1px solid var(--border);border-left:4px solid var(--accent);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;">🔍 Detective Lógico</div>
        <p style="font-size:.83rem;color:var(--slate);">Resuelve casos narrados en español usando lógica. Individual.</p>
      </div>
      <div onclick="showPage('duelo')" style="cursor:pointer;background:white;border:1px solid var(--border);border-left:4px solid var(--accent);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;">⚔️ Duelo 1 vs 1</div>
        <p style="font-size:.83rem;color:var(--slate);">Dos jugadores compiten por turnos en la misma pantalla.</p>
      </div>
      <div onclick="showPage('torneo')" style="cursor:pointer;background:white;border:1px solid var(--border);border-left:4px solid var(--accent);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;">🏟️ Torneo 4 Jugadores</div>
        <p style="font-size:.83rem;color:var(--slate);">Semifinales y final en bracket de eliminación directa.</p>
      </div>
      <div onclick="showPage('errores')" style="cursor:pointer;background:var(--purple-light);border:1px solid #ddd6fe;border-left:4px solid var(--purple);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;color:var(--purple);">🔎 Encuentra el Error</div>
        <p style="font-size:.83rem;color:#6b21a8;">Detecta el paso incorrecto en una prueba formal. El más desafiante.</p>
      </div>
      <div onclick="showPage('cadena')" style="cursor:pointer;background:#f0fdf4;border:1px solid #bbf7d0;border-left:4px solid var(--green);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;color:var(--green);">🔗 Cadena Lógica <span style="font-size:.7rem;background:var(--green);color:white;border-radius:4px;padding:.1rem .4rem;margin-left:.3rem;vertical-align:middle;">NUEVO</span></div>
        <p style="font-size:.83rem;color:#15803d;">Ordena los pasos de una prueba formal arrastrándolos al lugar correcto.</p>
      </div>
    </div>
  </div>

  <h2 class="section-title">Las 10 Reglas de un Vistazo</h2>
  <p class="section-sub">Haz clic en cualquier regla para ir directamente a su explicación completa.</p>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem;margin-bottom:2rem;">
    <!-- mini cards -->
    <div onclick="showPage('reglas');expandRule('mp')" style="cursor:pointer;background:white;border:1px solid var(--border);border-radius:10px;padding:.9rem 1rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
      <div style="font-family:'DM Mono',monospace;font-size:.85rem;color:var(--navy);margin-bottom:.3rem;">p → q, p ∴ q</div>
      <div style="font-size:.8rem;font-weight:600;color:var(--navy);">Modus Ponens</div>
    </div>
    <div onclick="showPage('reglas');expandRule('mt')" style="cursor:pointer;background:white;border:1px solid var(--border);border-radius:10px;padding:.9rem 1rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
      <div style="font-family:'DM Mono',monospace;font-size:.85rem;color:var(--navy);margin-bottom:.3rem;">p → q, ¬q ∴ ¬p</div>
      <div style="font-size:.8rem;font-weight:600;color:var(--navy);">Modus Tollens</div>
    </div>
    <div onclick="showPage('reglas');expandRule('hs')" style="cursor:pointer;background:white;border:1px solid var(--border);border-radius:10px;padding:.9rem 1rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
      <div style="font-family:'DM Mono',monospace;font-size:.85rem;color:var(--navy);margin-bottom:.3rem;">p → q, q → r ∴ p → r</div>
      <div style="font-size:.8rem;font-weight:600;color:var(--navy);">Silogismo Hipotético</div>
    </div>
    <div onclick="showPage('reglas');expandRule('sd')" style="cursor:pointer;background:white;border:1px solid var(--border);border-radius:10px;padding:.9rem 1rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
      <div style="font-family:'DM Mono',monospace;font-size:.85rem;color:var(--navy);margin-bottom:.3rem;">p ∨ q, ¬p ∴ q</div>
      <div style="font-size:.8rem;font-weight:600;color:var(--navy);">Silogismo Disyuntivo</div>
    </div>
    <div onclick="showPage('reglas');expandRule('ad')" style="cursor:pointer;background:white;border:1px solid var(--border);border-radius:10px;padding:.9rem 1rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
      <div style="font-family:'DM Mono',monospace;font-size:.85rem;color:var(--navy);margin-bottom:.3rem;">p ∴ p ∨ q</div>
      <div style="font-size:.8rem;font-weight:600;color:var(--navy);">Adición</div>
    </div>
    <div onclick="showPage('reglas');expandRule('sim')" style="cursor:pointer;background:white;border:1px solid var(--border);border-radius:10px;padding:.9rem 1rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
      <div style="font-family:'DM Mono',monospace;font-size:.85rem;color:var(--navy);margin-bottom:.3rem;">p ∧ q ∴ p</div>
      <div style="font-size:.8rem;font-weight:600;color:var(--navy);">Simplificación</div>
    </div>
    <div onclick="showPage('reglas');expandRule('con')" style="cursor:pointer;background:white;border:1px solid var(--border);border-radius:10px;padding:.9rem 1rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
      <div style="font-family:'DM Mono',monospace;font-size:.85rem;color:var(--navy);margin-bottom:.3rem;">p, q ∴ p ∧ q</div>
      <div style="font-size:.8rem;font-weight:600;color:var(--navy);">Conjunción</div>
    </div>
    <div onclick="showPage('reglas');expandRule('dl')" style="cursor:pointer;background:white;border:1px solid var(--border);border-radius:10px;padding:.9rem 1rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
      <div style="font-family:'DM Mono',monospace;font-size:.85rem;color:var(--navy);margin-bottom:.3rem;">(p → q) ∧ (r → s), p ∨ r ∴ q ∨ s</div>
      <div style="font-size:.8rem;font-weight:600;color:var(--navy);">Dilema Constructivo</div>
    </div>
    <div onclick="showPage('reglas');expandRule('dd')" style="cursor:pointer;background:white;border:1px solid var(--border);border-radius:10px;padding:.9rem 1rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
      <div style="font-family:'DM Mono',monospace;font-size:.85rem;color:var(--navy);margin-bottom:.3rem;">(p → q) ∧ (r → s), ¬q ∨ ¬s ∴ ¬p ∨ ¬r</div>
      <div style="font-size:.8rem;font-weight:600;color:var(--navy);">Dilema Destructivo</div>
    </div>
    <div onclick="showPage('reglas');expandRule('abs')" style="cursor:pointer;background:white;border:1px solid var(--border);border-radius:10px;padding:.9rem 1rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
      <div style="font-family:'DM Mono',monospace;font-size:.85rem;color:var(--navy);margin-bottom:.3rem;">p → q ∴ p → (p ∧ q)</div>
      <div style="font-size:.8rem;font-weight:600;color:var(--navy);">Absorción</div>
    </div>
  </div>

</div>

<!-- ========= REGLAS ========= -->
<div class="page" id="page-reglas">
  <h2 class="section-title">Reglas de Inferencia</h2>
  <p class="section-sub">Haz clic en cada tarjeta para ver la explicación completa, forma formal y ejemplos concretos de cada regla.</p>

  <div class="rules-grid" id="rules-grid"></div>
</div>

<!-- ========= QUIZ ========= -->
<div class="page" id="page-quiz">
  <div id="quiz-active">
    <div class="score-banner">
      <div>
        <h3>Quiz de Reglas de Inferencia</h3>
        <p>Identifica qué regla de inferencia se aplica en cada argumento</p>
      </div>
      <div class="score-numbers">
        <div class="sn-item"><span class="sn-val" id="q-correct">0</span><span class="sn-lbl">Correctas</span></div>
        <div class="sn-item"><span class="sn-val" id="q-total">0</span><span class="sn-lbl">Respondidas</span></div>
      </div>
    </div>

    <div class="quiz-container">
      <div class="quiz-top">
        <h2 id="q-title">Pregunta 1 de 20</h2>
        <span class="quiz-score-badge" id="q-badge">0 / 0</span>
      </div>
      <div class="quiz-body">
        <div class="quiz-question-num" id="q-num">Pregunta 1</div>
        <div class="quiz-question-text" id="q-text"></div>
        <div class="quiz-premises-box" id="q-premises"></div>
        <div class="quiz-options" id="q-options"></div>
        <div class="quiz-feedback" id="q-feedback"></div>
        <div class="quiz-nav">
          <div class="progress-dots" id="q-dots"></div>
          <button class="btn btn-primary" id="q-next" onclick="nextQuestion()" style="display:none">Siguiente →</button>
        </div>
      </div>
    </div>
  </div>

  <div id="quiz-results" style="display:none">
    <div class="results-card">
      <div class="results-emoji" id="res-emoji">🎉</div>
      <div class="results-score-big"><span id="res-score">0</span><span>/20</span></div>
      <div class="results-label" id="res-label"></div>
      <div class="results-breakdown">
        <div class="rb-item"><div class="rb-num green" id="res-correct">0</div><div class="rb-label">Correctas</div></div>
        <div class="rb-item"><div class="rb-num red" id="res-wrong">0</div><div class="rb-label">Incorrectas</div></div>
        <div class="rb-item"><div class="rb-num" id="res-pct">0%</div><div class="rb-label">Precisión</div></div>
      </div>
      <div id="res-breakdown" style="margin:.75rem 0 1rem;text-align:left;max-width:380px;margin-left:auto;margin-right:auto;"></div>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <button class="btn btn-primary" onclick="restartQuiz()">🔄 Reiniciar Quiz</button>
        <button class="btn btn-outline" onclick="showPage('ejercicios')">✏️ Ir a Ejercicios</button>
        <button class="btn btn-outline" onclick="showPage('reglas')">📖 Repasar Reglas</button>
      </div>
    </div>
  </div>
</div>

<!-- ========= EJERCICIOS ========= -->
<div class="page" id="page-ejercicios">
  <h2 class="section-title">Ejercicios por Regla</h2>
  <p class="section-sub">2 ejercicios por cada una de las 10 reglas — con situación en lenguaje natural, formalización y solución paso a paso. Practica cada regla hasta memorizarla.</p>

  <!-- PROGRESS TRACKER -->
  <div style="background:white;border:1px solid var(--border);border-radius:12px;padding:1.1rem 1.5rem;box-shadow:var(--shadow);margin-bottom:1.5rem;display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;">
    <div>
      <div style="font-size:.78rem;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;font-weight:600;">Soluciones vistas</div>
      <div style="font-family:'DM Serif Display',serif;font-size:1.6rem;color:var(--navy);line-height:1;"><span id="sol-count">0</span><span style="font-size:1rem;color:var(--slate)">/20</span></div>
    </div>
    <div style="flex:1;min-width:200px;">
      <div style="height:8px;background:var(--border);border-radius:4px;overflow:hidden;">
        <div id="sol-progress-bar" style="height:100%;background:linear-gradient(90deg,var(--green),#22c55e);border-radius:4px;transition:width .4s ease;width:0%;"></div>
      </div>
      <div style="font-size:.78rem;color:var(--slate);margin-top:.3rem;">Completa los 20 ejercicios para dominar todas las reglas</div>
    </div>
    <button class="btn btn-outline" onclick="resetSolCount()" style="font-size:.8rem;">↺ Reiniciar</button>
  </div>

  <!-- RULE TABS -->
  <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;margin-bottom:1.5rem;">
    <div style="padding:.75rem 1rem;border-bottom:1px solid var(--border);background:var(--slate-light);">
      <div style="font-size:.78rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.6rem;">Selecciona una regla para ver sus ejercicios:</div>
      <div style="display:flex;gap:.4rem;flex-wrap:wrap;" id="rule-tabs">
        <!-- built by JS -->
      </div>
    </div>
    <div id="rule-exercises-panel" style="padding:1.5rem;">
      <div style="text-align:center;padding:2rem;color:var(--slate);">
        <div style="font-size:2.5rem;margin-bottom:.75rem;">👆</div>
        <div style="font-weight:600;">Haz clic en una regla arriba para ver sus ejercicios</div>
      </div>
    </div>
  </div>

  <!-- ALL EXERCISES ACCORDION (respaldo) -->
  <div style="margin-top:2rem;">
    <h3 style="font-weight:600;font-size:1.1rem;color:var(--navy);margin-bottom:.25rem;">Todos los ejercicios en orden</h3>
    <p style="font-size:.85rem;color:var(--slate);margin-bottom:1rem;">Vista completa para repasar todas las reglas de corrido.</p>
    <div id="exercises-container"></div>
  </div>
</div>

<!-- ========= CONSTRUCTOR ========= -->
<div class="page" id="page-constructor">
  <h2 class="section-title">Constructor de Pruebas Formales</h2>
  <p class="section-sub">Construye demostraciones lógicas paso a paso, justificando cada línea con la regla aplicada.</p>

  <!-- TUTORIAL VISUAL -->
  <div style="background:white;border:1px solid var(--border);border-radius:14px;box-shadow:var(--shadow);margin-bottom:2rem;overflow:hidden;">
    <div style="background:linear-gradient(135deg,var(--navy),var(--navy2));color:white;padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;">
      <div>
        <div style="font-family:'DM Serif Display',serif;font-size:1.15rem;">📖 ¿Cómo funciona el Constructor?</div>
        <div style="color:#94a3b8;font-size:.82rem;margin-top:.2rem;">Sigue estos 4 pasos para construir tu primera prueba formal</div>
      </div>
      <button onclick="this.closest('div[id]')?.remove(); document.getElementById('tutorial-box').remove();" id="close-tutorial-btn" style="background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:white;border-radius:8px;padding:.35rem .8rem;cursor:pointer;font-size:.8rem;font-family:inherit;">✕ Cerrar tutorial</button>
    </div>
    <div id="tutorial-box">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:0;border-bottom:1px solid var(--border);">
      <div style="padding:1.25rem;border-right:1px solid var(--border);">
        <div style="width:32px;height:32px;background:var(--blue);color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;margin-bottom:.75rem;">1</div>
        <div style="font-weight:600;font-size:.9rem;margin-bottom:.4rem;color:var(--navy);">Escribe las premisas</div>
        <div style="font-size:.82rem;color:var(--slate);line-height:1.6;">Ingresa cada premisa en una línea separada. Estas son las verdades de partida de tu argumento.</div>
        <div style="font-family:'DM Mono',monospace;font-size:.8rem;background:var(--slate-light);border-radius:6px;padding:.5rem .7rem;margin-top:.6rem;color:var(--navy3);">p → q<br>q → r<br>p</div>
      </div>
      <div style="padding:1.25rem;border-right:1px solid var(--border);">
        <div style="width:32px;height:32px;background:var(--accent);color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;margin-bottom:.75rem;">2</div>
        <div style="font-weight:600;font-size:.9rem;margin-bottom:.4rem;color:var(--navy);">Define tu meta</div>
        <div style="font-size:.82rem;color:var(--slate);line-height:1.6;">En "Meta" escribe la fórmula que quieres probar. El sistema verificará si llegaste a ella al final.</div>
        <div style="font-family:'DM Mono',monospace;font-size:.9rem;background:var(--accent-light);border:1px solid #fed7aa;border-radius:6px;padding:.5rem .7rem;margin-top:.6rem;color:#92400e;">Meta: r</div>
      </div>
      <div style="padding:1.25rem;border-right:1px solid var(--border);">
        <div style="width:32px;height:32px;background:var(--purple);color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;margin-bottom:.75rem;">3</div>
        <div style="font-weight:600;font-size:.9rem;margin-bottom:.4rem;color:var(--navy);">Agrega pasos derivados</div>
        <div style="font-size:.82rem;color:var(--slate);line-height:1.6;">Por cada deducción: escribe la fórmula resultante, elige la regla usada y presiona <strong>+ Agregar</strong>.</div>
        <div style="font-size:.8rem;background:var(--purple-light);border-radius:6px;padding:.5rem .7rem;margin-top:.6rem;color:var(--purple);">Fórmula: <code>p → r</code><br>Regla: Sil. Hipotético ✓</div>
      </div>
      <div style="padding:1.25rem;">
        <div style="width:32px;height:32px;background:var(--green);color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;margin-bottom:.75rem;">4</div>
        <div style="font-weight:600;font-size:.9rem;margin-bottom:.4rem;color:var(--navy);">Verifica tu prueba</div>
        <div style="font-size:.82rem;color:var(--slate);line-height:1.6;">Cuando creas que terminaste, presiona <strong>✅ Verificar</strong>. El sistema confirma si tu última línea es la meta.</div>
        <div style="font-size:.8rem;background:var(--green-light);border:1px solid #bbf7d0;border-radius:6px;padding:.5rem .7rem;margin-top:.6rem;color:var(--green);">✅ ¡Prueba correcta!<br>Última línea = meta r</div>
      </div>
    </div>

    <!-- EXAMPLE PROOFS BUTTONS -->
    <div style="padding:1.25rem;background:var(--slate-light);border-top:1px solid var(--border);">
      <div style="font-weight:600;font-size:.88rem;color:var(--navy);margin-bottom:.75rem;">🚀 Selecciona una regla para ver su ejemplo completo en el constructor:</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.5rem;">
        <button class="btn btn-primary" onclick="loadExample(0)" style="font-size:.8rem;padding:.5rem .9rem;justify-content:flex-start;">
          <span style="background:rgba(255,255,255,.2);border-radius:4px;padding:.1rem .4rem;font-size:.72rem;margin-right:.4rem;">1</span> Modus Ponens
        </button>
        <button class="btn btn-primary" onclick="loadExample(1)" style="font-size:.8rem;padding:.5rem .9rem;justify-content:flex-start;">
          <span style="background:rgba(255,255,255,.2);border-radius:4px;padding:.1rem .4rem;font-size:.72rem;margin-right:.4rem;">2</span> Modus Tollens
        </button>
        <button class="btn btn-primary" onclick="loadExample(2)" style="font-size:.8rem;padding:.5rem .9rem;justify-content:flex-start;">
          <span style="background:rgba(255,255,255,.2);border-radius:4px;padding:.1rem .4rem;font-size:.72rem;margin-right:.4rem;">3</span> Sil. Hipotético
        </button>
        <button class="btn btn-primary" onclick="loadExample(3)" style="font-size:.8rem;padding:.5rem .9rem;justify-content:flex-start;">
          <span style="background:rgba(255,255,255,.2);border-radius:4px;padding:.1rem .4rem;font-size:.72rem;margin-right:.4rem;">4</span> Sil. Disyuntivo
        </button>
        <button class="btn btn-primary" onclick="loadExample(4)" style="font-size:.8rem;padding:.5rem .9rem;justify-content:flex-start;">
          <span style="background:rgba(255,255,255,.2);border-radius:4px;padding:.1rem .4rem;font-size:.72rem;margin-right:.4rem;">5</span> Adición
        </button>
        <button class="btn btn-primary" onclick="loadExample(5)" style="font-size:.8rem;padding:.5rem .9rem;justify-content:flex-start;">
          <span style="background:rgba(255,255,255,.2);border-radius:4px;padding:.1rem .4rem;font-size:.72rem;margin-right:.4rem;">6</span> Simplificación
        </button>
        <button class="btn btn-primary" onclick="loadExample(6)" style="font-size:.8rem;padding:.5rem .9rem;justify-content:flex-start;">
          <span style="background:rgba(255,255,255,.2);border-radius:4px;padding:.1rem .4rem;font-size:.72rem;margin-right:.4rem;">7</span> Conjunción
        </button>
        <button class="btn btn-primary" onclick="loadExample(7)" style="font-size:.8rem;padding:.5rem .9rem;justify-content:flex-start;">
          <span style="background:rgba(255,255,255,.2);border-radius:4px;padding:.1rem .4rem;font-size:.72rem;margin-right:.4rem;">8</span> Absorción
        </button>
        <button class="btn btn-primary" onclick="loadExample(8)" style="font-size:.8rem;padding:.5rem .9rem;justify-content:flex-start;">
          <span style="background:rgba(255,255,255,.2);border-radius:4px;padding:.1rem .4rem;font-size:.72rem;margin-right:.4rem;">9</span> Dilema Constructivo
        </button>
        <button class="btn btn-primary" onclick="loadExample(9)" style="font-size:.8rem;padding:.5rem .9rem;justify-content:flex-start;">
          <span style="background:rgba(255,255,255,.2);border-radius:4px;padding:.1rem .4rem;font-size:.72rem;margin-right:.4rem;">10</span> Dilema Destructivo
        </button>
      </div>
    </div>
    </div>
  </div>

  <!-- EXAMPLE PREVIEW (aparece al cargar ejemplo) -->
  <div id="example-preview" style="display:none;background:white;border:2px solid var(--accent);border-radius:14px;box-shadow:var(--shadow-lg);margin-bottom:2rem;overflow:hidden;">
    <div style="background:var(--accent);color:white;padding:.9rem 1.5rem;display:flex;justify-content:space-between;align-items:center;">
      <div style="font-weight:600;font-size:.95rem;" id="preview-title">Ejemplo cargado</div>
      <button onclick="document.getElementById('example-preview').style.display='none'" style="background:rgba(255,255,255,.2);border:none;color:white;border-radius:6px;padding:.3rem .7rem;cursor:pointer;font-size:.85rem;">✕</button>
    </div>
    <div style="padding:1.25rem;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.25rem;" id="preview-context"></div>
      <div style="font-weight:600;font-size:.88rem;color:var(--navy);margin-bottom:.75rem;">📋 Así queda la prueba paso a paso:</div>
      <div style="border:1px solid var(--border);border-radius:10px;overflow:hidden;" id="preview-table"></div>
      <div style="margin-top:1rem;padding:.9rem 1.1rem;background:var(--green-light);border:1px solid #bbf7d0;border-radius:10px;font-size:.88rem;color:var(--green);" id="preview-explanation"></div>
      <div style="margin-top:1rem;display:flex;gap:.75rem;flex-wrap:wrap;align-items:center;">
        <button class="btn btn-accent" onclick="activateExample()" id="btn-activate-example">✏️ Practicar este ejemplo (modo editable)</button>
        <button class="btn btn-outline" onclick="loadExample((currentExampleIdx+9)%10)" style="font-size:.82rem;">← Regla anterior</button>
        <button class="btn btn-outline" onclick="loadExample((currentExampleIdx+1)%10)" style="font-size:.82rem;">Siguiente regla →</button>
        <button class="btn btn-outline" onclick="document.getElementById('example-preview').style.display='none'">Cerrar</button>
      </div>
    </div>
  </div>

  <div class="practice-container">
    <div class="practice-panel">
      <div class="practice-panel-header">⚙️ Configurar tu Prueba</div>
      <div class="practice-panel-body">
        <div class="input-group">
          <label>Nombre del argumento</label>
          <input type="text" id="proof-name" placeholder="Ej: Demostración de r" value="Mi Demostración">
        </div>

        <div class="input-group">
          <label>Premisas <span style="font-weight:400;color:var(--slate)">(una por línea)</span></label>
          <div class="symbols-palette">
            <button class="sym-btn" onclick="insertSymbol('proof-premises','¬')">¬</button>
            <button class="sym-btn" onclick="insertSymbol('proof-premises','∧')">∧</button>
            <button class="sym-btn" onclick="insertSymbol('proof-premises','∨')">∨</button>
            <button class="sym-btn" onclick="insertSymbol('proof-premises','→')">→</button>
            <button class="sym-btn" onclick="insertSymbol('proof-premises','↔')">↔</button>
          </div>
          <textarea id="proof-premises" rows="4" style="font-family:'DM Mono',monospace;font-size:.9rem;resize:vertical;width:100%;padding:.7rem .9rem;border:1.5px solid var(--border);border-radius:8px;color:var(--navy);" placeholder="p → q&#10;p"></textarea>
        </div>

        <div class="input-group">
          <label>Meta <span style="font-weight:400;color:var(--slate)">(conclusión a probar)</span></label>
          <div class="symbols-palette">
            <button class="sym-btn" onclick="insertSymbol('proof-goal','¬')">¬</button>
            <button class="sym-btn" onclick="insertSymbol('proof-goal','∧')">∧</button>
            <button class="sym-btn" onclick="insertSymbol('proof-goal','∨')">∨</button>
            <button class="sym-btn" onclick="insertSymbol('proof-goal','→')">→</button>
          </div>
          <input type="text" id="proof-goal" placeholder="Ej: r" value="" style="font-family:'DM Mono',monospace;">
        </div>

        <button class="btn btn-primary" onclick="initProof()" style="width:100%;margin-bottom:.6rem;">🚀 Iniciar Prueba</button>
        <button class="btn btn-outline" onclick="openProofChallenge()" style="width:100%;font-size:.85rem;">🎯 Modo Reto — dame un problema</button>
      </div>
    </div>

    <div class="practice-panel">
      <div class="practice-panel-header">📚 Referencia Rápida de Reglas</div>
      <div class="practice-panel-body" style="max-height:380px;overflow-y:auto;">
        <div id="quick-ref"></div>
      </div>
    </div>
  </div>

  <!-- PROOF AREA -->
  <div id="proof-area" style="display:none;">
    <div style="background:white;border:1px solid var(--border);border-radius:14px;box-shadow:var(--shadow);overflow:hidden;margin-bottom:1rem;">

      <!-- Proof header -->
      <div style="background:var(--navy);color:white;padding:.9rem 1.25rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;">
        <div>
          <div style="font-family:'DM Serif Display',serif;font-size:1.05rem;" id="proof-display-name">Mi Demostración</div>
          <div style="color:#94a3b8;font-size:.78rem;margin-top:.1rem;">Meta: <span id="proof-display-goal" style="color:var(--accent);font-family:'DM Mono',monospace;"></span></div>
        </div>
        <div style="display:flex;gap:.5rem;align-items:center;">
          <span style="font-size:.78rem;color:#94a3b8;" id="proof-line-count">0 líneas</span>
        </div>
      </div>

      <!-- Hint box -->
      <div id="proof-hint" style="background:var(--blue-light);border-bottom:1px solid #bfdbfe;padding:.7rem 1.25rem;font-size:.83rem;color:#1d4ed8;display:none;">
        💡 <span id="proof-hint-text"></span>
      </div>

      <!-- Table header -->
      <div style="display:grid;grid-template-columns:44px 1fr 200px 44px;background:var(--slate-light);border-bottom:1px solid var(--border);padding:.55rem 1rem;">
        <div style="font-size:.75rem;font-weight:600;color:var(--slate);">#</div>
        <div style="font-size:.75rem;font-weight:600;color:var(--slate);">FÓRMULA</div>
        <div style="font-size:.75rem;font-weight:600;color:var(--slate);">JUSTIFICACIÓN</div>
        <div></div>
      </div>

      <div id="proof-lines"></div>

      <!-- Add row -->
      <div style="padding:.9rem 1rem;background:#fafafa;border-top:2px dashed var(--border);">
        <div style="font-size:.78rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.6rem;">➕ Agregar siguiente línea derivada</div>
        <div style="display:grid;grid-template-columns:1fr 200px auto;gap:.6rem;align-items:end;">
          <div>
            <div style="font-size:.75rem;color:var(--slate);margin-bottom:.3rem;">Fórmula deducida</div>
            <div class="symbols-palette" style="margin-bottom:.35rem;">
              <button class="sym-btn" onclick="insertSymbol('new-formula','¬')">¬</button>
              <button class="sym-btn" onclick="insertSymbol('new-formula','∧')">∧</button>
              <button class="sym-btn" onclick="insertSymbol('new-formula','∨')">∨</button>
              <button class="sym-btn" onclick="insertSymbol('new-formula','→')">→</button>
              <button class="sym-btn" onclick="insertSymbol('new-formula','↔')">↔</button>
            </div>
            <input type="text" id="new-formula" placeholder="Ej: p → r" style="width:100%;font-family:'DM Mono',monospace;" onkeydown="if(event.key==='Enter')addProofLine()">
          </div>
          <div>
            <div style="font-size:.75rem;color:var(--slate);margin-bottom:.3rem;">Regla aplicada</div>
            <select id="new-rule" style="width:100%;padding:.6rem .7rem;border:1.5px solid var(--border);border-radius:8px;font-size:.85rem;color:var(--navy);">
              <option value="">— Selecciona —</option>
              <option value="Modus Ponens (MP)">Modus Ponens (MP)</option>
              <option value="Modus Tollens (MT)">Modus Tollens (MT)</option>
              <option value="Silogismo Hipotético (SH)">Sil. Hipotético (SH)</option>
              <option value="Silogismo Disyuntivo (SD)">Sil. Disyuntivo (SD)</option>
              <option value="Adición (Ad)">Adición (Ad)</option>
              <option value="Simplificación (Sim)">Simplificación (Sim)</option>
              <option value="Conjunción (Con)">Conjunción (Con)</option>
              <option value="Dilema Constructivo (DC)">Dilema Constructivo (DC)</option>
              <option value="Dilema Destructivo (DD)">Dilema Destructivo (DD)</option>
              <option value="Absorción (Abs)">Absorción (Abs)</option>
            </select>
          </div>
          <button class="btn btn-accent" onclick="addProofLine()" style="height:38px;">+ Agregar</button>
        </div>
      </div>
    </div>

    <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-bottom:1rem;">
      <button class="btn btn-primary" onclick="checkProof()">✅ Verificar Prueba</button>
      <button class="btn btn-outline" onclick="clearProof()">🗑️ Limpiar pasos</button>
      <button class="btn btn-outline" onclick="showProofHint()">💡 Dame una pista</button>
      <button class="btn btn-outline" onclick="document.getElementById('proof-area').style.display='none';document.getElementById('proof-message').style.display='none'">✕ Cerrar</button>
    </div>

    <div id="proof-message" style="margin-top:.5rem;display:none;"></div>
  </div>

  <!-- CHALLENGE MODAL -->
  <div id="challenge-modal" style="display:none;background:white;border:2px solid var(--purple);border-radius:14px;box-shadow:var(--shadow-lg);margin-top:1rem;overflow:hidden;">
    <div style="background:var(--purple);color:white;padding:.9rem 1.5rem;display:flex;justify-content:space-between;align-items:center;">
      <div style="font-family:'DM Serif Display',serif;font-size:1.05rem;">🎯 Modo Reto</div>
      <button onclick="document.getElementById('challenge-modal').style.display='none'" style="background:rgba(255,255,255,.2);border:none;color:white;border-radius:6px;padding:.3rem .7rem;cursor:pointer;">✕</button>
    </div>
    <div style="padding:1.5rem;" id="challenge-body"></div>
  </div>

</div>

<!-- ========= CHEATSHEET ========= -->
<div class="page" id="page-cheatsheet">
  <h2 class="section-title">Guía Rápida de Referencia</h2>
  <p class="section-sub">Todas las reglas de inferencia en formato compacto para consulta rápida durante exámenes y ejercicios.</p>

  <div style="margin-bottom:1.5rem;display:flex;gap:.75rem;flex-wrap:wrap;">
    <button class="btn btn-primary" onclick="window.print()">🖨️ Imprimir</button>
    <span style="font-size:.85rem;color:var(--slate);align-self:center;">Puedes imprimir esta guía y llevarla a clase.</span>
  </div>

  <h3 style="font-weight:600;margin-bottom:1rem;color:var(--navy);">Reglas de Implicación (10 reglas fundamentales)</h3>
  <div class="cheatsheet-grid" id="cheatsheet-grid"></div>

  <h3 style="font-weight:600;margin:2rem 0 1rem;color:var(--navy);">Tabla de Verdad de Conectores</h3>
  <div style="overflow-x:auto;background:white;border-radius:12px;border:1px solid var(--border);box-shadow:var(--shadow);">
    <table>
      <thead>
        <tr>
          <th>p</th><th>q</th><th>¬p</th><th>p ∧ q</th><th>p ∨ q</th><th>p → q</th><th>p ↔ q</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="true-val">V</td><td class="true-val">V</td><td class="false-val">F</td><td class="true-val">V</td><td class="true-val">V</td><td class="true-val">V</td><td class="true-val">V</td></tr>
        <tr><td class="true-val">V</td><td class="false-val">F</td><td class="false-val">F</td><td class="false-val">F</td><td class="true-val">V</td><td class="false-val">F</td><td class="false-val">F</td></tr>
        <tr><td class="false-val">F</td><td class="true-val">V</td><td class="true-val">V</td><td class="false-val">F</td><td class="true-val">V</td><td class="true-val">V</td><td class="false-val">F</td></tr>
        <tr><td class="false-val">F</td><td class="false-val">F</td><td class="true-val">V</td><td class="false-val">F</td><td class="false-val">F</td><td class="true-val">V</td><td class="true-val">V</td></tr>
      </tbody>
    </table>
  </div>

  <h3 style="font-weight:600;margin:2rem 0 1rem;color:var(--navy);">Errores Comunes a Evitar</h3>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1rem;margin-bottom:2rem;">
    <div style="background:white;border:1px solid var(--border);border-radius:12px;padding:1.25rem;box-shadow:var(--shadow);border-left:4px solid var(--red);">
      <div style="font-weight:600;color:var(--red);margin-bottom:.5rem;">❌ Afirmación del Consecuente (INVÁLIDO)</div>
      <div style="font-family:'DM Mono',monospace;font-size:.85rem;background:var(--red-light);padding:.6rem;border-radius:6px;margin-bottom:.5rem;">p → q<br>q<br>∴ p <span style="color:var(--red)">← ¡ERROR!</span></div>
      <p style="font-size:.83rem;color:var(--slate);">Solo porque q es verdadero no significa que p sea verdadero. Ejemplo: Si llueve entonces hay nubes. Hay nubes, ¿necesariamente llueve? No.</p>
    </div>
    <div style="background:white;border:1px solid var(--border);border-radius:12px;padding:1.25rem;box-shadow:var(--shadow);border-left:4px solid var(--red);">
      <div style="font-weight:600;color:var(--red);margin-bottom:.5rem;">❌ Negación del Antecedente (INVÁLIDO)</div>
      <div style="font-family:'DM Mono',monospace;font-size:.85rem;background:var(--red-light);padding:.6rem;border-radius:6px;margin-bottom:.5rem;">p → q<br>¬p<br>∴ ¬q <span style="color:var(--red)">← ¡ERROR!</span></div>
      <p style="font-size:.83rem;color:var(--slate);">Si p es falso no sabemos nada sobre q. El condicional solo nos dice qué pasa cuando p es verdadero.</p>
    </div>
    <div style="background:white;border:1px solid var(--border);border-radius:12px;padding:1.25rem;box-shadow:var(--shadow);border-left:4px solid var(--red);">
      <div style="font-weight:600;color:var(--red);margin-bottom:.5rem;">❌ Silogismo Disyuntivo Incompleto</div>
      <div style="font-family:'DM Mono',monospace;font-size:.85rem;background:var(--red-light);padding:.6rem;border-radius:6px;margin-bottom:.5rem;">p ∨ q<br>p<br>∴ ¬q <span style="color:var(--red)">← ¡ERROR!</span></div>
      <p style="font-size:.83rem;color:var(--slate);">La disyunción no es exclusiva. Que p sea verdadero no implica que q sea falso (ambos pueden ser verdaderos).</p>
    </div>
  </div>

</div>

<!-- ========= FLASHCARDS ========= -->
<div class="page" id="page-flashcards">
  <h2 class="section-title">Flashcards — Memoriza las Reglas</h2>
  <p class="section-sub">Ve las premisas, piensa en la conclusión y luego voltea la tarjeta para verificar. Repite hasta dominarlas todas.</p>

  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem;">
    <div style="display:flex;gap:.6rem;flex-wrap:wrap;">
      <button class="btn btn-outline" id="fc-mode-all" onclick="setFlashMode('all')" style="font-size:.82rem;">Todas las reglas</button>
      <button class="btn btn-outline" id="fc-mode-hard" onclick="setFlashMode('hard')" style="font-size:.82rem;">Solo difíciles</button>
      <button class="btn btn-outline" onclick="shuffleFlash()" style="font-size:.82rem;">🔀 Mezclar</button>
    </div>
    <div style="font-size:.85rem;color:var(--slate);">Tarjeta <span id="fc-current">1</span> de <span id="fc-total">10</span> &nbsp;·&nbsp; <span id="fc-score-display" style="color:var(--green);font-weight:600;">0 dominadas</span></div>
  </div>

  <!-- Progress strip -->
  <div style="display:flex;gap:4px;margin-bottom:1.5rem;flex-wrap:wrap;" id="fc-strip"></div>

  <!-- Card -->
  <div style="perspective:1000px;margin-bottom:1.5rem;">
    <div id="fc-card" onclick="flipCard()" style="cursor:pointer;position:relative;min-height:280px;transform-style:preserve-3d;transition:transform .5s cubic-bezier(.4,0,.2,1);">
      <!-- Front -->
      <div id="fc-front" style="position:absolute;inset:0;backface-visibility:hidden;background:white;border:1px solid var(--border);border-radius:16px;box-shadow:var(--shadow-lg);display:flex;flex-direction:column;overflow:hidden;">
        <div id="fc-front-header" style="background:var(--navy);color:white;padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;">
          <div>
            <div style="font-size:.72rem;color:#94a3b8;text-transform:uppercase;letter-spacing:.08em;">Premisas</div>
            <div style="font-family:'DM Serif Display',serif;font-size:1.1rem;margin-top:.2rem;" id="fc-rule-name">Modus Ponens</div>
          </div>
          <div style="font-size:.8rem;color:#64748b;background:rgba(255,255,255,.08);border-radius:8px;padding:.3rem .8rem;">Haz clic para voltear</div>
        </div>
        <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;">
          <div id="fc-premises-display" style="font-family:'DM Mono',monospace;font-size:1.15rem;text-align:center;color:var(--navy);line-height:2.2;"></div>
          <div style="margin-top:1.5rem;border-top:2px solid var(--border);padding-top:1.2rem;width:100%;text-align:center;">
            <div style="font-size:.8rem;color:var(--slate);margin-bottom:.4rem;">¿Cuál es la conclusión?</div>
            <div style="font-family:'DM Mono',monospace;font-size:1.4rem;color:var(--border);letter-spacing:.15em;">∴ &nbsp;? ? ?</div>
          </div>
        </div>
      </div>
      <!-- Back -->
      <div id="fc-back" style="position:absolute;inset:0;backface-visibility:hidden;transform:rotateY(180deg);background:white;border:1px solid var(--border);border-radius:16px;box-shadow:var(--shadow-lg);overflow:hidden;">
        <div id="fc-back-header" style="padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;">
          <div>
            <div style="font-size:.72rem;text-transform:uppercase;letter-spacing:.08em;opacity:.7;">Respuesta</div>
            <div style="font-family:'DM Serif Display',serif;font-size:1.1rem;margin-top:.1rem;" id="fc-rule-name-back"></div>
          </div>
          <div style="font-size:.75rem;opacity:.7;font-family:'DM Mono',monospace;" id="fc-form-label"></div>
        </div>
        <div style="padding:0 1.5rem 1rem;display:flex;flex-direction:column;gap:1rem;">
          <div style="font-family:'DM Mono',monospace;font-size:1.1rem;text-align:center;padding:1rem;border-radius:10px;" id="fc-full-form"></div>
          <div style="font-size:.88rem;color:var(--text2);line-height:1.65;border-radius:10px;padding:.9rem 1rem;background:var(--slate-light);" id="fc-explanation-back"></div>
          <div style="font-size:.82rem;font-style:italic;color:var(--slate);padding:.5rem 1rem;border-left:3px solid var(--accent);" id="fc-example-back"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Controls -->
  <div style="display:flex;justify-content:center;gap:1rem;flex-wrap:wrap;margin-bottom:1.5rem;">
    <button class="btn" onclick="rateCard('hard')" style="background:#fef2f2;color:var(--red);border:1.5px solid var(--red-mid);min-width:120px;">😓 Difícil</button>
    <button class="btn btn-outline" onclick="prevCard()" style="min-width:80px;">← Anterior</button>
    <button class="btn btn-outline" onclick="nextCard()" style="min-width:80px;">Siguiente →</button>
    <button class="btn" onclick="rateCard('easy')" style="background:var(--green-light);color:var(--green);border:1.5px solid #bbf7d0;min-width:120px;">✅ La sé</button>
  </div>

  <div style="background:white;border:1px solid var(--border);border-radius:12px;padding:1.25rem;box-shadow:var(--shadow);">
    <div style="font-weight:600;font-size:.88rem;margin-bottom:.75rem;color:var(--navy);">📊 Tu progreso en esta sesión</div>
    <div style="display:flex;gap:1.5rem;flex-wrap:wrap;" id="fc-stats">
      <div style="text-align:center;"><div style="font-family:'DM Serif Display',serif;font-size:1.6rem;color:var(--green);" id="fc-easy-count">0</div><div style="font-size:.78rem;color:var(--slate);">Dominadas</div></div>
      <div style="text-align:center;"><div style="font-family:'DM Serif Display',serif;font-size:1.6rem;color:var(--red);" id="fc-hard-count">0</div><div style="font-size:.78rem;color:var(--slate);">A repasar</div></div>
      <div style="text-align:center;"><div style="font-family:'DM Serif Display',serif;font-size:1.6rem;color:var(--slate);" id="fc-unseen-count">10</div><div style="font-size:.78rem;color:var(--slate);">Sin ver</div></div>
    </div>
  </div>
</div>

<!-- ========= VALIDO/INVALIDO ========= -->
<div class="page" id="page-valido">
  <h2 class="section-title">¿Válido o Inválido?</h2>
  <p class="section-sub">El error más común en lógica es confundir argumentos válidos con falacias. Decide si cada argumento es lógicamente válido o contiene un error formal.</p>

  <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;margin-bottom:1.5rem;">
    <div style="background:var(--navy);color:white;padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;">
      <div>
        <div style="font-family:'DM Serif Display',serif;font-size:1.1rem;">Detector de Argumentos</div>
        <div style="color:#94a3b8;font-size:.78rem;margin-top:.15rem;">¿Sabes distinguir los válidos de las falacias?</div>
      </div>
      <div style="display:flex;gap:1rem;">
        <div style="text-align:center;"><span style="font-family:'DM Serif Display',serif;font-size:1.4rem;color:var(--green);" id="vi-correct">0</span><div style="font-size:.72rem;color:#64748b;">Correctas</div></div>
        <div style="text-align:center;"><span style="font-family:'DM Serif Display',serif;font-size:1.4rem;color:var(--red);" id="vi-wrong">0</span><div style="font-size:.72rem;color:#64748b;">Incorrectas</div></div>
        <div style="text-align:center;"><span style="font-family:'DM Serif Display',serif;font-size:1.4rem;color:var(--accent);" id="vi-streak">0</span><div style="font-size:.72rem;color:#64748b;">Racha</div></div>
      </div>
    </div>
    <div style="padding:1.75rem;">
      <div style="font-size:.78rem;color:var(--slate);text-transform:uppercase;letter-spacing:.08em;font-weight:600;margin-bottom:.5rem;" id="vi-num">Argumento 1</div>
      <div style="font-size:.95rem;color:var(--text2);margin-bottom:1.25rem;line-height:1.6;" id="vi-context"></div>
      <div style="background:var(--slate-light);border:1px solid var(--border);border-radius:10px;padding:1.1rem 1.25rem;font-family:'DM Mono',monospace;font-size:.95rem;margin-bottom:1.5rem;" id="vi-argument"></div>
      <div style="display:flex;gap:1rem;margin-bottom:1.25rem;flex-wrap:wrap;">
        <button class="btn" onclick="answerVI(true)" id="vi-btn-valid" style="flex:1;min-width:140px;background:var(--green-light);color:var(--green);border:2px solid #bbf7d0;font-size:.95rem;justify-content:center;">✅ VÁLIDO</button>
        <button class="btn" onclick="answerVI(false)" id="vi-btn-invalid" style="flex:1;min-width:140px;background:var(--red-light);color:var(--red);border:2px solid var(--red-mid);font-size:.95rem;justify-content:center;">❌ INVÁLIDO</button>
      </div>
      <div id="vi-feedback" style="display:none;border-radius:10px;padding:1.1rem 1.25rem;margin-bottom:1.25rem;font-size:.9rem;"></div>
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.75rem;">
        <div style="display:flex;gap:5px;flex-wrap:wrap;" id="vi-dots"></div>
        <button class="btn btn-primary" id="vi-next" onclick="nextVI()" style="display:none;">Siguiente →</button>
      </div>
    </div>
  </div>

  <div id="vi-results" style="display:none;">
    <div class="results-card">
      <div style="font-size:3.5rem;margin-bottom:1rem;" id="vi-res-emoji">🎯</div>
      <div style="font-family:'DM Serif Display',serif;font-size:3rem;color:var(--navy);line-height:1;" id="vi-res-score">0/20</div>
      <div style="color:var(--slate);margin:1rem 0 2rem;" id="vi-res-label"></div>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <button class="btn btn-primary" onclick="restartVI()">🔄 Jugar de nuevo</button>
        <button class="btn btn-outline" onclick="showPage('flashcards')">🃏 Ir a Flashcards</button>
      </div>
    </div>
  </div>
</div>

<!-- ========= TABLAS DE VERDAD ========= -->
<div class="page" id="page-tablas">
  <h2 class="section-title">Visualizador de Tablas de Verdad</h2>
  <p class="section-sub">Escribe cualquier fórmula lógica y el sistema genera su tabla de verdad completa automáticamente. Comprueba si una fórmula es tautología, contradicción o contingencia.</p>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">
    <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;">
      <div style="background:var(--navy);color:white;padding:.85rem 1.25rem;font-weight:600;font-size:.9rem;">⚡ Generador de Tabla</div>
      <div style="padding:1.25rem;">
        <div class="input-group">
          <label>Fórmula lógica</label>
          <div class="symbols-palette">
            <button class="sym-btn" onclick="insertSymbol('tt-formula','¬')">¬</button>
            <button class="sym-btn" onclick="insertSymbol('tt-formula','∧')">∧</button>
            <button class="sym-btn" onclick="insertSymbol('tt-formula','∨')">∨</button>
            <button class="sym-btn" onclick="insertSymbol('tt-formula','→')">→</button>
            <button class="sym-btn" onclick="insertSymbol('tt-formula','↔')">↔</button>
            <button class="sym-btn" onclick="insertSymbol('tt-formula','(')"> ( </button>
            <button class="sym-btn" onclick="insertSymbol('tt-formula',')')"> ) </button>
          </div>
          <input type="text" id="tt-formula" placeholder="Ej: p → (p ∧ q)" style="font-family:'DM Mono',monospace;font-size:1rem;" onkeydown="if(event.key==='Enter')generateTT()">
        </div>
        <button class="btn btn-primary" onclick="generateTT()" style="width:100%;margin-bottom:.6rem;">📊 Generar Tabla</button>
        <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
          <button class="btn btn-outline" onclick="loadTTExample('p → q')" style="font-size:.78rem;padding:.3rem .7rem;">p → q</button>
          <button class="btn btn-outline" onclick="loadTTExample('¬p ∨ q')" style="font-size:.78rem;padding:.3rem .7rem;">¬p ∨ q</button>
          <button class="btn btn-outline" onclick="loadTTExample('p ∧ ¬p')" style="font-size:.78rem;padding:.3rem .7rem;">p ∧ ¬p</button>
          <button class="btn btn-outline" onclick="loadTTExample('p ∨ ¬p')" style="font-size:.78rem;padding:.3rem .7rem;">p ∨ ¬p</button>
          <button class="btn btn-outline" onclick="loadTTExample('(p → q) ∧ (q → p)')" style="font-size:.78rem;padding:.3rem .7rem;">p ↔ q</button>
          <button class="btn btn-outline" onclick="loadTTExample('(p → q) ∧ p')" style="font-size:.78rem;padding:.3rem .7rem;">MP premisas</button>
          <button class="btn btn-outline" onclick="loadTTExample('p → (p ∧ q)')" style="font-size:.78rem;padding:.3rem .7rem;">Absorción</button>
        </div>
      </div>
    </div>
    <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;">
      <div style="background:var(--navy);color:white;padding:.85rem 1.25rem;font-weight:600;font-size:.9rem;">📖 Guía de Símbolos</div>
      <div style="padding:1.25rem;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem;font-size:.85rem;">
          <div style="padding:.5rem;background:var(--slate-light);border-radius:6px;"><span style="font-family:'DM Mono',monospace;font-weight:700;">¬p</span> — NO p (negación)</div>
          <div style="padding:.5rem;background:var(--slate-light);border-radius:6px;"><span style="font-family:'DM Mono',monospace;font-weight:700;">p ∧ q</span> — p Y q</div>
          <div style="padding:.5rem;background:var(--slate-light);border-radius:6px;"><span style="font-family:'DM Mono',monospace;font-weight:700;">p ∨ q</span> — p O q</div>
          <div style="padding:.5rem;background:var(--slate-light);border-radius:6px;"><span style="font-family:'DM Mono',monospace;font-weight:700;">p → q</span> — SI p ENTONCES q</div>
          <div style="padding:.5rem;background:var(--slate-light);border-radius:6px;"><span style="font-family:'DM Mono',monospace;font-weight:700;">p ↔ q</span> — p SI Y SOLO SI q</div>
          <div style="padding:.5rem;background:var(--slate-light);border-radius:6px;"><span style="font-family:'DM Mono',monospace;font-weight:700;">( )</span> — agrupa subf.</div>
        </div>
        <div style="margin-top:1rem;padding:.75rem;background:var(--accent-light);border-radius:8px;font-size:.82rem;color:#92400e;">
          <strong>💡 Tip:</strong> Usa letras minúsculas (p, q, r, s) para las variables. La precedencia es: ¬ primero, luego ∧, luego ∨, luego →, luego ↔.
        </div>
      </div>
    </div>
  </div>

  <div id="tt-result" style="display:none;">
    <div id="tt-verdict" style="border-radius:12px;padding:1.1rem 1.5rem;margin-bottom:1.25rem;font-size:.95rem;font-weight:600;"></div>
    <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;">
      <div style="background:var(--navy);color:white;padding:.75rem 1.25rem;font-family:'DM Mono',monospace;font-size:.9rem;" id="tt-formula-display"></div>
      <div style="overflow-x:auto;" id="tt-table-container"></div>
    </div>
  </div>

  <div id="tt-error" style="display:none;" class="alert alert-warning"></div>
</div>

<!-- ========= EQUIVALENCIAS ========= -->
<div class="page" id="page-equivalencias">
  <h2 class="section-title">Equivalencias Lógicas</h2>
  <p class="section-sub">Las leyes de equivalencia permiten reemplazar una fórmula por otra con el mismo valor de verdad. Son esenciales para simplificar y transformar expresiones lógicas.</p>
  <div id="equiv-grid"></div>
</div>

<!-- ========= COMPLETA LA PRUEBA ========= -->
<div class="page" id="page-completa">
  <h2 class="section-title">Completa la Prueba</h2>
  <p class="section-sub">Se muestra una demostración con líneas en blanco. Completa la fórmula o la regla que falta antes de revelar la respuesta.</p>
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem;">
    <div style="display:flex;gap:.6rem;">
      <button class="btn btn-outline" onclick="prevCP()" style="font-size:.82rem;">← Anterior</button>
      <button class="btn btn-outline" onclick="nextCP()" style="font-size:.82rem;">Siguiente →</button>
      <button class="btn btn-outline" onclick="shuffleCP()" style="font-size:.82rem;">🔀 Mezclar</button>
    </div>
    <div style="font-size:.85rem;color:var(--slate);">Ejercicio <span id="cp-current">1</span> de <span id="cp-total">10</span></div>
  </div>
  <div id="cp-card"></div>
</div>

<!-- ========= FORMALIZADOR ========= -->
<div class="page" id="page-formalizador">
  <h2 class="section-title">Formalizador de Lenguaje Natural</h2>
  <p class="section-sub">Escribe un argumento en español y el sistema te guía para traducirlo a lógica simbólica paso a paso — la habilidad más importante para tus exámenes.</p>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">
    <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;">
      <div style="background:var(--navy);color:white;padding:.85rem 1.25rem;font-weight:600;font-size:.9rem;">🗣️ Argumento en Español</div>
      <div style="padding:1.25rem;">
        <div class="input-group">
          <label>Escribe tu argumento (una oración por línea)</label>
          <textarea id="fz-input" rows="5" style="width:100%;padding:.7rem .9rem;border:1.5px solid var(--border);border-radius:8px;font-size:.93rem;resize:vertical;" placeholder="Si llueve, me mojo.&#10;No me mojé.&#10;Por lo tanto, no llovió."></textarea>
        </div>
        <button class="btn btn-primary" onclick="formalize()" style="width:100%;margin-bottom:.6rem;">🔍 Analizar y Formalizar</button>
        <div style="font-size:.8rem;color:var(--slate);margin-bottom:.75rem;">O prueba con un ejemplo:</div>
        <div style="display:flex;gap:.5rem;flex-wrap:wrap;" id="fz-examples-btns"></div>
      </div>
    </div>
    <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;">
      <div style="background:var(--navy);color:white;padding:.85rem 1.25rem;font-weight:600;font-size:.9rem;">📐 Guía de Formalización</div>
      <div style="padding:1.25rem;font-size:.85rem;">
        <div style="display:grid;gap:.5rem;">
          <div style="padding:.6rem;background:var(--slate-light);border-radius:6px;"><strong>"Si…entonces"</strong> → p → q</div>
          <div style="padding:.6rem;background:var(--slate-light);border-radius:6px;"><strong>"…solo si…"</strong> → p → q</div>
          <div style="padding:.6rem;background:var(--slate-light);border-radius:6px;"><strong>"…si y solo si…"</strong> → p ↔ q</div>
          <div style="padding:.6rem;background:var(--slate-light);border-radius:6px;"><strong>"…y…" / "…pero…"</strong> → p ∧ q</div>
          <div style="padding:.6rem;background:var(--slate-light);border-radius:6px;"><strong>"…o…"</strong> → p ∨ q</div>
          <div style="padding:.6rem;background:var(--slate-light);border-radius:6px;"><strong>"no…" / "es falso que…"</strong> → ¬p</div>
          <div style="padding:.6rem;background:var(--slate-light);border-radius:6px;"><strong>"por lo tanto" / "en consecuencia"</strong> → ∴ (conclusión)</div>
        </div>
      </div>
    </div>
  </div>
  <div id="fz-result" style="display:none;"></div>
</div>

<!-- ========= VERIFICADOR ========= -->
<div class="page" id="page-verificador">
  <h2 class="section-title">Verificador de Argumentos</h2>
  <p class="section-sub">Escribe tus propias premisas y conclusión. El sistema verifica automáticamente si el argumento es válido usando tablas de verdad.</p>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">
    <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;">
      <div style="background:var(--navy);color:white;padding:.85rem 1.25rem;font-weight:600;font-size:.9rem;">⚙️ Tu Argumento</div>
      <div style="padding:1.25rem;">
        <div class="input-group">
          <label>Premisas (una por línea)</label>
          <div class="symbols-palette">
            <button class="sym-btn" onclick="insertSymbol('vf-premises','¬')">¬</button>
            <button class="sym-btn" onclick="insertSymbol('vf-premises','∧')">∧</button>
            <button class="sym-btn" onclick="insertSymbol('vf-premises','∨')">∨</button>
            <button class="sym-btn" onclick="insertSymbol('vf-premises','→')">→</button>
            <button class="sym-btn" onclick="insertSymbol('vf-premises','↔')">↔</button>
          </div>
          <textarea id="vf-premises" rows="4" style="width:100%;padding:.7rem .9rem;border:1.5px solid var(--border);border-radius:8px;font-family:'DM Mono',monospace;font-size:.9rem;resize:vertical;" placeholder="p → q&#10;p"></textarea>
        </div>
        <div class="input-group">
          <label>Conclusión</label>
          <div class="symbols-palette">
            <button class="sym-btn" onclick="insertSymbol('vf-conclusion','¬')">¬</button>
            <button class="sym-btn" onclick="insertSymbol('vf-conclusion','∧')">∧</button>
            <button class="sym-btn" onclick="insertSymbol('vf-conclusion','∨')">∨</button>
            <button class="sym-btn" onclick="insertSymbol('vf-conclusion','→')">→</button>
          </div>
          <input type="text" id="vf-conclusion" placeholder="q" style="font-family:'DM Mono',monospace;">
        </div>
        <button class="btn btn-primary" onclick="verifyArgument()" style="width:100%;">🔍 Verificar Validez</button>
      </div>
    </div>
    <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;">
      <div style="background:var(--navy);color:white;padding:.85rem 1.25rem;font-weight:600;font-size:.9rem;">💡 Ejemplos rápidos</div>
      <div style="padding:1.25rem;display:flex;flex-direction:column;gap:.5rem;" id="vf-examples"></div>
    </div>
  </div>
  <div id="vf-result" style="display:none;"></div>
</div>

<!-- ========= ÁRBOL SINTÁCTICO ========= -->
<div class="page" id="page-arbol">
  <h2 class="section-title">Árbol Sintáctico</h2>
  <p class="section-sub">Visualiza cómo se descompone cualquier fórmula lógica en un árbol de subfórmulas. Ayuda a entender la precedencia de operadores y la estructura interna de las fórmulas.</p>
  <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;margin-bottom:1.5rem;">
    <div style="background:var(--navy);color:white;padding:.85rem 1.25rem;font-weight:600;font-size:.9rem;">🌳 Generador de Árbol</div>
    <div style="padding:1.25rem;">
      <div class="input-group">
        <label>Fórmula lógica</label>
        <div class="symbols-palette">
          <button class="sym-btn" onclick="insertSymbol('tree-formula','¬')">¬</button>
          <button class="sym-btn" onclick="insertSymbol('tree-formula','∧')">∧</button>
          <button class="sym-btn" onclick="insertSymbol('tree-formula','∨')">∨</button>
          <button class="sym-btn" onclick="insertSymbol('tree-formula','→')">→</button>
          <button class="sym-btn" onclick="insertSymbol('tree-formula','↔')">↔</button>
          <button class="sym-btn" onclick="insertSymbol('tree-formula','(')"> ( </button>
          <button class="sym-btn" onclick="insertSymbol('tree-formula',')')"> ) </button>
        </div>
        <input type="text" id="tree-formula" placeholder="Ej: (p → q) ∧ ¬q" style="font-family:'DM Mono',monospace;font-size:1rem;" onkeydown="if(event.key==='Enter')generateTree()">
      </div>
      <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
        <button class="btn btn-primary" onclick="generateTree()">🌳 Generar Árbol</button>
        <button class="btn btn-outline" onclick="loadTreeEx('p → q')" style="font-size:.8rem;">p → q</button>
        <button class="btn btn-outline" onclick="loadTreeEx('(p → q) ∧ ¬q')" style="font-size:.8rem;">(p→q) ∧ ¬q</button>
        <button class="btn btn-outline" onclick="loadTreeEx('(p ∧ q) → (r ∨ ¬s)')" style="font-size:.8rem;">(p∧q)→(r∨¬s)</button>
        <button class="btn btn-outline" onclick="loadTreeEx('¬(p ∧ q)')" style="font-size:.8rem;">¬(p∧q)</button>
      </div>
    </div>
  </div>
  <div id="tree-result" style="display:none;background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;">
    <div style="background:var(--navy);color:white;padding:.75rem 1.25rem;font-family:'DM Mono',monospace;font-size:.9rem;" id="tree-formula-display"></div>
    <div style="padding:1.5rem;overflow-x:auto;" id="tree-container"></div>
    <div style="padding:1rem 1.5rem;background:var(--slate-light);border-top:1px solid var(--border);font-size:.82rem;color:var(--slate);">
      <strong>Cómo leer el árbol:</strong> La raíz (arriba) es la fórmula completa. Cada nodo interno es un operador. Las hojas (abajo) son variables atómicas. El árbol se evalúa de abajo hacia arriba.
    </div>
  </div>
  <div id="tree-error" style="display:none;" class="alert alert-warning"></div>
</div>

<!-- ========= DUELO ========= -->
<div class="page" id="page-duelo">
  <h2 class="section-title">⚔️ Duelo 1 vs 1</h2>
  <p class="section-sub">Dos jugadores compiten respondiendo preguntas de reglas de inferencia. Cada uno responde en su turno desde la misma pantalla.</p>
  <div id="duelo-setup">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">
      <div style="background:white;border:2px solid #3b82f6;border-radius:12px;padding:1.5rem;box-shadow:var(--shadow);">
        <div style="font-size:1.8rem;margin-bottom:.5rem;">🔵</div>
        <div class="input-group"><label>Nombre del Jugador 1</label><input type="text" id="p1-name" value="Jugador 1"></div>
      </div>
      <div style="background:white;border:2px solid #dc2626;border-radius:12px;padding:1.5rem;box-shadow:var(--shadow);">
        <div style="font-size:1.8rem;margin-bottom:.5rem;">🔴</div>
        <div class="input-group"><label>Nombre del Jugador 2</label><input type="text" id="p2-name" value="Jugador 2"></div>
      </div>
    </div>
    <div style="background:white;border:1px solid var(--border);border-radius:12px;padding:1.25rem 1.5rem;box-shadow:var(--shadow);margin-bottom:1.5rem;">
      <div style="font-weight:700;margin-bottom:1rem;font-size:.95rem;">⚙️ Configuración del Duelo</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;">
        <div>
          <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem;">Número de preguntas</label>
          <div style="display:flex;gap:.5rem;">
            <button onclick="setDueloOpt('duelo-rounds',this,'10')" class="game-opt-btn active" data-group="duelo-rounds">10</button>
            <button onclick="setDueloOpt('duelo-rounds',this,'15')" class="game-opt-btn" data-group="duelo-rounds">15</button>
            <button onclick="setDueloOpt('duelo-rounds',this,'20')" class="game-opt-btn" data-group="duelo-rounds">20</button>
          </div>
          <input type="hidden" id="duelo-rounds" value="10">
        </div>
        <div>
          <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem;">Tiempo por pregunta: <span id="duelo-time-label" style="color:var(--accent);">20 seg</span></label>
          <input type="range" id="duelo-time" min="5" max="60" step="5" value="20" style="width:100%;" oninput="document.getElementById('duelo-time-label').textContent=this.value+' seg'">
          <div style="display:flex;justify-content:space-between;font-size:.72rem;color:var(--slate);margin-top:.2rem;"><span>5 seg</span><span>30 seg</span><span>60 seg</span></div>
        </div>
      </div>
    </div>
    <button class="btn btn-primary" onclick="startDuelo()" style="font-size:1rem;padding:.75rem 2.5rem;">⚔️ ¡Comenzar Duelo!</button>
  </div>
  <div id="duelo-game" style="display:none;"></div>
  <div id="duelo-results" style="display:none;"></div>
</div>

<!-- ========= LOGROS ========= -->
<div class="page" id="page-logros">
  <h2 class="section-title">🏆 Mis Logros</h2>
  <p class="section-sub">Desbloquea insignias completando actividades en el sitio. Tu progreso se guarda automáticamente entre sesiones.</p>
  <div id="logros-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;margin-bottom:2rem;"></div>
  <div style="background:white;border:1px solid var(--border);border-radius:12px;padding:1.25rem;box-shadow:var(--shadow);margin-bottom:1.5rem;">
    <div style="font-weight:600;margin-bottom:.75rem;font-size:.95rem;">📊 Estadísticas Persistentes</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:.75rem;" id="logros-stats"></div>
  </div>
  <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
    <button class="btn btn-primary" onclick="exportStudentPDF()">📄 Exportar Reporte PDF</button>
    <button class="btn btn-outline" onclick="AppState.set('achievements',[]); AppState._data={}; AppState.save(); location.reload();" style="font-size:.82rem;">↺ Reiniciar progreso</button>
  </div>
</div>

<!-- ========= GENERADOR DE EXAMEN ========= -->
<div class="page" id="page-examen">
  <h2 class="section-title">📄 Generador de Examen</h2>
  <p class="section-sub">Configura y genera un examen de lógica listo para imprimir, con preguntas seleccionadas aleatoriamente y clave de respuestas incluida.</p>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">
    <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;">
      <div style="background:var(--navy);color:white;padding:.85rem 1.25rem;font-weight:600;font-size:.9rem;">⚙️ Configurar Examen</div>
      <div style="padding:1.25rem;">
        <div class="input-group"><label>Nombre del curso</label><input type="text" id="ex-course" value="Lógica — IYA008"></div>
        <div class="input-group"><label>Nombre del profesor</label><input type="text" id="ex-teacher" value="Prof. George Mármol"></div>
        <div class="input-group"><label>Fecha</label><input type="date" id="ex-date"></div>
        <div class="input-group"><label>Título del examen</label><input type="text" id="ex-title" value="Evaluación: Reglas de Inferencia"></div>
        <div class="input-group">
          <label>Número de preguntas</label>
          <select id="ex-num" style="width:100%;padding:.6rem .8rem;border:1.5px solid var(--border);border-radius:8px;">
            <option value="5">5 preguntas</option>
            <option value="10" selected>10 preguntas</option>
            <option value="15">15 preguntas</option>
            <option value="20">20 preguntas (todas)</option>
          </select>
        </div>
        <div class="input-group">
          <label>Tipo de preguntas</label>
          <select id="ex-type" style="width:100%;padding:.6rem .8rem;border:1.5px solid var(--border);border-radius:8px;">
            <option value="identify">Identificar la regla</option>
            <option value="validinvalid">Válido o Inválido</option>
            <option value="mixed">Mixto</option>
          </select>
        </div>
        <div style="display:flex;gap:.6rem;flex-wrap:wrap;">
          <button class="btn btn-primary" onclick="generateExam()" style="flex:1;">👁️ Vista Previa</button>
          <button class="btn btn-accent" onclick="printExam()" style="flex:1;">🖨️ Imprimir</button>
        </div>
      </div>
    </div>
    <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;">
      <div style="background:var(--navy);color:white;padding:.85rem 1.25rem;font-weight:600;font-size:.9rem;">ℹ️ Acerca del Generador</div>
      <div style="padding:1.25rem;font-size:.88rem;color:var(--text2);line-height:1.7;">
        <p style="margin-bottom:.75rem;">El generador crea exámenes con preguntas seleccionadas aleatoriamente del banco de <strong>60+ preguntas</strong> disponibles en el sistema.</p>
        <p style="margin-bottom:.75rem;">Cada examen incluye automáticamente:</p>
        <ul style="padding-left:1.2rem;margin-bottom:.75rem;">
          <li>Encabezado con datos del curso</li>
          <li>Campo para nombre y matrícula del estudiante</li>
          <li>Preguntas numeradas con espacio para respuesta</li>
          <li>Clave de respuestas en página separada</li>
        </ul>
        <p>Puedes generar múltiples versiones con distribución diferente de preguntas.</p>
      </div>
    </div>
  </div>
  <div id="exam-preview" style="display:none;"></div>
</div>
<!-- ========= SUPERVIVENCIA ========= -->
<div class="page" id="page-supervivencia">
  <h2 class="section-title">❤️ Modo Supervivencia</h2>
  <p class="section-sub">Responde correctamente para seguir con vida. Cada error quita una vida. Selecciona las reglas que quieres practicar antes de comenzar.</p>
  <div id="surv-setup">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">

      <!-- Selección de reglas -->
      <div style="background:white;border:1px solid var(--border);border-radius:14px;padding:1.5rem;box-shadow:var(--shadow);">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
          <div style="font-weight:700;font-size:.95rem;">📚 Reglas a practicar</div>
          <div style="display:flex;gap:.4rem;">
            <button onclick="survSelectAll()" style="font-size:.72rem;background:var(--navy);color:white;border:none;border-radius:6px;padding:.25rem .6rem;cursor:pointer;">Todas</button>
            <button onclick="survSelectNone()" style="font-size:.72rem;background:var(--slate-light);color:var(--slate);border:1px solid var(--border);border-radius:6px;padding:.25rem .6rem;cursor:pointer;">Ninguna</button>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:.5rem;" id="surv-rule-list"></div>
        <div style="margin-top:.9rem;padding:.6rem .8rem;background:var(--slate-light);border-radius:8px;font-size:.8rem;color:var(--slate);" id="surv-q-count">
          <span id="surv-count-num" style="font-weight:700;color:var(--navy);">20</span> preguntas disponibles
        </div>
      </div>

      <!-- Configuración de partida -->
      <div style="background:white;border:1px solid var(--border);border-radius:14px;padding:1.5rem;box-shadow:var(--shadow);">
        <div style="font-weight:700;font-size:.95rem;margin-bottom:1rem;">⚙️ Configuración</div>
        <div style="margin-bottom:1.1rem;">
          <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem;">Vidas iniciales</label>
          <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
            <button onclick="setGameOpt('surv-lives',this,'1')" class="game-opt-btn" data-group="surv-lives">☠️ 1</button>
            <button onclick="setGameOpt('surv-lives',this,'3')" class="game-opt-btn active" data-group="surv-lives">❤️ 3</button>
            <button onclick="setGameOpt('surv-lives',this,'5')" class="game-opt-btn" data-group="surv-lives">❤️ 5</button>
            <button onclick="setGameOpt('surv-lives',this,'99')" class="game-opt-btn" data-group="surv-lives">♾️ Infinitas</button>
          </div>
          <input type="hidden" id="surv-lives" value="3">
        </div>
        <div style="margin-bottom:1.1rem;">
          <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem;">
            Tiempo por pregunta: <span id="surv-time-label" style="color:var(--accent);">Sin límite</span>
          </label>
          <input type="range" id="surv-time" min="0" max="60" step="5" value="0" style="width:100%;"
            oninput="document.getElementById('surv-time-label').textContent=this.value==0?'Sin límite':this.value+' seg'">
          <div style="display:flex;justify-content:space-between;font-size:.72rem;color:var(--slate);margin-top:.2rem;">
            <span>Sin límite</span><span>30 seg</span><span>60 seg</span>
          </div>
        </div>
        <div style="margin-bottom:1.25rem;">
          <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem;">Orden de preguntas</label>
          <div style="display:flex;gap:.5rem;">
            <button onclick="setGameOpt('surv-order',this,'random')" class="game-opt-btn active" data-group="surv-order">🔀 Aleatorio</button>
            <button onclick="setGameOpt('surv-order',this,'sequential')" class="game-opt-btn" data-group="surv-order">📋 Por regla</button>
          </div>
          <input type="hidden" id="surv-order" value="random">
        </div>
        <button class="btn btn-primary" onclick="startSurvival()" style="width:100%;font-size:1rem;padding:.75rem;" id="surv-start-btn">
          ❤️ ¡Comenzar Supervivencia!
        </button>
        <div style="margin-top:.75rem;text-align:center;font-size:.78rem;color:var(--slate);">
          Selecciona al menos 1 regla para comenzar
        </div>
      </div>
    </div>

    <!-- Récord -->
    <div style="background:var(--accent-light);border:1px solid #fed7aa;border-radius:10px;padding:.9rem 1.1rem;font-size:.85rem;color:#92400e;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;">
      <span>🏆 <strong>Récord de esta sesión:</strong> <span id="surv-record">0 preguntas</span></span>
      <span style="font-size:.78rem;color:#b45309;">El récord se guarda mientras tengas la página abierta</span>
    </div>
  </div>
  <div id="surv-game" style="display:none;"></div>
</div>

<!-- ========= CONTRARRELOJ ========= -->
<div class="page" id="page-contrarreloj">
  <h2 class="section-title">⏱️ Contrarreloj</h2>
  <p class="section-sub">Responde tantas preguntas como puedas antes de que el tiempo termine. Cada respuesta correcta da puntos extra. ¡Velocidad y precisión!</p>
  <div id="crl-setup">
    <div style="background:white;border:1px solid var(--border);border-radius:14px;padding:1.5rem;box-shadow:var(--shadow);max-width:520px;margin-bottom:1.5rem;">
      <div style="font-weight:700;font-size:.95rem;margin-bottom:1rem;">⚙️ Configura tu partida</div>
      <div style="margin-bottom:1rem;">
        <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem;">Duración total</label>
        <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
          <button onclick="setGameOpt('crl-duration',this,'60')" class="game-opt-btn" data-group="crl-duration">1 min</button>
          <button onclick="setGameOpt('crl-duration',this,'120')" class="game-opt-btn active" data-group="crl-duration">2 min</button>
          <button onclick="setGameOpt('crl-duration',this,'180')" class="game-opt-btn" data-group="crl-duration">3 min</button>
          <button onclick="setGameOpt('crl-duration',this,'300')" class="game-opt-btn" data-group="crl-duration">5 min</button>
        </div>
        <input type="hidden" id="crl-duration" value="120">
      </div>
      <div style="margin-bottom:1.25rem;">
        <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.4rem;">Sistema de puntuación</label>
        <div style="display:flex;gap:.5rem;">
          <button onclick="setGameOpt('crl-scoring',this,'normal')" class="game-opt-btn active" data-group="crl-scoring">Normal (+10 por correcta)</button>
          <button onclick="setGameOpt('crl-scoring',this,'speed')" class="game-opt-btn" data-group="crl-scoring">Velocidad (+tiempo restante)</button>
        </div>
        <input type="hidden" id="crl-scoring" value="normal">
      </div>
      <button class="btn btn-accent" onclick="startContrarreloj()" style="width:100%;font-size:1rem;padding:.75rem;">⏱️ ¡Empezar!</button>
    </div>
    <div style="background:var(--blue-light);border:1px solid #bfdbfe;border-radius:10px;padding:.9rem 1.1rem;max-width:520px;font-size:.85rem;color:#1d4ed8;">
      <strong>🏆 Mejor puntuación:</strong> <span id="crl-record">0 puntos</span>
    </div>
  </div>
  <div id="crl-game" style="display:none;"></div>
</div>

<!-- ========= DETECTIVE LÓGICO ========= -->
<div class="page" id="page-misterio">
  <h2 class="section-title">🔍 Detective Lógico</h2>
  <p class="section-sub">Un caso lógico narrado en lenguaje natural. Usando las pistas dadas y las reglas de inferencia, debes identificar la conclusión correcta. ¡Piensa como Sherlock!</p>
  <div id="mystery-setup">
    <div style="background:white;border:1px solid var(--border);border-radius:14px;padding:1.5rem;box-shadow:var(--shadow);max-width:500px;margin-bottom:1.5rem;">
      <div style="font-weight:700;font-size:.95rem;margin-bottom:1rem;">⚙️ Configura el caso</div>
      <div style="margin-bottom:1rem;">
        <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem;">Dificultad</label>
        <div style="display:flex;gap:.5rem;">
          <button onclick="setGameOpt('mystery-diff',this,'easy')" class="game-opt-btn active" data-group="mystery-diff">🟢 Fácil</button>
          <button onclick="setGameOpt('mystery-diff',this,'medium')" class="game-opt-btn" data-group="mystery-diff">🟡 Medio</button>
          <button onclick="setGameOpt('mystery-diff',this,'hard')" class="game-opt-btn" data-group="mystery-diff">🔴 Difícil</button>
        </div>
        <input type="hidden" id="mystery-diff" value="easy">
      </div>
      <div style="margin-bottom:1.25rem;">
        <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem;">Tiempo por caso: <span id="mystery-time-label" style="color:var(--accent);">Sin límite</span></label>
        <input type="range" id="mystery-time" min="0" max="120" step="10" value="0" style="width:100%;" oninput="document.getElementById('mystery-time-label').textContent=this.value==0?'Sin límite':this.value+' seg'">
        <div style="display:flex;justify-content:space-between;font-size:.72rem;color:var(--slate);margin-top:.2rem;"><span>Sin límite</span><span>60 seg</span><span>2 min</span></div>
      </div>
      <button class="btn btn-primary" onclick="startMystery()" style="width:100%;font-size:1rem;padding:.75rem;">🔍 ¡Investigar!</button>
    </div>
  </div>
  <div id="mystery-game" style="display:none;"></div>
</div>

<!-- ========= TORNEO ========= -->
<div class="page" id="page-torneo">
  <h2 class="section-title">🏟️ Torneo (4 Jugadores)</h2>
  <p class="section-sub">Cuatro jugadores compiten en eliminación directa. Semifinal y Final. El campeón es quien mejor domine las reglas de inferencia.</p>
  <div id="torneo-setup">
    <div style="background:white;border:1px solid var(--border);border-radius:14px;padding:1.5rem;box-shadow:var(--shadow);margin-bottom:1.5rem;">
      <div style="font-weight:700;font-size:.95rem;margin-bottom:1rem;">👥 Jugadores</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.25rem;">
        <div style="background:#eff6ff;border:1.5px solid #bfdbfe;border-radius:10px;padding:1rem;">
          <div style="font-size:1.1rem;margin-bottom:.4rem;">🔵 Semifinal 1</div>
          <input type="text" id="t-p1" value="Jugador 1" style="width:100%;margin-bottom:.5rem;padding:.45rem .7rem;border:1px solid var(--border);border-radius:6px;font-size:.88rem;">
          <input type="text" id="t-p2" value="Jugador 2" style="width:100%;padding:.45rem .7rem;border:1px solid var(--border);border-radius:6px;font-size:.88rem;">
        </div>
        <div style="background:#fef2f2;border:1.5px solid #fca5a5;border-radius:10px;padding:1rem;">
          <div style="font-size:1.1rem;margin-bottom:.4rem;">🔴 Semifinal 2</div>
          <input type="text" id="t-p3" value="Jugador 3" style="width:100%;margin-bottom:.5rem;padding:.45rem .7rem;border:1px solid var(--border);border-radius:6px;font-size:.88rem;">
          <input type="text" id="t-p4" value="Jugador 4" style="width:100%;padding:.45rem .7rem;border:1px solid var(--border);border-radius:6px;font-size:.88rem;">
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.25rem;">
        <div>
          <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem;">Preguntas por ronda</label>
          <div style="display:flex;gap:.5rem;">
            <button onclick="setGameOpt('torneo-rounds',this,'5')" class="game-opt-btn active" data-group="torneo-rounds">5</button>
            <button onclick="setGameOpt('torneo-rounds',this,'10')" class="game-opt-btn" data-group="torneo-rounds">10</button>
            <button onclick="setGameOpt('torneo-rounds',this,'15')" class="game-opt-btn" data-group="torneo-rounds">15</button>
          </div>
          <input type="hidden" id="torneo-rounds" value="5">
        </div>
        <div>
          <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem;">Tiempo por pregunta: <span id="torneo-time-label" style="color:var(--accent);">20 seg</span></label>
          <input type="range" id="torneo-time" min="5" max="60" step="5" value="20" style="width:100%;" oninput="document.getElementById('torneo-time-label').textContent=this.value+' seg'">
        </div>
      </div>
      <button class="btn btn-primary" onclick="startTorneo()" style="font-size:1rem;padding:.75rem 2.5rem;">🏟️ ¡Comenzar Torneo!</button>
    </div>
  </div>
  <div id="torneo-bracket" style="display:none;margin-bottom:1.5rem;"></div>
  <div id="torneo-game" style="display:none;"></div>
  <div id="torneo-results" style="display:none;"></div>
</div>

<!-- ========= ENCUENTRA EL ERROR ========= -->
<div class="page" id="page-errores">
  <h2 class="section-title">🔎 Encuentra el Error</h2>
  <p class="section-sub">Se te presenta una prueba formal con un paso incorrecto. Tu misión: identificar exactamente cuál es el error y explicar por qué falla. El ejercicio más parecido a corregir un examen.</p>

  <div id="err-setup">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.5rem;">
      <div style="background:white;border:1px solid var(--border);border-radius:14px;padding:1.5rem;box-shadow:var(--shadow);">
        <div style="font-weight:700;font-size:.95rem;margin-bottom:1rem;color:var(--navy);">⚙️ Configuración</div>
        <div style="margin-bottom:1rem;">
          <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem;">Dificultad</label>
          <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
            <button onclick="setGameOpt('err-diff',this,'facil')" class="game-opt-btn active" data-group="err-diff">🟢 Fácil</button>
            <button onclick="setGameOpt('err-diff',this,'medio')" class="game-opt-btn" data-group="err-diff">🟡 Medio</button>
            <button onclick="setGameOpt('err-diff',this,'dificil')" class="game-opt-btn" data-group="err-diff">🔴 Difícil</button>
            <button onclick="setGameOpt('err-diff',this,'todos')" class="game-opt-btn" data-group="err-diff">🎲 Todos</button>
          </div>
          <input type="hidden" id="err-diff" value="facil">
        </div>
        <div style="margin-bottom:1rem;">
          <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem;">Modo de respuesta</label>
          <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
            <button onclick="setGameOpt('err-mode',this,'click')" class="game-opt-btn active" data-group="err-mode">👆 Clic en la línea</button>
            <button onclick="setGameOpt('err-mode',this,'write')" class="game-opt-btn" data-group="err-mode">✍️ Escribe el número</button>
          </div>
          <input type="hidden" id="err-mode" value="click">
        </div>
        <button class="btn btn-primary" onclick="startErrorGame()" style="font-size:1rem;padding:.75rem 2.5rem;width:100%;">🔎 ¡Comenzar!</button>
      </div>
      <div style="background:var(--purple-light);border:1px solid #ddd6fe;border-radius:14px;padding:1.5rem;box-shadow:var(--shadow);">
        <div style="font-weight:700;font-size:.95rem;margin-bottom:.75rem;color:var(--purple);">🎯 ¿Cómo funciona?</div>
        <div style="font-size:.88rem;color:var(--text2);line-height:1.7;">
          <div style="display:flex;gap:.6rem;margin-bottom:.5rem;"><span style="color:var(--purple);font-weight:700;">1.</span><span>Se te muestra una prueba formal completa con premisas y pasos derivados.</span></div>
          <div style="display:flex;gap:.6rem;margin-bottom:.5rem;"><span style="color:var(--purple);font-weight:700;">2.</span><span><strong>Uno de los pasos es incorrecto</strong> — la fórmula no se sigue de las líneas citadas usando la regla indicada.</span></div>
          <div style="display:flex;gap:.6rem;margin-bottom:.5rem;"><span style="color:var(--purple);font-weight:700;">3.</span><span>Haz clic (o escribe el número) de la línea errónea.</span></div>
          <div style="display:flex;gap:.6rem;"><span style="color:var(--purple);font-weight:700;">4.</span><span>Recibirás explicación detallada de por qué falla y cuál es la derivación correcta.</span></div>
        </div>
      </div>
    </div>
  </div>

  <div id="err-game" style="display:none;"></div>
  <div id="err-results" style="display:none;"></div>
</div>


<!-- ========= CADENA LÓGICA ========= -->
<div class="page" id="page-cadena">
  <h2 class="section-title">🔗 Cadena Lógica</h2>
  <p class="section-sub">Se te dan los pasos de una prueba formal desordenados. Arrástralos al orden correcto y verifica tu solución. Entrena la construcción activa de argumentos.</p>

  <div id="cadena-setup">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.5rem;">
      <div style="background:white;border:1px solid var(--border);border-radius:14px;padding:1.5rem;box-shadow:var(--shadow);">
        <div style="font-weight:700;font-size:.95rem;margin-bottom:1rem;color:var(--navy);">⚙️ Configuración</div>
        <div style="margin-bottom:1rem;">
          <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem;">Dificultad</label>
          <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
            <button onclick="setGameOpt('cadena-diff',this,'facil')" class="game-opt-btn active" data-group="cadena-diff">🟢 Fácil</button>
            <button onclick="setGameOpt('cadena-diff',this,'medio')" class="game-opt-btn" data-group="cadena-diff">🟡 Medio</button>
            <button onclick="setGameOpt('cadena-diff',this,'dificil')" class="game-opt-btn" data-group="cadena-diff">🔴 Difícil</button>
            <button onclick="setGameOpt('cadena-diff',this,'todos')" class="game-opt-btn" data-group="cadena-diff">🎲 Todos</button>
          </div>
          <input type="hidden" id="cadena-diff" value="facil">
        </div>
        <div style="margin-bottom:1rem;">
          <label style="font-size:.82rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:.5rem;">Mostrar pistas</label>
          <div style="display:flex;gap:.5rem;">
            <button onclick="setGameOpt('cadena-hints',this,'si')" class="game-opt-btn active" data-group="cadena-hints">💡 Con pistas</button>
            <button onclick="setGameOpt('cadena-hints',this,'no')" class="game-opt-btn" data-group="cadena-hints">🧠 Sin pistas</button>
          </div>
          <input type="hidden" id="cadena-hints" value="si">
        </div>
        <button class="btn btn-primary" onclick="startCadenaGame()" style="font-size:1rem;padding:.75rem 2.5rem;width:100%;">🔗 ¡Comenzar!</button>
      </div>
      <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:14px;padding:1.5rem;box-shadow:var(--shadow);">
        <div style="font-weight:700;font-size:.95rem;margin-bottom:.75rem;color:var(--green);">🎯 ¿Cómo funciona?</div>
        <div style="font-size:.88rem;color:var(--text2);line-height:1.7;">
          <div style="display:flex;gap:.6rem;margin-bottom:.5rem;"><span style="color:var(--green);font-weight:700;">1.</span><span>Se te muestran las premisas fijas arriba y los pasos derivados <strong>desordenados</strong> abajo.</span></div>
          <div style="display:flex;gap:.6rem;margin-bottom:.5rem;"><span style="color:var(--green);font-weight:700;">2.</span><span>Arrastra cada paso al slot correcto en la zona de construcción.</span></div>
          <div style="display:flex;gap:.6rem;margin-bottom:.5rem;"><span style="color:var(--green);font-weight:700;">3.</span><span>Cuando tengas todos los pasos colocados, pulsa <strong>Verificar</strong>.</span></div>
          <div style="display:flex;gap:.6rem;"><span style="color:var(--green);font-weight:700;">4.</span><span>Recibirás feedback línea por línea: ✅ correcto o ❌ incorrecto con explicación.</span></div>
        </div>
      </div>
    </div>
  </div>

  <div id="cadena-game" style="display:none;"></div>
  <div id="cadena-results" style="display:none;"></div>
</div>


</main>

<script>
/* =========================================================
   MEJORAS v3 — Inyectadas al inicio del script original
   Theme toggle, persistencia, logros, bug fixes
   ========================================================= */

// ── Theme Toggle ──
(function(){
  var saved = localStorage.getItem('logica-theme');
  if(saved === 'dark') document.documentElement.setAttribute('data-theme','dark');
})();

function toggleTheme() {
  var html = document.documentElement;
  var isDark = html.getAttribute('data-theme') === 'dark';
  html.setAttribute('data-theme', isDark ? 'light' : 'dark');
  localStorage.setItem('logica-theme', isDark ? 'light' : 'dark');
  var icon = document.getElementById('theme-icon');
  var label = document.getElementById('theme-label');
  if(icon) icon.textContent = isDark ? '🌙' : '☀️';
  if(label) label.textContent = isDark ? 'Noche' : 'Día';
}

// ── State Persistence ──
var AppState = {
  _key: 'logica-pro-state',
  _data: null,
  load: function() {
    try { this._data = JSON.parse(localStorage.getItem(this._key)) || {}; }
    catch(e) { this._data = {}; }
    return this._data;
  },
  save: function() {
    try { localStorage.setItem(this._key, JSON.stringify(this._data)); } catch(e) {}
  },
  get: function(path) {
    if(!this._data) this.load();
    if(!path) return this._data;
    return path.split('.').reduce(function(o,k){ return o && o[k]; }, this._data);
  },
  set: function(path, val) {
    if(!this._data) this.load();
    var keys = path.split('.'), obj = this._data;
    for(var i=0; i<keys.length-1; i++) { if(!obj[keys[i]]) obj[keys[i]]={}; obj=obj[keys[i]]; }
    obj[keys[keys.length-1]] = val;
    this.save();
  },
  inc: function(path) { this.set(path, (this.get(path)||0)+1); }
};
AppState.load();

// ── Achievement System ──
var Achievements = {
  defs: [
    {id:'first_visit',icon:'🎓',name:'Primera Visita',desc:'Visitaste la plataforma'},
    {id:'explorer',icon:'🗺️',name:'Explorador',desc:'Visitaste 5+ secciones'},
    {id:'quiz_complete',icon:'📝',name:'Quiz Completo',desc:'Completaste el quiz'},
    {id:'quiz_perfect',icon:'🏆',name:'Perfección',desc:'20/20 en el quiz'},
    {id:'survivor_5',icon:'❤️',name:'Superviviente',desc:'5+ en supervivencia'},
    {id:'survivor_10',icon:'💪',name:'Resistencia',desc:'10+ en supervivencia'},
    {id:'speedster',icon:'⚡',name:'Velocista',desc:'5+ pts contrarreloj'},
    {id:'exercises_10',icon:'📚',name:'Estudioso',desc:'Viste 10 soluciones'},
    {id:'exercises_20',icon:'🎯',name:'Maestro',desc:'20 ejercicios completados'},
    {id:'five_games',icon:'🎮',name:'Jugador',desc:'5 partidas jugadas'},
  ],
  _unlocked: new Set(AppState.get('achievements') || []),
  check: function() {
    var self = this, news = [];
    var s = AppState;
    this.defs.forEach(function(d) {
      if(self._unlocked.has(d.id)) return;
      var ok = false;
      if(d.id==='first_visit') ok=true;
      else if(d.id==='explorer') ok=(s.get('pagesVisited')||[]).length>=5;
      else if(d.id==='quiz_complete') ok=(s.get('quiz.played')||0)>=1;
      else if(d.id==='quiz_perfect') ok=(s.get('quiz.best')||0)>=20;
      else if(d.id==='survivor_5') ok=(s.get('surv.record')||0)>=5;
      else if(d.id==='survivor_10') ok=(s.get('surv.record')||0)>=10;
      else if(d.id==='speedster') ok=(s.get('crl.record')||0)>=5;
      else if(d.id==='exercises_10') ok=(s.get('solCount')||0)>=10;
      else if(d.id==='exercises_20') ok=(s.get('solCount')||0)>=20;
      else if(d.id==='five_games') ok=(s.get('gamesPlayed')||0)>=5;
      if(ok) { self._unlocked.add(d.id); news.push(d); }
    });
    if(news.length) {
      s.set('achievements', Array.from(self._unlocked));
      news.forEach(function(d) {
        var t = document.createElement('div');
        t.className = 'achievement-toast';
        t.innerHTML = '<div style="font-size:2rem;">'+d.icon+'</div><div><div style="font-size:.72rem;color:#94a3b8;text-transform:uppercase;">🏆 LOGRO</div><div style="font-weight:600;">'+d.name+'</div><div style="font-size:.8rem;color:#94a3b8;">'+d.desc+'</div></div>';
        document.body.appendChild(t);
        setTimeout(function(){t.style.opacity='0';t.style.transition='opacity .3s';setTimeout(function(){t.remove()},300)},3500);
      });
    }
  },
  getAll: function() { var u=this._unlocked; return this.defs.map(function(d){return Object.assign({},d,{unlocked:u.has(d.id)});}); },
  getProgress: function() { return {unlocked:this._unlocked.size,total:this.defs.length}; }
};

// ── Timer Cleanup ──
var _activeTimers = new Set();
function safeSetInterval(fn,ms) { var id=setInterval(fn,ms); _activeTimers.add(id); return id; }
function safeSetTimeout(fn,ms) { var id=setTimeout(fn,ms); _activeTimers.add(id); return id; }
function clearAllGameTimers() { _activeTimers.forEach(function(id){clearInterval(id);clearTimeout(id);}); _activeTimers.clear(); }

// ── Fisher-Yates shuffle (non-mutating) ──
function fisherYates(arr) {
  var a = arr.slice();
  for(var i=a.length-1;i>0;i--) { var j=Math.floor(Math.random()*(i+1)); var t=a[i]; a[i]=a[j]; a[j]=t; }
  return a;
}

// ====================== DATA ======================
const RULES = [
  {
    id: 'mp',
    name: 'Modus Ponens',
    latin: 'Modo que afirma',
    icon: '→',
    color: '#3b82f6',
    bg: '#eff6ff',
    badge: 'badge-blue',
    premises: ['p → q', 'p'],
    conclusion: 'q',
    description: 'Si tenemos un condicional (p → q) y la premisa p es verdadera, entonces podemos concluir q. Es la regla más usada en lógica y en la vida cotidiana. Básicamente: si la regla aplica y la condición se cumple, se sigue la consecuencia.',
    example: {
      p1: 'Si estudio (p), entonces apruebo el examen (q)',
      p2: 'Estudio (p)',
      c: 'Por lo tanto, apruebo el examen (q)'
    },
    tips: 'Orden: primero el condicional, luego el antecedente. El resultado es siempre el consecuente.'
  },
  {
    id: 'mt',
    name: 'Modus Tollens',
    latin: 'Modo que niega',
    icon: '¬',
    color: '#dc2626',
    bg: '#fef2f2',
    badge: 'badge-blue',
    premises: ['p → q', '¬q'],
    conclusion: '¬p',
    description: 'Si tenemos un condicional (p → q) y sabemos que q es falso (¬q), entonces debemos concluir que p también es falso (¬p). Es la contrapositiva en acción: si la consecuencia no ocurre, la causa tampoco pudo haber ocurrido.',
    example: {
      p1: 'Si hay fuego (p), entonces hay humo (q)',
      p2: 'No hay humo (¬q)',
      c: 'Por lo tanto, no hay fuego (¬p)'
    },
    tips: 'Se "invierte y niega" el condicional. La clave está en negar el consecuente para negar el antecedente.'
  },
  {
    id: 'hs',
    name: 'Silogismo Hipotético',
    latin: 'Transitivity of implication',
    icon: '⛓',
    color: '#7c3aed',
    bg: '#f5f3ff',
    badge: 'badge-purple',
    premises: ['p → q', 'q → r'],
    conclusion: 'p → r',
    description: 'Cuando tenemos una cadena de condicionales, podemos "encadenarlos" para obtener un condicional directo del primero al último. Es como la transitividad: si A lleva a B, y B lleva a C, entonces A lleva directamente a C.',
    example: {
      p1: 'Si llueve (p), los caminos se mojan (q)',
      p2: 'Si los caminos se mojan (q), hay accidentes (r)',
      c: 'Por lo tanto, si llueve (p), hay accidentes (r)'
    },
    tips: 'El consecuente de la primera premisa debe ser idéntico al antecedente de la segunda.'
  },
  {
    id: 'sd',
    name: 'Silogismo Disyuntivo',
    latin: 'Eliminación de la disyunción',
    icon: '∨',
    color: '#f97316',
    bg: '#fff7ed',
    badge: 'badge-orange',
    premises: ['p ∨ q', '¬p'],
    conclusion: 'q',
    description: 'Si tenemos una disyunción (p o q es verdad) y sabemos que una de ellas es falsa, la otra debe ser necesariamente verdadera. Es como decir: "o una cosa o la otra; si no es lo primero, entonces es lo segundo".',
    example: {
      p1: 'O voy al cine (p) o me quedo en casa (q)',
      p2: 'No voy al cine (¬p)',
      c: 'Por lo tanto, me quedo en casa (q)'
    },
    tips: 'Funciona en ambas direcciones: puedes negar p para concluir q, o negar q para concluir p.'
  },
  {
    id: 'ad',
    name: 'Adición',
    latin: 'Addition',
    icon: '+',
    color: '#16a34a',
    bg: '#f0fdf4',
    badge: 'badge-green',
    premises: ['p'],
    conclusion: 'p ∨ q',
    description: 'A partir de una proposición verdadera, podemos agregarle cualquier otra proposición mediante una disyunción. Si p es verdadera, entonces "p o cualquier cosa" también es verdadera, porque la disyunción solo requiere que una parte sea verdadera.',
    example: {
      p1: 'Hoy es martes (p)',
      p2: '—',
      c: 'Por lo tanto, hoy es martes O mañana llueve (p ∨ q)'
    },
    tips: 'q puede ser CUALQUIER proposición. La regla es lógicamente válida aunque q sea absurda o ni siquiera conozcamos su valor de verdad.'
  },
  {
    id: 'sim',
    name: 'Simplificación',
    latin: 'Simplification',
    icon: '∧',
    color: '#0891b2',
    bg: '#ecfeff',
    badge: 'badge-blue',
    premises: ['p ∧ q'],
    conclusion: 'p',
    description: 'Si tenemos una conjunción verdadera (p y q ambas son verdaderas), podemos extraer cualquiera de sus componentes. Es intuitivo: si "A y B" es verdad, entonces A por sí solo también es verdad.',
    example: {
      p1: 'Estudio y trabajo (p ∧ q)',
      p2: '—',
      c: 'Por lo tanto, estudio (p) — o bien: trabajo (q)'
    },
    tips: 'Puedes extraer el primer componente (p) o el segundo (q). Ambas formas son válidas.'
  },
  {
    id: 'con',
    name: 'Conjunción',
    latin: 'Conjunction',
    icon: '∧',
    color: '#0d9488',
    bg: '#f0fdfa',
    badge: 'badge-green',
    premises: ['p', 'q'],
    conclusion: 'p ∧ q',
    description: 'Si tenemos dos proposiciones verdaderas por separado, podemos unirlas en una sola conjunción. Es la operación inversa a la simplificación: juntamos lo que está separado.',
    example: {
      p1: 'El cielo está nublado (p)',
      p2: 'Hace frío (q)',
      c: 'Por lo tanto, el cielo está nublado Y hace frío (p ∧ q)'
    },
    tips: 'Ambas premisas deben estar disponibles en la demostración. No puedes conjuntar una premisa con algo que no has probado.'
  },
  {
    id: 'dl',
    name: 'Dilema Constructivo',
    latin: 'Constructive dilemma',
    icon: '⊕',
    color: '#9333ea',
    bg: '#faf5ff',
    badge: 'badge-purple',
    premises: ['(p → q) ∧ (r → s)', 'p ∨ r'],
    conclusion: 'q ∨ s',
    description: 'Tenemos dos condicionales y sabemos que al menos uno de sus antecedentes es verdadero. Sin importar cuál es el verdadero, podemos concluir que al menos uno de los consecuentes también es verdadero. Es un razonamiento por casos.',
    example: {
      p1: 'Si estudio (p) apruebo (q), y si duermo bien (r) rindo mejor (s)',
      p2: 'O estudio (p) o duermo bien (r)',
      c: 'Por lo tanto, o apruebo (q) o rindo mejor (s)'
    },
    tips: 'La forma abreviada es válida: si p→q y r→s, y p∨r, entonces q∨s.'
  },
  {
    id: 'dd',
    name: 'Dilema Destructivo',
    latin: 'Destructive dilemma',
    icon: '⊕',
    color: '#be123c',
    bg: '#fff1f2',
    badge: 'badge-orange',
    premises: ['(p → q) ∧ (r → s)', '¬q ∨ ¬s'],
    conclusion: '¬p ∨ ¬r',
    description: 'Tenemos dos condicionales y sabemos que al menos uno de sus consecuentes es falso. Por Modus Tollens aplicado dos veces y Silogismo Disyuntivo, concluimos que al menos uno de los antecedentes es también falso.',
    example: {
      p1: 'Si estudio (p) apruebo (q), y si me cuido (r) estoy sano (s)',
      p2: 'O no apruebo (¬q) o no estoy sano (¬s)',
      c: 'Por lo tanto, o no estudio (¬p) o no me cuido (¬r)'
    },
    tips: 'Es como aplicar Modus Tollens a ambos condicionales simultáneamente.'
  },
  {
    id: 'abs',
    name: 'Absorción',
    latin: 'Absorption',
    icon: '⊂',
    color: '#b45309',
    bg: '#fffbeb',
    badge: 'badge-orange',
    premises: ['p → q'],
    conclusion: 'p → (p ∧ q)',
    description: 'Si p implica q, entonces p implica (p y q). Esto se debe a que si p es verdadera y p→q, entonces q también lo es, por lo que tenemos tanto p como q. La regla "absorbe" la condición en la conclusión.',
    example: {
      p1: 'Si eres estudiante (p), entonces tienes carnet (q)',
      p2: '—',
      c: 'Por lo tanto, si eres estudiante (p), entonces eres estudiante Y tienes carnet (p ∧ q)'
    },
    tips: 'Útil para preparar una conjunción en pruebas más largas. Agrega redundancia que puede ser necesaria en pasos posteriores.'
  }
];

const QUIZ_QUESTIONS = [
  { q:'Identifica la regla aplicada:', premises:'p → q\np', conclusion:'∴ q', answer:'Modus Ponens', opts:['Modus Ponens','Modus Tollens','Silogismo Hipotético','Adición'], explain:'Tenemos el condicional (p→q) y el antecedente (p), lo que nos permite concluir el consecuente (q). Esto es exactamente Modus Ponens.' },
  { q:'¿Qué regla produce esta conclusión?', premises:'p → q\n¬q', conclusion:'∴ ¬p', answer:'Modus Tollens', opts:['Modus Ponens','Modus Tollens','Silogismo Disyuntivo','Conjunción'], explain:'Negamos el consecuente (¬q) para negar el antecedente (¬p). Esta es la esencia del Modus Tollens: "modo que niega".' },
  { q:'¿Qué regla se aplica aquí?', premises:'p → q\nq → r', conclusion:'∴ p → r', answer:'Silogismo Hipotético', opts:['Modus Ponens','Modus Tollens','Silogismo Hipotético','Dilema Constructivo'], explain:'Encadenamos dos condicionales: como p→q y q→r, concluimos p→r directamente. Esto es el Silogismo Hipotético (transitividad).' },
  { q:'Identifica la regla:', premises:'p ∨ q\n¬p', conclusion:'∴ q', answer:'Silogismo Disyuntivo', opts:['Adición','Simplificación','Silogismo Disyuntivo','Conjunción'], explain:'De la disyunción (p∨q) y la negación de una parte (¬p), concluimos la otra parte (q). Es el Silogismo Disyuntivo.' },
  { q:'¿Cuál regla justifica esta inferencia?', premises:'p', conclusion:'∴ p ∨ q', answer:'Adición', opts:['Simplificación','Adición','Conjunción','Modus Ponens'], explain:'A partir de p verdadero, añadimos cualquier q para formar la disyunción p∨q. Esto es la Adición.' },
  { q:'¿Qué regla se aplica?', premises:'p ∧ q', conclusion:'∴ p', answer:'Simplificación', opts:['Conjunción','Adición','Simplificación','Modus Tollens'], explain:'De la conjunción (p∧q), extraemos el primer componente (p). Esto es la Simplificación.' },
  { q:'Identifica la regla:', premises:'p\nq', conclusion:'∴ p ∧ q', answer:'Conjunción', opts:['Adición','Simplificación','Conjunción','Silogismo Hipotético'], explain:'Unimos dos premisas individuales en una conjunción. Esto es la Conjunción.' },
  { q:'¿Qué regla produce esta conclusión?', premises:'(p → q) ∧ (r → s)\np ∨ r', conclusion:'∴ q ∨ s', answer:'Dilema Constructivo', opts:['Dilema Constructivo','Dilema Destructivo','Modus Tollens','Silogismo Hipotético'], explain:'Tenemos dos condicionales y la disyunción de sus antecedentes. Concluimos la disyunción de sus consecuentes. Dilema Constructivo.' },
  { q:'¿Cuál regla se aplica aquí?', premises:'(p → q) ∧ (r → s)\n¬q ∨ ¬s', conclusion:'∴ ¬p ∨ ¬r', answer:'Dilema Destructivo', opts:['Dilema Constructivo','Dilema Destructivo','Modus Ponens','Adición'], explain:'Negamos los consecuentes de dos condicionales para negar (en disyunción) sus antecedentes. Dilema Destructivo.' },
  { q:'¿Qué regla justifica esta inferencia?', premises:'p → q', conclusion:'∴ p → (p ∧ q)', answer:'Absorción', opts:['Simplificación','Conjunción','Absorción','Modus Ponens'], explain:'El condicional "absorbe" su propio antecedente en el consecuente. Si p→q, entonces si p ocurre, tenemos tanto p como q. Absorción.' },
  { q:'María dice: "Si hay descuento, compro el libro. Hay descuento." ¿Qué concluye?', premises:'p → q\np', conclusion:'∴ q (compra el libro)', answer:'Modus Ponens', opts:['Modus Ponens','Modus Tollens','Adición','Simplificación'], explain:'La condición se cumple (hay descuento), así que se sigue la consecuencia (compra el libro). Modus Ponens.' },
  { q:'El detective dice: "Si el sospechoso estuvo en la escena, habría huellas. No hay huellas."', premises:'p → q\n¬q', conclusion:'∴ ¬p', answer:'Modus Tollens', opts:['Modus Tollens','Modus Ponens','Silogismo Disyuntivo','Silogismo Hipotético'], explain:'El detective usa Modus Tollens: la ausencia del efecto (huellas) niega la causa (sospechoso en escena).' },
  { q:'¿Qué regla es esta? "Apruebo o repito. No apruebo. Por tanto, repito."', premises:'p ∨ q\n¬p', conclusion:'∴ q', answer:'Silogismo Disyuntivo', opts:['Modus Ponens','Silogismo Disyuntivo','Adición','Simplificación'], explain:'Eliminamos una opción de la disyunción al negar una de ellas. Silogismo Disyuntivo.' },
  { q:'¿Qué regla aplica aquí? "Trabajo y estudio. Por tanto, trabajo."', premises:'p ∧ q', conclusion:'∴ p', answer:'Simplificación', opts:['Conjunción','Simplificación','Adición','Modus Tollens'], explain:'De "trabajo Y estudio" extraemos solo "trabajo". Simplificación.' },
  { q:'Si aprobar la materia implica que entrego tareas, ¿qué concluimos?', premises:'p → q', conclusion:'∴ p → (p ∧ q)', answer:'Absorción', opts:['Absorción','Modus Ponens','Conjunción','Silogismo Hipotético'], explain:'La conclusión incorpora el antecedente dentro del consecuente. Es la regla de Absorción.' },
  { q:'¿Cuál regla justifica: "Si p entonces q, si q entonces r, si r entonces s; por lo tanto si p entonces s"?', premises:'p → q, q → r, r → s', conclusion:'∴ p → s', answer:'Silogismo Hipotético', opts:['Modus Ponens','Dilema Constructivo','Silogismo Hipotético','Absorción'], explain:'Encadenamos condicionales múltiples. Aplicando Silogismo Hipotético dos veces: p→q y q→r nos da p→r; luego p→r y r→s nos da p→s.' },
  { q:'¿Qué regla aplica si añadimos algo a una premisa verdadera?', premises:'Llueve', conclusion:'∴ Llueve ∨ Hace sol', answer:'Adición', opts:['Conjunción','Adición','Simplificación','Silogismo Disyuntivo'], explain:'Si una proposición es verdadera, podemos disyuntarla con cualquier otra. Esto es la Adición.' },
  { q:'Si tenemos "el examen fue difícil" y "saqué buena nota", ¿qué regla nos da "el examen fue difícil Y saqué buena nota"?', premises:'p\nq', conclusion:'∴ p ∧ q', answer:'Conjunción', opts:['Adición','Simplificación','Conjunción','Modus Tollens'], explain:'Unimos dos premisas verdaderas en una conjunción. Regla de Conjunción.' },
  { q:'En la prueba: "Si vas al gimnasio mejoras tu salud, y si te alimentas bien tienes energía. O vas al gimnasio o te alimentas bien." ¿Qué concluyes?', premises:'(p → q) ∧ (r → s)\np ∨ r', conclusion:'∴ q ∨ s', answer:'Dilema Constructivo', opts:['Dilema Constructivo','Dilema Destructivo','Modus Ponens','Silogismo Hipotético'], explain:'Es el Dilema Constructivo: de dos condicionales y la disyunción de sus antecedentes, obtenemos la disyunción de sus consecuentes.' },
  { q:'AVANZADO: "Si estudio (p), apruebo (q). Si apruebo (q), me gradúo (r). Si me gradúo (r), consigo trabajo (s). Estudio (p). ¿Qué obtengo al final?"', premises:'p→q, q→r, r→s, p', conclusion:'∴ s', answer:'Silogismo Hipotético', opts:['Modus Ponens','Silogismo Hipotético','Modus Tollens','Dilema Constructivo'], explain:'Primero usamos Silogismo Hipotético varias veces para obtener p→s; luego aplicamos Modus Ponens con p para concluir s.' }
];

// ====================== STATE ======================
let currentPage = 'inicio';
let quizIndex = 0;
let quizScore = 0;
let quizAnswered = [];
let quizDone = false;
let proofLines = [];
let proofPremisesCount = 0;

// ====================== NAV ======================
const PAGE_GROUPS = {
  inicio:        { group:'inicio',       label:'Inicio' },
  reglas:        { group:'teoria',       label:'Reglas de Inferencia' },
  equivalencias: { group:'teoria',       label:'Equivalencias Lógicas' },
  cheatsheet:    { group:'teoria',       label:'Guía Rápida' },
  ejercicios:    { group:'practica',     label:'Ejercicios por Regla' },
  completa:      { group:'practica',     label:'Completa la Prueba' },
  constructor:   { group:'practica',     label:'Constructor de Pruebas' },
  quiz:          { group:'practica',     label:'Quiz de Reglas' },
  tablas:        { group:'herramientas', label:'Tablas de Verdad' },
  arbol:         { group:'herramientas', label:'Árbol Sintáctico' },
  formalizador:  { group:'herramientas', label:'Formalizador' },
  verificador:   { group:'herramientas', label:'Verificador' },
  examen:        { group:'herramientas', label:'Generador de Examen' },
  flashcards:    { group:'jugar',        label:'Flashcards' },
  valido:        { group:'jugar',        label:'Válido o Inválido' },
  supervivencia: { group:'jugar',        label:'Modo Supervivencia' },
  contrarreloj:  { group:'jugar',        label:'Contrarreloj' },
  misterio:      { group:'jugar',        label:'Detective Lógico' },
  duelo:         { group:'jugar',        label:'Duelo 1 vs 1' },
  torneo:        { group:'jugar',        label:'Torneo 4 Jugadores' },
  errores:       { group:'jugar',        label:'Encuentra el Error' },
  cadena:        { group:'jugar',        label:'Cadena Lógica' },
  logros:        { group:'jugar',        label:'Mis Logros' },
};

function showPage(page) {
  // Clear all game timers when navigating
  clearAllGameTimers();

  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const target = document.getElementById('page-' + page);
  if(target) target.classList.add('active');

  const info = PAGE_GROUPS[page] || { group:'inicio', label: page };

  // Highlight active group button
  document.querySelectorAll('.nav-group-btn').forEach(b => b.classList.remove('has-active'));
  const activeGroupBtn = document.getElementById('navbtn-' + (info.group === 'inicio' ? 'inicio' : info.group));
  if(activeGroupBtn) activeGroupBtn.classList.add('has-active');

  // Highlight active link inside dropdown
  document.querySelectorAll('.nav-dropdown a').forEach(a => a.classList.remove('active'));
  document.querySelectorAll('.nav-dropdown a').forEach(a => {
    if(a.getAttribute('onclick')?.includes(`'${page}'`)) a.classList.add('active');
  });

  // Update breadcrumb label
  const label = document.getElementById('nav-current-label');
  if(label) label.textContent = info.label;

  closeAllDropdowns();
  closeMobileNav();
  currentPage = page;
  updateProgress();
  if(page === 'logros') buildLogros();

  // Persist page visit
  var visited = AppState.get('pagesVisited') || [];
  if(visited.indexOf(page) === -1) { visited.push(page); AppState.set('pagesVisited', visited); }

  trackLogro('page_visited');
  Achievements.check();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function toggleDropdown(id) {
  const dd = document.getElementById(id);
  const isOpen = dd.classList.contains('open');
  closeAllDropdowns();
  if(!isOpen) {
    dd.classList.add('open');
    const btn = dd.previousElementSibling;
    if(btn) btn.classList.add('open');
  }
}

function closeAllDropdowns() {
  document.querySelectorAll('.nav-dropdown').forEach(d => d.classList.remove('open'));
  document.querySelectorAll('.nav-group-btn').forEach(b => b.classList.remove('open'));
}

function toggleMobileNav() {
  const nav = document.getElementById('main-nav');
  const btn = document.getElementById('hamburger-btn');
  nav.classList.toggle('mobile-open');
  btn.textContent = nav.classList.contains('mobile-open') ? '✕' : '☰';
}

function closeMobileNav() {
  const nav = document.getElementById('main-nav');
  const btn = document.getElementById('hamburger-btn');
  if(nav) nav.classList.remove('mobile-open');
  if(btn) btn.textContent = '☰';
}

document.addEventListener('click', e => {
  if(!e.target.closest('.nav-group') && !e.target.closest('#main-nav')) closeAllDropdowns();
});

function updateProgress() {
  const pages = Object.keys(PAGE_GROUPS);
  const idx = pages.indexOf(currentPage);
  const pct = Math.max(4, ((idx + 1) / pages.length) * 100);
  const bar = document.getElementById('global-progress');
  if(bar) bar.style.width = pct + '%';
}

// ====================== RULES PAGE ======================
function buildRules() {
  const grid = document.getElementById('rules-grid');
  const qr = document.getElementById('quick-ref');
  const cs = document.getElementById('cheatsheet-grid');
  grid.innerHTML = '';
  qr.innerHTML = '';
  cs.innerHTML = '';

  RULES.forEach(r => {
    // Main card
    const card = document.createElement('div');
    card.className = 'rule-card';
    card.id = 'rule-' + r.id;

    const premHtml = r.premises.map((p, i) => `
      <div class="premise-row">
        <span class="premise-label">P${i+1}</span>
        <span>${p}</span>
      </div>
    `).join('');

    const p2html = r.example.p2 !== '—' ? `<div class="ex-premise">Premisa 2: ${r.example.p2}</div>` : '';

    card.innerHTML = `
      <div class="rule-header" onclick="toggleRule('${r.id}')">
        <div class="rule-icon" style="background:${r.bg};color:${r.color};font-family:'DM Mono',monospace;">${r.icon}</div>
        <div>
          <div class="rule-name">${r.name}</div>
          <div class="rule-latin">${r.latin}</div>
        </div>
        <button class="rule-toggle">▼</button>
      </div>
      <div class="rule-body">
        <div class="formal-box">
          ${premHtml}
          <hr class="divider-line">
          <div class="conclusion-row">
            <span class="premise-label">∴</span>
            <span>${r.conclusion}</span>
          </div>
        </div>
        <p class="rule-description">${r.description}</p>
        <div class="concrete-example">
          <div class="ex-title">📌 Ejemplo Concreto</div>
          <div class="ex-premise">Premisa 1: ${r.example.p1}</div>
          ${p2html}
          <div class="ex-conclusion">∴ ${r.example.c}</div>
        </div>
        <div style="margin-top:.75rem;padding:.75rem;background:var(--accent-light);border:1px solid #fed7aa;border-radius:8px;font-size:.84rem;color:#92400e;">
          <strong>💡 Clave:</strong> ${r.tips}
        </div>
      </div>
    `;
    grid.appendChild(card);

    // Quick ref
    const qrItem = document.createElement('div');
    qrItem.style.cssText = 'padding:.6rem 0;border-bottom:1px solid var(--border);font-size:.83rem;';
    qrItem.innerHTML = `<div style="font-weight:600;color:var(--navy);margin-bottom:.3rem;">${r.name}</div>
      <div style="font-family:'DM Mono',monospace;color:var(--navy3);">${r.premises.join(', ')} ∴ ${r.conclusion}</div>`;
    qr.appendChild(qrItem);

    // Cheatsheet
    const csItem = document.createElement('div');
    csItem.className = 'cheat-item';
    csItem.innerHTML = `
      <div class="cheat-name" style="color:${r.color};">${r.name}</div>
      <div class="cheat-formula">${r.premises.join(', ')} ∴ ${r.conclusion}</div>
    `;
    cs.appendChild(csItem);
  });
}

function toggleRule(id) {
  const card = document.getElementById('rule-' + id);
  card.classList.toggle('expanded');
}

function expandRule(id) {
  setTimeout(() => {
    const card = document.getElementById('rule-' + id);
    if(card) {
      card.classList.add('expanded');
      card.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }, 100);
}

// ====================== QUIZ ======================
function buildQuiz() {
  quizIndex = 0;
  quizScore = 0;
  quizAnswered = [];
  quizDone = false;
  // Shuffle questions each session
  window._quizDeck = fisherYates(QUIZ_QUESTIONS);
  renderQuestion();
  buildDots();
}

function renderQuestion() {
  window._quizLocked = false;
  const q = (window._quizDeck || QUIZ_QUESTIONS)[quizIndex];
  const total = (window._quizDeck || QUIZ_QUESTIONS).length;
  document.getElementById('q-title').textContent = `Pregunta ${quizIndex + 1} de ${total}`;
  document.getElementById('q-num').textContent = `Pregunta ${quizIndex + 1}`;
  document.getElementById('q-text').textContent = q.q;
  document.getElementById('q-premises').innerHTML = q.premises.split('\n').map(p => `<div>${p}</div>`).join('') + `<div style="border-top:1px solid var(--border);margin-top:.5rem;padding-top:.5rem;color:var(--red);font-weight:600;">${q.conclusion}</div>`;
  document.getElementById('q-badge').textContent = `${quizScore} / ${quizAnswered.length}`;
  document.getElementById('q-correct').textContent = quizScore;
  document.getElementById('q-total').textContent = quizAnswered.length;

  const opts = document.getElementById('q-options');
  opts.innerHTML = '';
  const RULE_FORMS = {
    'Modus Ponens': 'p→q, p ∴ q', 'Modus Tollens': 'p→q, ¬q ∴ ¬p',
    'Silogismo Hipotético': 'p→q, q→r ∴ p→r', 'Silogismo Disyuntivo': 'p∨q, ¬p ∴ q',
    'Adición': 'p ∴ p∨q', 'Simplificación': 'p∧q ∴ p', 'Conjunción': 'p, q ∴ p∧q',
    'Absorción': 'p→q ∴ p→(p∧q)', 'Dilema Constructivo': '(p→q)∧(r→s), p∨r ∴ q∨s',
    'Dilema Destructivo': '(p→q)∧(r→s), ¬q∨¬s ∴ ¬p∨¬r',
  };
  // Shuffle options per question
  fisherYates(q.opts).forEach(opt => {
    const btn = document.createElement('button');
    btn.className = 'quiz-option';
    btn.textContent = opt;
    btn.title = RULE_FORMS[opt] ? `Forma: ${RULE_FORMS[opt]}` : '';
    btn.onclick = () => answerQuestion(opt, btn);
    opts.appendChild(btn);
  });

  document.getElementById('q-feedback').className = 'quiz-feedback';
  document.getElementById('q-feedback').innerHTML = '';
  document.getElementById('q-next').style.display = 'none';
  updateDots();
}

function answerQuestion(ans, btn) {
  if(window._quizLocked) return; // Block double-click
  window._quizLocked = true;
  const q = (window._quizDeck || QUIZ_QUESTIONS)[quizIndex];
  const correct = ans === q.answer;
  if(correct) quizScore++;
  quizAnswered.push(correct);
  trackLogro('quiz_answer');
  if(quizAnswered.length === (window._quizDeck||QUIZ_QUESTIONS).length && quizScore === (window._quizDeck||QUIZ_QUESTIONS).length) trackLogro('quiz_perfect');

  document.querySelectorAll('.quiz-option').forEach(b => {
    b.disabled = true;
    if(b.textContent === q.answer) b.classList.add('correct');
    else if(b === btn && !correct) b.classList.add('wrong');
  });

  const fb = document.getElementById('q-feedback');
  fb.className = 'quiz-feedback show ' + (correct ? 'correct' : 'wrong');
  fb.innerHTML = `<strong>${correct ? '✅ ¡Correcto!' : `❌ Incorrecto — La respuesta es: ${q.answer}`}</strong>${q.explain}
    <div style="margin-top:.5rem;padding:.4rem .75rem;border-radius:6px;background:rgba(0,0,0,.05);font-size:.8rem;display:inline-block;">
      💡 <em>Forma canónica de ${q.answer}:</em> ${
        q.answer==='Modus Ponens'?'p→q, p ∴ q':
        q.answer==='Modus Tollens'?'p→q, ¬q ∴ ¬p':
        q.answer==='Silogismo Hipotético'?'p→q, q→r ∴ p→r':
        q.answer==='Silogismo Disyuntivo'?'p∨q, ¬p ∴ q':
        q.answer==='Adición'?'p ∴ p∨q':
        q.answer==='Simplificación'?'p∧q ∴ p':
        q.answer==='Conjunción'?'p, q ∴ p∧q':
        q.answer==='Absorción'?'p→q ∴ p→(p∧q)':
        q.answer==='Dilema Constructivo'?'(p→q)∧(r→s), p∨r ∴ q∨s':
        q.answer==='Dilema Destructivo'?'(p→q)∧(r→s), ¬q∨¬s ∴ ¬p∨¬r':''
      }
    </div>`;

  document.getElementById('q-badge').textContent = `${quizScore} / ${quizAnswered.length}`;
  document.getElementById('q-correct').textContent = quizScore;
  document.getElementById('q-total').textContent = quizAnswered.length;

  const nextBtn = document.getElementById('q-next');
  nextBtn.style.display = 'inline-flex';
  nextBtn.textContent = quizIndex + 1 < (window._quizDeck||QUIZ_QUESTIONS).length ? 'Siguiente →' : 'Ver Resultados →';
  updateDots();
}

function nextQuestion() {
  quizIndex++;
  if(quizIndex >= (window._quizDeck||QUIZ_QUESTIONS).length) {
    showQuizResults();
    return;
  }
  renderQuestion();
}

function showQuizResults() {
  document.getElementById('quiz-active').style.display = 'none';
  document.getElementById('quiz-results').style.display = 'block';
  const pct = Math.round((quizScore / (window._quizDeck||QUIZ_QUESTIONS).length) * 100);
  document.getElementById('res-score').textContent = quizScore;
  document.getElementById('res-correct').textContent = quizScore;
  document.getElementById('res-wrong').textContent = (window._quizDeck||QUIZ_QUESTIONS).length - quizScore;
  document.getElementById('res-pct').textContent = pct + '%';

  let emoji = '📚', label = '';
  if(pct >= 90) { emoji = '🏆'; label = '¡Excelente! Dominas las reglas de inferencia.'; }
  else if(pct >= 70) { emoji = '🎉'; label = '¡Muy bien! Tienes una buena comprensión.'; }
  else if(pct >= 50) { emoji = '📖'; label = 'Vas bien, repasa las reglas que fallaste.'; }
  else { emoji = '💪'; label = 'Necesitas más práctica. Revisa las reglas y vuelve a intentarlo.'; }

  document.getElementById('res-emoji').textContent = emoji;
  document.getElementById('res-label').textContent = label;

  // Show per-rule breakdown of errors
  const ruleErrors = {};
  (window._quizDeck||QUIZ_QUESTIONS).forEach((q, i) => {
    if(!quizAnswered[i]) {
      ruleErrors[q.answer] = (ruleErrors[q.answer] || 0) + 1;
    }
  });
  const failedRules = Object.entries(ruleErrors).sort((a,b) => b[1]-a[1]);
  const breakdownEl = document.getElementById('res-breakdown');
  if(breakdownEl) {
    if(failedRules.length === 0) {
      breakdownEl.innerHTML = '<div style="color:var(--green);font-weight:600;text-align:center;padding:.75rem;">🎯 ¡Sin errores! Dominio perfecto.</div>';
    } else {
      breakdownEl.innerHTML = `<div style="font-weight:600;font-size:.85rem;color:var(--navy);margin-bottom:.5rem;">📌 Reglas a repasar:</div>` +
        failedRules.map(([rule, count]) => `
          <div style="display:flex;align-items:center;justify-content:space-between;padding:.4rem .75rem;margin-bottom:.3rem;background:var(--red-light);border:1px solid var(--red-mid);border-radius:8px;font-size:.85rem;">
            <span style="color:#991b1b;font-weight:500;">${rule}</span>
            <span style="background:#dc2626;color:white;border-radius:20px;padding:.1rem .5rem;font-size:.75rem;font-weight:700;">${count} fallo${count>1?'s':''}</span>
          </div>`).join('');
    }
  }
}

function restartQuiz() {
  document.getElementById('quiz-active').style.display = 'block';
  document.getElementById('quiz-results').style.display = 'none';
  buildQuiz();
}

function buildDots() {
  const c = document.getElementById('q-dots');
  c.innerHTML = '';
  (window._quizDeck||QUIZ_QUESTIONS).forEach((_, i) => {
    const d = document.createElement('div');
    d.className = 'progress-dot';
    d.id = 'dot-' + i;
    c.appendChild(d);
  });
}

function updateDots() {
  (window._quizDeck||QUIZ_QUESTIONS).forEach((_, i) => {
    const d = document.getElementById('dot-' + i);
    if(!d) return;
    d.className = 'progress-dot';
    if(i < quizAnswered.length) {
      d.classList.add(quizAnswered[i] ? 'done-correct' : 'done-wrong');
    } else if(i === quizIndex) {
      d.classList.add('current');
    }
  });
}

