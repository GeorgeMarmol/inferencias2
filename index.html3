    ],
    errorLine: 5,
    errorExplanation: 'El Dilema Destructivo va de NEGAR CONSECUENTES a NEGAR ANTECEDENTES: (p→q)∧(r→s) y ¬q∨¬s concluye ¬p∨¬r. Aquí la línea 3 tiene ¬p∨¬r (negaciones de antecedentes) y la línea 5 concluye ¬q∨¬s (negaciones de consecuentes) — exactamente al revés. DD no puede usarse así; necesitaría ¬q∨¬s como premisa para concluir ¬p∨¬r, no al contrario.',
    correctLine: '(Las premisas están invertidas — DD necesita ¬q∨¬s para concluir ¬p∨¬r)',
    correctReason: 'DD: (p→q)∧(r→s), ¬q∨¬s ∴ ¬p∨¬r — no al revés'
  },
  {
    diff: 'dificil',
    title: 'Error de citación en prueba larga',
    context: 'Prueba de 7 líneas donde se cita una línea incorrecta como justificación de MP.',
    legend: { p: 'Hay señal', q: 'El sistema funciona', r: 'Hay conectividad', s: 'Se puede trabajar remotamente' },
    lines: [
      { formula: 'p → q', reason: 'Premisa', type: 'premise' },
      { formula: 'r → s', reason: 'Premisa', type: 'premise' },
      { formula: 'p', reason: 'Premisa', type: 'premise' },
      { formula: 'r', reason: 'Premisa', type: 'premise' },
      { formula: 'q', reason: 'Modus Ponens (MP) — líneas 1, 3', type: 'derived' },
      { formula: 's', reason: 'Modus Ponens (MP) — líneas 2, 3', type: 'derived', isError: true },
      { formula: 'q ∧ s', reason: 'Conjunción (Con) — líneas 5, 6', type: 'derived' }
    ],
    errorLine: 6,
    errorExplanation: 'La línea 6 aplica MP citando las líneas 2 y 3. La línea 2 es r→s y la línea 3 es p (hay señal). Para aplicar MP a r→s se necesita r como premisa adicional, no p. La línea que contiene r es la línea 4. La justificación correcta debe citar "líneas 2, 4". Usar p cuando se necesita r es un error de citación que invalida la derivación de s.',
    correctLine: 's',
    correctReason: 'Modus Ponens (MP) — líneas 2, 4  (no 2, 3)'
  }
];

let errState = {};

function startErrorGame() {
  var diff = document.getElementById('err-diff').value;
  var mode = document.getElementById('err-mode').value;
  var pool = diff === 'todos' ? ERR_DATA.slice() : ERR_DATA.filter(function(e){ return e.diff === diff; });
  if(!pool.length){ alert('No hay casos para esa dificultad.'); return; }
  pool = fisherYates(pool);
  errState = { pool:pool, idx:0, correct:0, mode:mode, answered:{} };
  document.getElementById('err-setup').style.display = 'none';
  document.getElementById('err-results').style.display = 'none';
  document.getElementById('err-game').style.display = 'block';
  renderErrorGame();
}

function errRestart() {
  document.getElementById('err-game').style.display = 'none';
  document.getElementById('err-results').style.display = 'none';
  document.getElementById('err-setup').style.display = 'block';
}

function renderErrorGame() {
  var s = errState;
  if(s.idx >= s.pool.length){ endErrorGame(); return; }
  var ex = s.pool[s.idx];
  var diffColors = {facil:'#16a34a', medio:'#d97706', dificil:'#dc2626'};
  var diffLabels = {facil:'🟢 Fácil', medio:'🟡 Medio', dificil:'🔴 Difícil'};
  var col = diffColors[ex.diff] || '#64748b';
  var isAnswered = s.answered.hasOwnProperty(s.idx);
  var userAnswer = s.answered[s.idx];

  // Legend
  var legendHtml = Object.entries(ex.legend).map(function(e){
    return '<span style="display:inline-flex;align-items:center;gap:.3rem;margin-right:.75rem;margin-bottom:.3rem;font-size:.83rem;">'
      + '<code style="background:var(--slate-light);border:1px solid var(--border);border-radius:4px;padding:.1rem .4rem;'
      + 'font-weight:700;color:var(--purple);">' + e[0] + '</code>'
      + '<span style="color:var(--text2);">= ' + e[1] + '</span></span>';
  }).join('');

  // Proof lines
  var linesHtml = ex.lines.map(function(line, i){
    var n = i + 1;
    var isPremise = line.type === 'premise';
    var isError = !!line.isError;
    var wasSelected = isAnswered && userAnswer === n;

    var bg = isPremise ? '#fafafa' : 'white';
    var borderLeft = '';
    var fColor = 'var(--navy)';
    var action = '';

    if(isAnswered){
      if(isError){ bg='#fef2f2'; borderLeft='border-left:3px solid var(--red);'; fColor='var(--red)'; action='<span style="font-size:1rem;">&#10060;</span>'; }
      else if(wasSelected){ bg='#fffbeb'; borderLeft='border-left:3px solid #d97706;'; action='<span style="font-size:1rem;">&#9888;&#65039;</span>'; }
      else { action='<span style="font-size:.9rem;opacity:.3;color:var(--green);">&#10003;</span>'; }
    } else if(isPremise){
      action = '<span style="font-size:.72rem;background:#e2e8f0;color:var(--slate);border-radius:4px;padding:.1rem .35rem;font-weight:600;">P'+n+'</span>';
    } else if(s.mode === 'click'){
      action = '<button class="err-select-btn" data-line="'+n+'" style="background:var(--purple-light);border:1px solid #c4b5fd;'
        + 'border-radius:6px;padding:.2rem .5rem;font-size:.75rem;color:var(--purple);font-weight:600;cursor:pointer;font-family:inherit;">¿Error?</button>';
    }

    var rColor = isPremise ? 'var(--slate)' : 'var(--blue)';
    var rStyle = isPremise ? 'font-style:italic;' : '';

    return '<div style="display:grid;grid-template-columns:40px 1fr 1fr 50px;align-items:center;padding:.65rem 1rem;'
      + 'border-bottom:1px solid var(--border);background:'+bg+';'+borderLeft+'">'
      + '<div style="font-size:.78rem;color:var(--slate);font-weight:700;">'+n+'</div>'
      + '<div style="font-size:.9rem;font-weight:500;color:'+fColor+';">'+line.formula+'</div>'
      + '<div style="font-size:.78rem;color:'+rColor+';'+rStyle+'">'+line.reason+'</div>'
      + '<div style="text-align:center;">'+action+'</div>'
      + '</div>';
  }).join('');

  // Write-mode input
  var writeHtml = (s.mode === 'write' && !isAnswered)
    ? '<div style="padding:1rem 1.5rem;border-top:1px solid var(--border);display:flex;gap:.75rem;align-items:center;flex-wrap:wrap;">'
      + '<label style="font-size:.85rem;font-weight:600;color:var(--navy);">Línea incorrecta:</label>'
      + '<input type="number" id="err-line-input" min="1" max="'+ex.lines.length+'" placeholder="Nro..."'
      + ' style="width:80px;padding:.5rem .75rem;border:2px solid var(--purple);border-radius:8px;font-size:1rem;text-align:center;">'
      + '<button class="btn btn-primary" id="err-verify-btn" style="background:var(--purple);">🔎 Verificar</button>'
      + '</div>'
    : '';

  // Instruction banner
  var instrHtml = !isAnswered
    ? '<div style="padding:.65rem 1.5rem;background:var(--accent-light);border-bottom:1px solid #fed7aa;font-size:.83rem;color:#92400e;">'
      + (s.mode==='click' ? '👆 <strong>Haz clic en "¿Error?"</strong> junto a la línea incorrecta.'
                          : '✍️ <strong>Escribe el número</strong> de la línea incorrecta abajo y pulsa Verificar.')
      + '</div>'
    : '';

  // Feedback
  var feedbackHtml = isAnswered ? buildErrorFeedback(ex, userAnswer) : '';

  document.getElementById('err-game').innerHTML =
    '<div style="background:white;border:1px solid var(--border);border-radius:14px;box-shadow:var(--shadow-lg);overflow:hidden;margin-bottom:1rem;">'
    // Header
    + '<div style="background:var(--navy);color:white;padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.75rem;">'
      + '<div>'
        + '<div style="font-size:.72rem;color:#94a3b8;text-transform:uppercase;letter-spacing:.08em;margin-bottom:.2rem;">Caso '+(s.idx+1)+' de '+s.pool.length+' &nbsp;·&nbsp; <span style="color:'+col+';">'+(diffLabels[ex.diff]||ex.diff)+'</span></div>'
        + '<div style="font-size:1.2rem;">🔎 '+ex.title+'</div>'
      + '</div>'
      + '<div style="display:flex;gap:1.25rem;align-items:center;">'
        + '<div style="text-align:center;"><div style="font-size:1.6rem;color:var(--green);font-weight:700;">'+s.correct+'</div><div style="font-size:.7rem;color:#94a3b8;">Correctas</div></div>'
        + '<div style="text-align:center;"><div style="font-size:1.3rem;color:#94a3b8;font-weight:700;">'+(s.idx+1)+'/'+s.pool.length+'</div><div style="font-size:.7rem;color:#94a3b8;">Progreso</div></div>'
      + '</div>'
    + '</div>'
    // Context
    + '<div style="padding:.85rem 1.5rem;background:#f5f3ff;border-bottom:1px solid #e9d5ff;">'
      + '<div style="font-size:.83rem;color:#6b21a8;line-height:1.6;margin-bottom:.4rem;"><strong>📋 Situación:</strong> '+ex.context+'</div>'
      + '<div style="display:flex;flex-wrap:wrap;">'+legendHtml+'</div>'
    + '</div>'
    // Instruction
    + instrHtml
    // Table header
    + '<div style="display:grid;grid-template-columns:40px 1fr 1fr 50px;background:var(--slate-light);border-bottom:1px solid var(--border);padding:.45rem 1rem;">'
      + '<div style="font-size:.72rem;font-weight:700;color:var(--slate);">#</div>'
      + '<div style="font-size:.72rem;font-weight:700;color:var(--slate);">FÓRMULA</div>'
      + '<div style="font-size:.72rem;font-weight:700;color:var(--slate);">JUSTIFICACIÓN</div>'
      + '<div style="font-size:.72rem;font-weight:700;color:var(--slate);text-align:center;">ACCIÓN</div>'
    + '</div>'
    // Lines
    + linesHtml
    // Write input
    + writeHtml
    // Feedback
    + (feedbackHtml ? '<div style="padding:1rem 1.5rem 1.5rem;">'+feedbackHtml+'</div>' : '')
    + '</div>';

  // Attach click handlers via JS (no inline onclick with problematic quotes)
  document.querySelectorAll('.err-select-btn').forEach(function(btn){
    btn.addEventListener('mouseover', function(){ this.style.background='var(--purple)'; this.style.color='white'; });
    btn.addEventListener('mouseout', function(){ this.style.background='var(--purple-light)'; this.style.color='var(--purple)'; });
    btn.addEventListener('click', function(){
      var lineNum = parseInt(this.getAttribute('data-line'));
      selectErrorLine(lineNum);
    });
  });

  var verifyBtn = document.getElementById('err-verify-btn');
  if(verifyBtn) verifyBtn.addEventListener('click', submitErrorLine);

  var lineInput = document.getElementById('err-line-input');
  if(lineInput) lineInput.addEventListener('keydown', function(e){ if(e.key === 'Enter') submitErrorLine(); });

  // Attach feedback buttons if feedback is already showing (after answer)
  errAttachFeedbackBtns();
}

function selectErrorLine(lineNum) {
  if(errState.answered.hasOwnProperty(errState.idx)) return;
  processErrorAnswer(lineNum);
}

function submitErrorLine() {
  var input = document.getElementById('err-line-input');
  if(!input) return;
  var val = parseInt(input.value);
  var max = errState.pool[errState.idx].lines.length;
  if(!val || val < 1 || val > max){ alert('Escribe un número de línea válido (1 a ' + max + ').'); return; }
  processErrorAnswer(val);
}

function processErrorAnswer(lineNum) {
  var s = errState;
  var correct = lineNum === s.pool[s.idx].errorLine;
  s.answered[s.idx] = lineNum;
  if(correct) s.correct++;
  trackLogro('err_played');
  if(correct) trackLogro('err_correct');
  renderErrorGame();
}

function buildErrorFeedback(ex, userLine) {
  var correct = userLine === ex.errorLine;
  var selLine = ex.lines[userLine - 1];
  var isPremise = selLine && selLine.type === 'premise';
  var isLast = errState.idx + 1 >= errState.pool.length;

  var headerHtml;
  if(correct){
    headerHtml = '<div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem;">'
      + '<span style="font-size:1.4rem;">&#9989;</span>'
      + '<div><div style="font-weight:700;font-size:.95rem;color:var(--green);">¡Encontraste el error!</div>'
      + '<div style="font-size:.82rem;color:var(--slate);">La línea ' + ex.errorLine + ' es efectivamente incorrecta.</div></div>'
      + '</div>';
  } else {
    var icon = isPremise ? '&#9888;&#65039;' : '&#10060;';
    var titleColor = isPremise ? '#d97706' : 'var(--red)';
    var titleText = isPremise ? 'Las premisas no pueden ser erróneas' : 'No es la línea ' + userLine;
    var descText = isPremise
      ? 'Las premisas son datos aceptados. El error está en un paso derivado.'
      : 'Esa línea es correcta. El error real está en la línea ' + ex.errorLine + '.';
    headerHtml = '<div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem;">'
      + '<span style="font-size:1.4rem;">'+icon+'</span>'
      + '<div><div style="font-weight:700;font-size:.95rem;color:'+titleColor+';">'+titleText+'</div>'
      + '<div style="font-size:.82rem;color:var(--slate);">'+descText+'</div></div>'
      + '</div>';
  }

  var nextLabel = isLast ? '🏁 Ver resultados' : 'Siguiente caso →';
  var nextStyle = isLast ? 'background:var(--green);' : '';

  var bodyHtml =
    '<div style="background:var(--slate-light);border:1px solid var(--border);border-radius:10px;padding:1rem 1.25rem;margin-bottom:.75rem;">'
    + '<div style="font-size:.8rem;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.5rem;">🔴 Por qué falla la línea ' + ex.errorLine + ':</div>'
    + '<div style="font-size:.88rem;color:var(--text2);line-height:1.7;">' + ex.errorExplanation + '</div>'
    + '</div>'
    + '<div style="background:var(--green-light);border:1px solid #bbf7d0;border-radius:10px;padding:1rem 1.25rem;margin-bottom:.75rem;">'
    + '<div style="font-size:.8rem;font-weight:700;color:var(--green);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.5rem;">&#9989; Derivación correcta:</div>'
    + '<div style="font-size:.9rem;color:var(--navy);font-weight:600;">' + ex.errorLine + '. ' + ex.correctLine + '</div>'
    + '<div style="font-size:.82rem;color:var(--slate);margin-top:.2rem;font-style:italic;">' + ex.correctReason + '</div>'
    + '</div>'
    + '<div style="display:flex;gap:.75rem;flex-wrap:wrap;">'
    + '<button class="btn btn-primary" id="err-next-btn" style="'+nextStyle+'">'+nextLabel+'</button>'
    + '<button class="btn btn-outline" id="err-back-btn">&#8617; Nueva configuración</button>'
    + '</div>';

  var bgColor = correct ? 'var(--green-light)' : '#fff';
  var borderColor = correct ? '#bbf7d0' : 'var(--border)';
  return '<div style="background:'+bgColor+';border:1px solid '+borderColor+';border-radius:12px;padding:1.1rem 1.25rem;">'
    + headerHtml + bodyHtml + '</div>';
}

function errAttachFeedbackBtns() {
  var nextBtn = document.getElementById('err-next-btn');
  var backBtn = document.getElementById('err-back-btn');
  if(nextBtn) nextBtn.addEventListener('click', nextErrorCase);
  if(backBtn) backBtn.addEventListener('click', errRestart);
}

function nextErrorCase() {
  errState.idx++;
  renderErrorGame();
}

function endErrorGame() {
  var s = errState;
  var pct = Math.round(s.correct / s.pool.length * 100);
  var emoji = pct===100 ? '🏆' : pct>=75 ? '🔍' : pct>=50 ? '📖' : '💪';
  var label = pct===100 ? '¡Perfecto! Eres un experto detectando errores lógicos.'
    : pct>=75 ? '¡Muy bien! Tienes buen ojo crítico. Sigue con los difíciles.'
    : pct>=50 ? 'Vas bien. Repasa las reglas donde más fallaste.'
    : 'Necesitas más práctica. Revisa la forma canónica de cada regla.';

  var dColors = {facil:'var(--green)', medio:'#d97706', dificil:'var(--red)'};
  var dLabels = {facil:'🟢 Fácil', medio:'🟡 Medio', dificil:'🔴 Difícil'};
  var byDiff = {facil:{c:0,t:0}, medio:{c:0,t:0}, dificil:{c:0,t:0}};
  s.pool.forEach(function(ex,i){
    if(byDiff[ex.diff]){ byDiff[ex.diff].t++; if(s.answered[i]===ex.errorLine) byDiff[ex.diff].c++; }
  });

  var breakdownHtml = Object.entries(byDiff).filter(function(e){ return e[1].t>0; }).map(function(e){
    var d=e[0], v=e[1], p=Math.round(v.c/v.t*100);
    return '<div style="display:flex;align-items:center;gap:.75rem;padding:.6rem .9rem;background:var(--slate-light);border-radius:8px;margin-bottom:.4rem;">'
      + '<span style="font-size:.85rem;font-weight:600;min-width:80px;">'+dLabels[d]+'</span>'
      + '<div style="flex:1;height:8px;background:var(--border);border-radius:4px;overflow:hidden;">'
        + '<div style="height:100%;width:'+p+'%;background:'+dColors[d]+';border-radius:4px;"></div>'
      + '</div>'
      + '<span style="font-size:.82rem;font-weight:700;color:'+dColors[d]+';min-width:40px;text-align:right;">'+v.c+'/'+v.t+'</span>'
      + '</div>';
  }).join('');

  document.getElementById('err-game').style.display = 'none';
  document.getElementById('err-results').style.display = 'block';
  document.getElementById('err-results').innerHTML =
    '<div class="results-card">'
    + '<div style="font-size:3rem;margin-bottom:.75rem;">'+emoji+'</div>'
    + '<div style="font-size:2.5rem;font-weight:700;color:var(--navy);">'+s.correct+'<span style="font-size:1.5rem;color:var(--slate);">/'+s.pool.length+'</span></div>'
    + '<div style="font-size:1.1rem;color:var(--purple);font-weight:600;margin:.25rem 0 .5rem;">'+pct+'% de errores detectados</div>'
    + '<div style="color:var(--slate);margin-bottom:1.5rem;font-size:.92rem;">'+label+'</div>'
    + '<div style="max-width:380px;margin:0 auto 1.5rem;text-align:left;">'
      + '<div style="font-size:.82rem;font-weight:700;color:var(--navy);margin-bottom:.5rem;">Resultado por dificultad:</div>'
      + breakdownHtml
    + '</div>'
    + '<div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">'
      + '<button class="btn btn-primary" id="err-replay-btn">🔄 Jugar de nuevo</button>'
      + '<button class="btn btn-outline" id="err-goto-constructor">&#9999; Ir al Constructor</button>'
      + '<button class="btn btn-outline" id="err-goto-reglas">&#128218; Repasar reglas</button>'
    + '</div>'
    + '</div>';

  document.getElementById('err-replay-btn').addEventListener('click', errRestart);
  document.getElementById('err-goto-constructor').addEventListener('click', function(){ showPage('constructor'); });
  document.getElementById('err-goto-reglas').addEventListener('click', function(){ showPage('reglas'); });

  trackLogro('err_finished');
}
// ====================== CADENA LÓGICA ======================
const CADENA_DATA = [
  // ─── FÁCIL ───
  {
    diff: 'facil',
    title: 'Reto 1 — Modus Ponens simple',
    legend: { p: 'Tengo efectivo', q: 'Puedo pagar', r: 'Compro el producto' },
    premises: [
      { formula: 'p → q', reason: 'Premisa' },
      { formula: 'p',     reason: 'Premisa' }
    ],
    goal: 'q',
    steps: [
      { formula: 'q', reason: 'Modus Ponens (MP) — líneas 1, 2', hint: 'Si tienes p→q y p, ¿qué obtienes?' }
    ]
