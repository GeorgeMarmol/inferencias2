<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reglas de Inferencia — Lógica Proposicional</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #0f172a;
  --navy2: #1e293b;
  --navy3: #334155;
  --red: #dc2626;
  --red-light: #fef2f2;
  --red-mid: #fca5a5;
  --accent: #f97316;
  --accent-light: #fff7ed;
  --green: #16a34a;
  --green-light: #f0fdf4;
  --blue: #2563eb;
  --blue-light: #eff6ff;
  --purple: #7c3aed;
  --purple-light: #f5f3ff;
  --slate: #64748b;
  --slate-light: #f8fafc;
  --border: #e2e8f0;
  --text: #0f172a;
  --text2: #475569;
  --white: #ffffff;
  --shadow: 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.06);
  --shadow-lg: 0 8px 32px rgba(0,0,0,.12);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Plus Jakarta Sans', sans-serif;
  background: #f1f5f9;
  color: var(--text);
  min-height: 100vh;
  font-size: 16px;
  line-height: 1.6;
}

/* ========= HEADER ========= */
header {
  background: var(--navy);
  color: white;
  padding: 0;
  position: sticky;
  top: 0;
  z-index: 200;
  box-shadow: 0 2px 12px rgba(0,0,0,.25);
}

.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: flex;
  align-items: center;
  gap: 1.25rem;
  height: 60px;
}

.logo {
  font-family: 'DM Serif Display', serif;
  font-size: 1.3rem;
  color: white;
  flex: 0 0 auto;
  line-height: 1.1;
  white-space: nowrap;
}

.logo span { color: var(--accent); }

/* ---- Top nav: category pills ---- */
nav#main-nav {
  display: flex;
  gap: 2px;
  flex: 1;
  overflow: visible;
  position: relative;
}

.nav-group {
  position: relative;
}

.nav-group-btn {
  display: flex;
  align-items: center;
  gap: .35rem;
  background: none;
  border: none;
  color: #94a3b8;
  padding: .45rem .85rem;
  font-size: .82rem;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
  border-bottom: 2px solid transparent;
  transition: color .2s, background .2s, border-color .2s;
  font-family: inherit;
  border-radius: 6px 6px 0 0;
  height: 60px;
}

.nav-group-btn:hover,
.nav-group-btn.open {
  color: white;
  background: rgba(255,255,255,.07);
}

.nav-group-btn.has-active {
  color: white;
  border-bottom-color: var(--accent);
}

.nav-group-btn .nav-arrow {
  font-size: .6rem;
  opacity: .6;
  transition: transform .2s;
  display: inline-block;
}

.nav-group-btn.open .nav-arrow { transform: rotate(180deg); }

/* ---- Dropdown panel ---- */
.nav-dropdown {
  display: none;
  position: absolute;
  top: 60px;
  left: 0;
  min-width: 220px;
  background: var(--navy2);
  border: 1px solid rgba(255,255,255,.1);
  border-top: 2px solid var(--accent);
  border-radius: 0 0 12px 12px;
  box-shadow: 0 12px 40px rgba(0,0,0,.4);
  overflow: hidden;
  z-index: 300;
}

.nav-dropdown.open { display: block; }

.nav-dropdown a {
  display: flex;
  align-items: center;
  gap: .6rem;
  padding: .65rem 1rem;
  color: #94a3b8;
  font-size: .83rem;
  font-family: inherit;
  cursor: pointer;
  transition: background .15s, color .15s;
  border: none;
  background: none;
  width: 100%;
  text-align: left;
  text-decoration: none;
}

.nav-dropdown a:hover {
  background: rgba(255,255,255,.07);
  color: white;
}

.nav-dropdown a.active {
  background: rgba(249,115,22,.15);
  color: var(--accent);
  font-weight: 600;
}

.nav-dropdown a .nav-icon {
  width: 20px;
  text-align: center;
  font-size: .95rem;
  flex: 0 0 20px;
}

/* ---- Current page breadcrumb ---- */
#nav-current {
  margin-left: auto;
  font-size: .75rem;
  color: #64748b;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: .4rem;
}

#nav-current span {
  color: var(--accent);
  font-weight: 600;
}

/* ---- Mobile hamburger ---- */
.nav-hamburger {
  display: none;
  background: none;
  border: 1px solid rgba(255,255,255,.15);
  color: white;
  border-radius: 8px;
  padding: .4rem .7rem;
  cursor: pointer;
  font-size: 1.1rem;
  margin-left: auto;
}

@media (max-width: 768px) {
  nav#main-nav { display: none; }
  nav#main-nav.mobile-open {
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 60px;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--navy);
    z-index: 300;
    overflow-y: auto;
    padding: 1rem;
    gap: 0;
  }
  nav#main-nav.mobile-open .nav-group { width: 100%; }
  nav#main-nav.mobile-open .nav-group-btn { width: 100%; height: auto; padding: .7rem 1rem; border-radius: 8px; }
  nav#main-nav.mobile-open .nav-dropdown { position: static; border-radius: 8px; margin: .25rem 0 .5rem .5rem; min-width: 0; box-shadow: none; }
  nav#main-nav.mobile-open .nav-dropdown.open { display: block; }
  .nav-hamburger { display: block; }
  #nav-current { display: none; }
}

.progress-bar {
  background: var(--navy2);
  height: 3px;
  position: relative;
}

.progress-fill {
  height: 100%;
  background: var(--accent);
  transition: width .4s ease;
  width: 0%;
}

/* ========= LAYOUT ========= */
main {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem 1.5rem;
}

.page { display: none; }
.page.active { display: block; }

/* ========= HERO ========= */
.hero {
  background: var(--navy);
  border-radius: 16px;
  padding: 3rem 2.5rem;
  color: white;
  margin-bottom: 2rem;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -60px; right: -60px;
  width: 280px; height: 280px;
  border-radius: 50%;
  background: rgba(249,115,22,.08);
  pointer-events: none;
}

.hero::after {
  content: '';
  position: absolute;
  bottom: -40px; left: -40px;
  width: 200px; height: 200px;
  border-radius: 50%;
  background: rgba(249,115,22,.05);
  pointer-events: none;
}

.hero h1 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  line-height: 1.15;
  margin-bottom: 1rem;
}

.hero h1 em { color: var(--accent); font-style: normal; }

.hero p {
  color: #94a3b8;
  max-width: 600px;
  margin-bottom: 2rem;
  font-size: 1.05rem;
}

.hero-stats {
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
}

.hero-stat {
  text-align: center;
}

.hero-stat .num {
  font-family: 'DM Serif Display', serif;
  font-size: 2rem;
  color: var(--accent);
  display: block;
}

.hero-stat .label {
  font-size: .8rem;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: .08em;
}

/* ========= SECTIONS ========= */
.section-title {
  font-family: 'DM Serif Display', serif;
  font-size: 1.6rem;
  margin-bottom: .4rem;
  color: var(--navy);
}

.section-sub {
  color: var(--slate);
  margin-bottom: 1.5rem;
  font-size: .95rem;
}

/* ========= RULE CARDS ========= */
.rules-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 1.25rem;
  margin-bottom: 2rem;
}

.rule-card {
  background: white;
  border-radius: 12px;
  border: 1px solid var(--border);
  overflow: hidden;
  box-shadow: var(--shadow);
  transition: box-shadow .2s, transform .2s;
  cursor: pointer;
}

.rule-card:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-2px);
}

.rule-card.expanded { box-shadow: var(--shadow-lg); }

.rule-header {
  padding: 1.1rem 1.25rem;
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  border-bottom: 1px solid var(--border);
}

.rule-icon {
  width: 40px; height: 40px;
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem;
  flex: 0 0 40px;
}

.rule-name {
  font-weight: 600;
  font-size: 1rem;
  line-height: 1.3;
}

.rule-latin {
  font-size: .78rem;
  color: var(--slate);
  margin-top: .1rem;
}

.rule-toggle {
  margin-left: auto;
  width: 24px; height: 24px;
  border: 1px solid var(--border);
  border-radius: 50%;
  background: none;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: .9rem;
  transition: transform .25s;
  flex: 0 0 24px;
}

.rule-card.expanded .rule-toggle { transform: rotate(180deg); }

.rule-body {
  display: none;
  padding: 1.25rem;
}

.rule-card.expanded .rule-body { display: block; }

.formal-box {
  background: var(--slate-light);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1.1rem 1.25rem;
  margin-bottom: 1rem;
  font-family: 'DM Mono', monospace;
}

.premise-row {
  display: flex;
  align-items: center;
  gap: .5rem;
  font-size: .95rem;
  padding: .2rem 0;
  color: var(--navy3);
}

.premise-label {
  font-size: .72rem;
  color: var(--slate);
  width: 28px;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-weight: 600;
}

.divider-line {
  border: none;
  border-top: 1.5px solid var(--navy3);
  margin: .5rem 0;
}

.conclusion-row {
  display: flex;
  align-items: center;
  gap: .5rem;
  font-size: .95rem;
  padding: .2rem 0;
  color: var(--red);
  font-weight: 600;
}

.rule-description {
  font-size: .9rem;
  color: var(--text2);
  margin-bottom: 1rem;
  line-height: 1.65;
}

.concrete-example {
  background: linear-gradient(135deg, #f0fdf4, #ecfdf5);
  border: 1px solid #bbf7d0;
  border-radius: 10px;
  padding: 1rem 1.25rem;
  font-size: .88rem;
}

.concrete-example .ex-title {
  font-weight: 600;
  color: var(--green);
  margin-bottom: .6rem;
  font-size: .8rem;
  text-transform: uppercase;
  letter-spacing: .06em;
}

.ex-premise { color: var(--text2); padding: .1rem 0; }
.ex-conclusion { color: var(--green); font-weight: 600; padding-top: .4rem; border-top: 1px solid #bbf7d0; margin-top: .4rem; }

/* ========= QUIZ ========= */
.quiz-container {
  background: white;
  border-radius: 16px;
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
  overflow: hidden;
}

.quiz-top {
  background: var(--navy);
  padding: 1.25rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: white;
}

.quiz-top h2 {
  font-family: 'DM Serif Display', serif;
  font-size: 1.2rem;
}

.quiz-score-badge {
  background: var(--accent);
  color: white;
  border-radius: 20px;
  padding: .3rem .9rem;
  font-size: .85rem;
  font-weight: 600;
}

.quiz-body { padding: 1.75rem; }

.quiz-question-num {
  font-size: .78rem;
  color: var(--slate);
  text-transform: uppercase;
  letter-spacing: .08em;
  margin-bottom: .6rem;
  font-weight: 600;
}

.quiz-question-text {
  font-size: 1.05rem;
  font-weight: 500;
  margin-bottom: 1.5rem;
  line-height: 1.55;
  color: var(--navy);
}

.quiz-premises-box {
  background: var(--slate-light);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1rem 1.25rem;
  margin-bottom: 1.5rem;
  font-family: 'DM Mono', monospace;
  font-size: .92rem;
}

.quiz-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: .75rem;
  margin-bottom: 1.5rem;
}

@media (max-width: 600px) {
  .quiz-options { grid-template-columns: 1fr; }
  .rules-grid { grid-template-columns: 1fr; }
}

.quiz-option {
  background: white;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  padding: .85rem 1rem;
  cursor: pointer;
  text-align: left;
  font-size: .9rem;
  transition: border-color .15s, background .15s, transform .1s;
  font-family: 'DM Mono', monospace;
  color: var(--navy);
}

.quiz-option:hover:not(:disabled) {
  border-color: var(--blue);
  background: var(--blue-light);
  transform: translateY(-1px);
}

.quiz-option.correct {
  border-color: var(--green);
  background: var(--green-light);
  color: var(--green);
  font-weight: 600;
}

.quiz-option.wrong {
  border-color: var(--red);
  background: var(--red-light);
  color: var(--red);
}

.quiz-option:disabled { cursor: default; transform: none; }

.quiz-feedback {
  border-radius: 10px;
  padding: 1rem 1.25rem;
  margin-bottom: 1rem;
  font-size: .9rem;
  display: none;
}

.quiz-feedback.show { display: block; }
.quiz-feedback.correct { background: var(--green-light); border: 1px solid #bbf7d0; color: var(--green); }
.quiz-feedback.wrong { background: var(--red-light); border: 1px solid var(--red-mid); color: #991b1b; }

.quiz-feedback strong { display: block; margin-bottom: .3rem; font-size: .95rem; }

.btn {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  padding: .65rem 1.4rem;
  border-radius: 10px;
  font-size: .9rem;
  font-weight: 600;
  cursor: pointer;
  transition: all .15s;
  font-family: inherit;
  border: none;
}

.btn-primary {
  background: var(--navy);
  color: white;
}

.btn-primary:hover { background: var(--navy2); transform: translateY(-1px); }

.btn-accent {
  background: var(--accent);
  color: white;
}

.btn-accent:hover { background: #ea6c00; transform: translateY(-1px); }

.btn-outline {
  background: white;
  color: var(--navy);
  border: 1.5px solid var(--border);
}

.btn-outline:hover { border-color: var(--navy); background: var(--slate-light); }

.quiz-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.progress-dots {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.progress-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--border);
  transition: background .2s;
}

.progress-dot.done-correct { background: var(--green); }
.progress-dot.done-wrong { background: var(--red); }
.progress-dot.current { background: var(--accent); transform: scale(1.2); }

/* ========= PRACTICE ========= */
.practice-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  margin-bottom: 2rem;
}

@media (max-width: 768px) {
  .practice-container { grid-template-columns: 1fr; }
}

.practice-panel {
  background: white;
  border: 1px solid var(--border);
  border-radius: 12px;
  box-shadow: var(--shadow);
  overflow: hidden;
}

.practice-panel-header {
  background: var(--slate-light);
  padding: .8rem 1.25rem;
  border-bottom: 1px solid var(--border);
  font-weight: 600;
  font-size: .9rem;
  color: var(--navy);
}

.practice-panel-body { padding: 1.25rem; }

.input-group {
  margin-bottom: 1rem;
}

.input-group label {
  display: block;
  font-size: .82rem;
  font-weight: 600;
  color: var(--slate);
  margin-bottom: .35rem;
  text-transform: uppercase;
  letter-spacing: .06em;
}

.input-group input, .input-group select, .input-group textarea {
  width: 100%;
  padding: .7rem .9rem;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  font-size: .92rem;
  font-family: 'DM Mono', monospace;
  color: var(--navy);
  transition: border-color .2s;
  background: white;
}

.input-group input:focus, .input-group select:focus {
  outline: none;
  border-color: var(--blue);
  box-shadow: 0 0 0 3px rgba(37,99,235,.08);
}

.truth-table-container {
  overflow-x: auto;
  margin-top: .5rem;
}

table {
  width: 100%;
  border-collapse: collapse;
  font-size: .85rem;
}

th {
  background: var(--navy);
  color: white;
  padding: .6rem .8rem;
  text-align: center;
  font-family: 'DM Mono', monospace;
  font-weight: 500;
}

td {
  padding: .5rem .8rem;
  text-align: center;
  border-bottom: 1px solid var(--border);
  font-family: 'DM Mono', monospace;
}

tr:nth-child(even) td { background: var(--slate-light); }
tr:last-child td { border-bottom: none; }

td.true-val { color: var(--green); font-weight: 600; }
td.false-val { color: var(--red); }

/* ========= BUILDER ========= */
.proof-builder {
  background: white;
  border: 1px solid var(--border);
  border-radius: 12px;
  box-shadow: var(--shadow);
  overflow: hidden;
}

.proof-line {
  display: grid;
  grid-template-columns: 40px 1fr 180px 40px;
  gap: .5rem;
  align-items: center;
  padding: .6rem 1rem;
  border-bottom: 1px solid var(--border);
  font-family: 'DM Mono', monospace;
  font-size: .88rem;
}

.proof-line:last-child { border-bottom: none; }

.proof-line.premise-line { background: #fafafa; }

.proof-line .line-num {
  color: var(--slate);
  font-size: .78rem;
  text-align: right;
}

.proof-line .line-formula {
  color: var(--navy);
  font-weight: 500;
}

.proof-line .line-justif {
  color: var(--slate);
  font-size: .78rem;
}

.proof-line .line-delete {
  background: none;
  border: none;
  color: var(--border);
  cursor: pointer;
  font-size: 1rem;
  padding: 2px;
  border-radius: 4px;
  transition: color .15s;
}

.proof-line .line-delete:hover { color: var(--red); }

.proof-add-row {
  display: grid;
  grid-template-columns: 1fr 180px auto;
  gap: .5rem;
  padding: .75rem 1rem;
  background: var(--slate-light);
  border-top: 1px solid var(--border);
  align-items: center;
}

.proof-add-row input, .proof-add-row select {
  padding: .55rem .8rem;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  font-family: 'DM Mono', monospace;
  font-size: .85rem;
  color: var(--navy);
  background: white;
}

/* ========= RESULTS ========= */
.results-card {
  background: white;
  border-radius: 16px;
  border: 1px solid var(--border);
  box-shadow: var(--shadow-lg);
  text-align: center;
  padding: 2.5rem;
}

.results-emoji { font-size: 4rem; margin-bottom: 1rem; }

.results-score-big {
  font-family: 'DM Serif Display', serif;
  font-size: 4rem;
  color: var(--navy);
  line-height: 1;
  margin-bottom: .5rem;
}

.results-score-big span { color: var(--accent); }

.results-label { color: var(--slate); font-size: .95rem; margin-bottom: 2rem; }

.results-breakdown {
  display: flex;
  justify-content: center;
  gap: 2rem;
  margin-bottom: 2rem;
  flex-wrap: wrap;
}

.rb-item { text-align: center; }
.rb-num { font-family: 'DM Serif Display', serif; font-size: 1.8rem; }
.rb-num.green { color: var(--green); }
.rb-num.red { color: var(--red); }
.rb-label { font-size: .8rem; color: var(--slate); }

/* ========= CHEATSHEET ========= */
.cheatsheet-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1rem;
}

.cheat-item {
  background: white;
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1rem 1.25rem;
  box-shadow: var(--shadow);
}

.cheat-name {
  font-weight: 600;
  font-size: .9rem;
  margin-bottom: .5rem;
  color: var(--navy);
}

.cheat-formula {
  font-family: 'DM Mono', monospace;
  font-size: .83rem;
  color: var(--navy3);
  background: var(--slate-light);
  border-radius: 6px;
  padding: .4rem .7rem;
}

/* ========= BADGES ========= */
.badge {
  display: inline-block;
  padding: .2rem .7rem;
  border-radius: 20px;
  font-size: .75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .06em;
}

.badge-blue { background: var(--blue-light); color: var(--blue); }
.badge-orange { background: var(--accent-light); color: var(--accent); }
.badge-purple { background: var(--purple-light); color: var(--purple); }
.badge-green { background: var(--green-light); color: var(--green); }

/* ========= SYMBOLS PALETTE ========= */
.symbols-palette {
  display: flex;
  gap: .4rem;
  flex-wrap: wrap;
  margin-bottom: .75rem;
}

.sym-btn {
  background: var(--slate-light);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: .3rem .6rem;
  font-family: 'DM Mono', monospace;
  font-size: 1rem;
  cursor: pointer;
  transition: background .15s, border-color .15s;
}

.sym-btn:hover { background: var(--navy); color: white; border-color: var(--navy); }

/* ========= EXERCISE SECTION ========= */
.exercise-card {
  background: white;
  border: 1px solid var(--border);
  border-radius: 12px;
  box-shadow: var(--shadow);
  margin-bottom: 1.5rem;
  overflow: hidden;
}

.exercise-header {
  background: linear-gradient(135deg, var(--navy), var(--navy2));
  color: white;
  padding: .9rem 1.25rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.exercise-header h3 { font-size: .95rem; font-weight: 600; }

.exercise-body { padding: 1.25rem; }

.step-by-step {
  counter-reset: step;
}

.step {
  counter-increment: step;
  padding: .7rem 0 .7rem 2.5rem;
  position: relative;
  border-bottom: 1px dashed var(--border);
}

.step:last-child { border-bottom: none; }

.step::before {
  content: counter(step);
  position: absolute;
  left: 0;
  top: .65rem;
  width: 22px;
  height: 22px;
  background: var(--navy);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: .72rem;
  font-weight: 700;
}

.step .step-formula {
  font-family: 'DM Mono', monospace;
  font-size: .9rem;
  color: var(--navy);
  font-weight: 500;
}

.step .step-reason {
  font-size: .82rem;
  color: var(--slate);
  margin-top: .2rem;
}

/* ========= MODALS ========= */
.modal-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(15,23,42,.6);
  z-index: 200;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}

.modal-backdrop.open {
  display: flex;
}

.modal {
  background: white;
  border-radius: 16px;
  max-width: 560px;
  width: 100%;
  box-shadow: 0 24px 80px rgba(0,0,0,.35);
  overflow: hidden;
  max-height: 90vh;
  overflow-y: auto;
}

.modal-header {
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-header h2 {
  font-family: 'DM Serif Display', serif;
  font-size: 1.25rem;
}

.modal-close {
  background: none;
  border: 1px solid var(--border);
  border-radius: 8px;
  width: 32px;
  height: 32px;
  cursor: pointer;
  font-size: 1.1rem;
  color: var(--slate);
  transition: color .15s;
}

.modal-close:hover { color: var(--red); }

.modal-body { padding: 1.5rem; }

/* ========= ANIMATIONS ========= */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideInRight {
  from { opacity: 0; transform: translateX(60px); }
  to   { opacity: 1; transform: translateX(0); }
}

@keyframes fadeOut {
  from { opacity: 1; transform: translateX(0); }
  to   { opacity: 0; transform: translateX(60px); }
}

.page.active { animation: fadeIn .25s ease; }

.rule-card { animation: fadeIn .3s ease both; }
.rule-card:nth-child(1) { animation-delay: .03s; }
.rule-card:nth-child(2) { animation-delay: .06s; }
.rule-card:nth-child(3) { animation-delay: .09s; }
.rule-card:nth-child(4) { animation-delay: .12s; }
.rule-card:nth-child(5) { animation-delay: .15s; }
.rule-card:nth-child(6) { animation-delay: .18s; }

/* ========= SYMBOL HELPER ========= */
.symbol-help {
  background: var(--accent-light);
  border: 1px solid #fed7aa;
  border-radius: 10px;
  padding: .9rem 1.1rem;
  margin-bottom: 1.5rem;
  font-size: .88rem;
}

.symbol-help strong { color: var(--accent); margin-right: .5rem; }

.sym-table { display: flex; gap: 1.5rem; flex-wrap: wrap; margin-top: .5rem; }
.sym-row { display: flex; align-items: center; gap: .4rem; font-family: 'DM Mono', monospace; font-size: .9rem; }
.sym-row span { color: var(--slate); font-family: inherit; font-size: .82rem; }

/* ========= SCORE BANNER ========= */
.score-banner {
  background: linear-gradient(135deg, var(--navy), var(--navy2));
  color: white;
  border-radius: 12px;
  padding: 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}

.score-banner h3 { font-family: 'DM Serif Display', serif; font-size: 1.2rem; }
.score-banner p { color: #94a3b8; font-size: .85rem; margin-top: .2rem; }

.score-numbers { display: flex; gap: 1.5rem; }
.sn-item { text-align: center; }
.sn-val { font-family: 'DM Serif Display', serif; font-size: 1.6rem; color: var(--accent); display: block; }
.sn-lbl { font-size: .75rem; color: #94a3b8; }

/* ========= ALERT ========= */
.alert {
  padding: .9rem 1.1rem;
  border-radius: 10px;
  font-size: .9rem;
  margin-bottom: 1rem;
}

.alert-info { background: var(--blue-light); border: 1px solid #bfdbfe; color: #1d4ed8; }
.alert-success { background: var(--green-light); border: 1px solid #bbf7d0; color: #15803d; }
.alert-warning { background: var(--accent-light); border: 1px solid #fed7aa; color: #c2410c; }

/* ========= GAME OPTION BUTTONS ========= */
.game-opt-btn {
  background: white;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  padding: .45rem .9rem;
  font-size: .82rem;
  font-weight: 500;
  cursor: pointer;
  font-family: inherit;
  color: var(--navy);
  transition: all .15s;
  white-space: nowrap;
}
.game-opt-btn:hover { border-color: var(--accent); color: var(--accent); }
.game-opt-btn.active {
  background: var(--accent);
  border-color: var(--accent);
  color: white;
  font-weight: 700;
}

/* ========= TIMER RING ========= */
.timer-ring { position:relative; display:inline-flex; align-items:center; justify-content:center; }
.timer-ring svg { transform: rotate(-90deg); }
.timer-ring .timer-val { position:absolute; font-family:'DM Serif Display',serif; font-size:1.2rem; font-weight:700; }

/* ========= THEME TOGGLE ========= */
.theme-toggle {
  background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2);
  color: white; border-radius: 20px; padding: .3rem .75rem; cursor: pointer;
  font-size: .82rem; font-family: inherit; transition: all .2s;
  display: flex; align-items: center; gap: .3rem; white-space: nowrap; margin-left: auto;
}
.theme-toggle:hover { background: rgba(255,255,255,.2); }

/* ========= ANIMATIONS ========= */
@keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
.page.active { animation: fadeIn .2s ease; }
@keyframes pulse-urgency { 0%,100%{box-shadow:0 0 0 0 rgba(220,38,38,.4)} 50%{box-shadow:0 0 0 10px rgba(220,38,38,0)} }
.urgency { animation: pulse-urgency .8s infinite; }
.achievement-toast {
  position:fixed; bottom:2rem; right:2rem; background:var(--navy); color:white;
  border-radius:12px; padding:1rem 1.5rem; box-shadow:0 12px 40px rgba(0,0,0,.3);
  z-index:9999; display:flex; align-items:center; gap:1rem; max-width:340px;
  animation: fadeIn .3s ease;
}

/* ========= DARK MODE ========= */
[data-theme="dark"] body { background:#0c1222; color:#e2e8f0; }
[data-theme="dark"] header { background:#060d1b; }
[data-theme="dark"] .hero { background:#1a2332; border:1px solid #334155; }
[data-theme="dark"] .hero p { color:#94a3b8; }
[data-theme="dark"] .section-title { color:#f1f5f9; }
[data-theme="dark"] .section-sub { color:#94a3b8; }

[data-theme="dark"] .rule-card,
[data-theme="dark"] .quiz-container,
[data-theme="dark"] .practice-panel,
[data-theme="dark"] .score-banner,
[data-theme="dark"] .results-card { background:#1e293b; border-color:#334155; color:#e2e8f0; }

[data-theme="dark"] .rule-header { border-color:#334155; }
[data-theme="dark"] .rule-body { color:#cbd5e1; }
[data-theme="dark"] .rule-description { color:#94a3b8; }
[data-theme="dark"] .rule-name { color:#f1f5f9; }

[data-theme="dark"] .quiz-body { color:#e2e8f0; }
[data-theme="dark"] .quiz-question-text { color:#f1f5f9; }
[data-theme="dark"] .quiz-premises-box { background:#0f172a; border-color:#334155; color:#cbd5e1; }
[data-theme="dark"] .quiz-option { background:#1e293b; border-color:#475569; color:#e2e8f0; }
[data-theme="dark"] .quiz-option:hover:not(:disabled) { background:#334155; border-color:var(--accent); }
[data-theme="dark"] .quiz-feedback.correct { background:#052e16; border-color:#166534; color:#4ade80; }
[data-theme="dark"] .quiz-feedback.wrong { background:#450a0a; border-color:#991b1b; color:#fca5a5; }

[data-theme="dark"] .formal-box { background:#0f172a; border-color:#334155; }
[data-theme="dark"] .concrete-example { background:#0f2918; border-color:#166534; }
[data-theme="dark"] .concrete-example .ex-title { color:#4ade80; }

[data-theme="dark"] .btn-outline { background:#1e293b; color:#e2e8f0; border-color:#475569; }
[data-theme="dark"] .btn-outline:hover { background:#334155; border-color:#94a3b8; }
[data-theme="dark"] .game-opt-btn { background:#1e293b; color:#e2e8f0; border-color:#475569; }
[data-theme="dark"] .game-opt-btn:hover { border-color:var(--accent); color:var(--accent); }
[data-theme="dark"] .game-opt-btn.active { background:var(--accent); color:white; border-color:var(--accent); }

[data-theme="dark"] .input-group input,
[data-theme="dark"] .input-group select,
[data-theme="dark"] .input-group textarea { background:#0f172a; color:#e2e8f0; border-color:#475569; }
[data-theme="dark"] .input-group label { color:#94a3b8; }
[data-theme="dark"] .sym-btn { background:#334155; color:#e2e8f0; border-color:#475569; }

[data-theme="dark"] .practice-panel-header { background:#334155; border-color:#475569; color:#e2e8f0; }
[data-theme="dark"] .proof-line { border-color:#334155; color:#e2e8f0; }
[data-theme="dark"] .proof-line.premise-line { background:#0f172a; }

[data-theme="dark"] .cheat-item { background:#1e293b; border-color:#334155; color:#e2e8f0; }
[data-theme="dark"] .symbol-help { background:#1e293b; border-color:#334155; color:#e2e8f0; }
[data-theme="dark"] .alert-warning { background:#451a03; border-color:#92400e; color:#fbbf24; }

[data-theme="dark"] table th { background:#0f172a; }
[data-theme="dark"] table td { border-color:#334155; color:#e2e8f0; }
[data-theme="dark"] tr:nth-child(even) td { background:#1e293b; }

[data-theme="dark"] .nav-dropdown { background:#0a1121; border-color:#334155; }
[data-theme="dark"] .progress-bar { background:#1e293b; }

/* Dark mode for inline-styled game elements */
[data-theme="dark"] [style*="background:white"],
[data-theme="dark"] [style*="background: white"] { background:#1e293b !important; color:#e2e8f0 !important; }
[data-theme="dark"] [style*="border:1px solid var(--border)"],
[data-theme="dark"] [style*="border: 1px solid var(--border)"] { border-color:#334155 !important; }
[data-theme="dark"] [style*="color:var(--navy)"],
[data-theme="dark"] [style*="color: var(--navy)"] { color:#f1f5f9 !important; }
[data-theme="dark"] [style*="background:var(--slate-light)"],
[data-theme="dark"] [style*="background: var(--slate-light)"] { background:#0f172a !important; }
[data-theme="dark"] [style*="background:#fafafa"] { background:#0f172a !important; }
[data-theme="dark"] [style*="color:var(--text2)"] { color:#94a3b8 !important; }
[data-theme="dark"] [style*="color:var(--slate)"] { color:#94a3b8 !important; }

/* Smooth transitions */
body, .rule-card, .quiz-container, .quiz-option, .btn-outline, .game-opt-btn,
.practice-panel, .score-banner, .results-card, .section-title, .section-sub,
.formal-box, .cheat-item, .proof-line, table td, .symbol-help {
  transition: background-color .3s ease, color .3s ease, border-color .3s ease;
}

</style>
</head>
<body>

<header>
  <div class="header-inner">
    <div class="logo">∴ <span>Inferencia</span><br><small style="font-size:.6rem;color:#475569;font-family:'Plus Jakarta Sans',sans-serif;font-weight:400;">Lógica Proposicional</small></div>

    <nav id="main-nav">

      <!-- INICIO -->
      <div class="nav-group">
        <button class="nav-group-btn has-active" onclick="showPage('inicio');closeAllDropdowns()" id="navbtn-inicio">
          🏠 Inicio
        </button>
      </div>

      <!-- TEORÍA -->
      <div class="nav-group" id="navg-teoria">
        <button class="nav-group-btn" onclick="toggleDropdown('dd-teoria')" id="navbtn-teoria">
          📖 Teoría <span class="nav-arrow">▼</span>
        </button>
        <div class="nav-dropdown" id="dd-teoria">
          <a onclick="showPage('reglas');closeAllDropdowns()"><span class="nav-icon">📖</span>Reglas de Inferencia</a>
          <a onclick="showPage('equivalencias');closeAllDropdowns()"><span class="nav-icon">🔁</span>Equivalencias Lógicas</a>
          <a onclick="showPage('cheatsheet');closeAllDropdowns()"><span class="nav-icon">📋</span>Guía Rápida</a>
        </div>
      </div>

      <!-- PRÁCTICA -->
      <div class="nav-group" id="navg-practica">
        <button class="nav-group-btn" onclick="toggleDropdown('dd-practica')" id="navbtn-practica">
          ✏️ Práctica <span class="nav-arrow">▼</span>
        </button>
        <div class="nav-dropdown" id="dd-practica">
          <a onclick="showPage('ejercicios');closeAllDropdowns()"><span class="nav-icon">✏️</span>Ejercicios por Regla</a>
          <a onclick="showPage('completa');closeAllDropdowns()"><span class="nav-icon">🧩</span>Completa la Prueba</a>
          <a onclick="showPage('constructor');closeAllDropdowns()"><span class="nav-icon">🔧</span>Constructor de Pruebas</a>
          <a onclick="showPage('quiz');closeAllDropdowns()"><span class="nav-icon">❓</span>Quiz de Reglas</a>
        </div>
      </div>

      <!-- HERRAMIENTAS -->
      <div class="nav-group" id="navg-herramientas">
        <button class="nav-group-btn" onclick="toggleDropdown('dd-herramientas')" id="navbtn-herramientas">
          🔧 Herramientas <span class="nav-arrow">▼</span>
        </button>
        <div class="nav-dropdown" id="dd-herramientas">
          <a onclick="showPage('tablas');closeAllDropdowns()"><span class="nav-icon">📊</span>Tablas de Verdad</a>
          <a onclick="showPage('arbol');closeAllDropdowns()"><span class="nav-icon">🌳</span>Árbol Sintáctico</a>
          <a onclick="showPage('formalizador');closeAllDropdowns()"><span class="nav-icon">🗣️</span>Formalizador</a>
          <a onclick="showPage('verificador');closeAllDropdowns()"><span class="nav-icon">✔️</span>Verificador</a>
          <a onclick="showPage('examen');closeAllDropdowns()"><span class="nav-icon">📄</span>Generador de Examen</a>
        </div>
      </div>

      <!-- JUGAR -->
      <div class="nav-group" id="navg-jugar">
        <button class="nav-group-btn" onclick="toggleDropdown('dd-jugar')" id="navbtn-jugar">
          🎮 Jugar <span class="nav-arrow">▼</span>
        </button>
        <div class="nav-dropdown" id="dd-jugar">
          <a onclick="showPage('flashcards');closeAllDropdowns()"><span class="nav-icon">🃏</span>Flashcards</a>
          <a onclick="showPage('valido');closeAllDropdowns()"><span class="nav-icon">⚖️</span>Válido o Inválido</a>
          <a onclick="showPage('supervivencia');closeAllDropdowns()"><span class="nav-icon">❤️</span>Modo Supervivencia</a>
          <a onclick="showPage('contrarreloj');closeAllDropdowns()"><span class="nav-icon">⏱️</span>Contrarreloj</a>
          <a onclick="showPage('misterio');closeAllDropdowns()"><span class="nav-icon">🔍</span>Detective Lógico</a>
          <a onclick="showPage('duelo');closeAllDropdowns()"><span class="nav-icon">⚔️</span>Duelo 1 vs 1</a>
          <a onclick="showPage('torneo');closeAllDropdowns()"><span class="nav-icon">🏟️</span>Torneo (4 jugadores)</a>
          <a onclick="showPage('errores');closeAllDropdowns()"><span class="nav-icon">🔎</span>Encuentra el Error</a>
          <a onclick="showPage('cadena');closeAllDropdowns()"><span class="nav-icon">🔗</span>Cadena Lógica</a>
          <a onclick="showPage('logros');closeAllDropdowns()"><span class="nav-icon">🏆</span>Mis Logros</a>
        </div>
      </div>

    </nav>

    <!-- Breadcrumb del área activa -->
    <button class="theme-toggle" id="theme-toggle-btn" onclick="toggleTheme()" title="Cambiar tema">
      <span id="theme-icon">🌙</span> <span id="theme-label">Noche</span>
    </button>

    <div id="nav-current">Sección: <span id="nav-current-label">Inicio</span></div>

    <!-- Botón hamburguesa mobile -->
    <button class="nav-hamburger" onclick="toggleMobileNav()" id="hamburger-btn">☰</button>
  </div>
  <div class="progress-bar"><div class="progress-fill" id="global-progress"></div></div>
</header>

<main>

<!-- ========= INICIO ========= -->
<div class="page active" id="page-inicio">
  <div class="hero">
    <h1>Domina las <em>Reglas de Inferencia</em> en Lógica Proposicional</h1>
    <p>Un recurso completo e interactivo para aprender, practicar y dominar las 10 reglas fundamentales de la deducción lógica. Aprende con ejemplos reales, ejercicios y un constructor de pruebas.</p>
    <div class="hero-stats">
      <div class="hero-stat"><span class="num">10</span><span class="label">Reglas</span></div>
      <div class="hero-stat"><span class="num">20+</span><span class="label">Secciones</span></div>
      <div class="hero-stat"><span class="num">8</span><span class="label">Juegos</span></div>
      <div class="hero-stat"><span class="num">∞</span><span class="label">Práctica</span></div>
    </div>
  </div>

  <div class="symbol-help">
    <strong>🔑 Símbolos usados en este sitio:</strong>
    <div class="sym-table">
      <div class="sym-row">¬ <span>negación (NO)</span></div>
      <div class="sym-row">∧ <span>conjunción (Y)</span></div>
      <div class="sym-row">∨ <span>disyunción (O)</span></div>
      <div class="sym-row">→ <span>condicional (SI...ENTONCES)</span></div>
      <div class="sym-row">↔ <span>bicondicional (SI Y SOLO SI)</span></div>
      <div class="sym-row">∴ <span>por lo tanto (conclusión)</span></div>
    </div>
  </div>

  <h2 class="section-title">¿Por dónde empezar?</h2>
  <p class="section-sub">Ruta de aprendizaje recomendada — de lo más básico a lo más avanzado.</p>

  <!-- TEORÍA -->
  <div style="margin-bottom:1.75rem;">
    <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem;">
      <div style="background:var(--blue);color:white;border-radius:6px;padding:.2rem .7rem;font-size:.75rem;font-weight:700;">📖 TEORÍA</div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:.85rem;">
      <div onclick="showPage('reglas')" style="cursor:pointer;background:white;border:1px solid var(--border);border-left:4px solid var(--blue);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;">📖 Reglas de Inferencia</div>
        <p style="font-size:.83rem;color:var(--slate);">Las 10 reglas con forma formal, descripción y ejemplos cotidianos.</p>
      </div>
      <div onclick="showPage('equivalencias')" style="cursor:pointer;background:white;border:1px solid var(--border);border-left:4px solid var(--blue);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;">🔁 Equivalencias Lógicas</div>
        <p style="font-size:.83rem;color:var(--slate);">De Morgan, conmutatividad, distribución, contrapositiva y más.</p>
      </div>
      <div onclick="showPage('cheatsheet')" style="cursor:pointer;background:white;border:1px solid var(--border);border-left:4px solid var(--blue);border-radius:0 10px 10px 0;padding:1rem 1.25rem;box-shadow:var(--shadow);transition:all .15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--shadow)'">
        <div style="font-weight:600;margin-bottom:.3rem;">📋 Guía Rápida</div>
        <p style="font-size:.83rem;color:var(--slate);">Todas las reglas compactas, tabla de verdad y errores comunes.</p>
      </div>
    </div>
  </div>

  <!-- PRÁCTICA -->
  <div style="margin-bottom:1.75rem;">
    <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem;">
