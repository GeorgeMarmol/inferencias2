let solCount = 0;
const solSeen = new Set();

function updateSolProgress() {
  document.getElementById('sol-count').textContent = solCount;
  document.getElementById('sol-progress-bar').style.width = (solCount / 20 * 100) + '%';
}

function resetSolCount() {
  solCount = 0; solSeen.clear();
  updateSolProgress();
  // hide all solutions
  document.querySelectorAll('[id^="ex-sol-"]').forEach(el => el.style.display = 'none');
  document.querySelectorAll('[id^="ex-btn-"]').forEach(el => el.textContent = '👁 Ver Solución');
}

function buildExercises() {
  // Build rule tabs
  const tabs = document.getElementById('rule-tabs');
  if(tabs) {
    tabs.innerHTML = '';
    EXERCISES_BY_RULE.forEach((rule, i) => {
      const btn = document.createElement('button');
      btn.className = 'btn btn-outline';
      btn.id = `rtab-${i}`;
      btn.style.cssText = `font-size:.78rem;padding:.35rem .8rem;border-color:${rule.color}33;color:${rule.color};`;
      btn.innerHTML = `<span style="background:${rule.color};color:white;border-radius:3px;padding:.1rem .35rem;font-size:.7rem;margin-right:.3rem;">${rule.short}</span>${rule.rule}`;
      btn.onclick = () => showRuleExercises(i);
      tabs.appendChild(btn);
    });
  }

  // Build all-exercises accordion (bottom section)
  const c = document.getElementById('exercises-container');
  if(!c) return;
  c.innerHTML = '';
  let globalIdx = 0;
  EXERCISES_BY_RULE.forEach((ruleGroup) => {
    ruleGroup.exercises.forEach((ex) => {
      c.appendChild(makeExerciseCard(ex, ruleGroup, globalIdx, 'all'));
      globalIdx++;
    });
  });
  updateSolProgress();
}

function showRuleExercises(ruleIdx) {
  // Highlight active tab
  EXERCISES_BY_RULE.forEach((_, i) => {
    const btn = document.getElementById(`rtab-${i}`);
    if(!btn) return;
    btn.style.fontWeight = i === ruleIdx ? '700' : '400';
    btn.style.background = i === ruleIdx ? EXERCISES_BY_RULE[i].bg : '';
    btn.style.borderColor = i === ruleIdx ? EXERCISES_BY_RULE[i].color : EXERCISES_BY_RULE[i].color + '33';
  });

  const rule = EXERCISES_BY_RULE[ruleIdx];
  const panel = document.getElementById('rule-exercises-panel');
  panel.innerHTML = '';

  // Header
  const header = document.createElement('div');
  header.style.cssText = `background:${rule.bg};border:1px solid ${rule.color}33;border-radius:10px;padding:1rem 1.25rem;margin-bottom:1.25rem;display:flex;align-items:center;gap:.75rem;`;
  header.innerHTML = `
    <div style="background:${rule.color};color:white;border-radius:8px;padding:.4rem .9rem;font-weight:700;font-size:.9rem;font-family:'DM Mono',monospace;">${rule.short}</div>
    <div>
      <div style="font-weight:700;color:${rule.color};font-size:1rem;">${rule.rule}</div>
      <div style="font-size:.82rem;color:var(--slate);margin-top:.1rem;">2 ejercicios — intenta resolverlos antes de ver la solución</div>
    </div>
  `;
  panel.appendChild(header);

  rule.exercises.forEach((ex, i) => {
    const globalIdx = ruleIdx * 2 + i;
    panel.appendChild(makeExerciseCard(ex, rule, globalIdx, 'panel'));
  });
}

function makeExerciseCard(ex, rule, globalIdx, prefix) {
  const card = document.createElement('div');
  card.className = 'exercise-card';
  card.style.marginBottom = '1.25rem';

  const premHtml = ex.premises.map((p, i) => `<div style="padding:.2rem 0;font-family:'DM Mono',monospace;font-size:.9rem;">P${i+1}: <strong>${p}</strong></div>`).join('');
  const legendHtml = Object.entries(ex.legend).map(([k,v]) =>
    `<div style="font-size:.82rem;color:var(--text2);padding:.1rem 0;"><span style="font-family:'DM Mono',monospace;font-weight:700;color:${rule.color};">${k}</span> = ${v}</div>`
  ).join('');
  const stepsHtml = ex.steps.map((s, n) => `
    <div class="step">
      <div class="step-formula">${n+1}. &nbsp;${s.formula}</div>
      <div class="step-reason">${s.reason}</div>
    </div>
  `).join('');

  const solId = `ex-sol-${prefix}-${globalIdx}`;
  const btnId = `ex-btn-${prefix}-${globalIdx}`;

  card.innerHTML = `
    <div class="exercise-header" style="background:linear-gradient(135deg,${rule.color},${rule.color}dd);">
      <h3 style="font-size:.9rem;">Ejercicio ${(globalIdx % 2) + 1}: ${ex.title}</h3>
      <span style="background:rgba(255,255,255,.2);color:white;border-radius:6px;padding:.2rem .7rem;font-size:.75rem;font-weight:700;">${rule.short}</span>
    </div>
    <div class="exercise-body">
      <p style="font-size:.9rem;color:var(--text2);margin-bottom:1rem;line-height:1.65;">${ex.situation}</p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:1rem;">
        <div style="background:var(--slate-light);border:1px solid var(--border);border-radius:8px;padding:.9rem 1rem;">
          <div style="font-size:.72rem;font-weight:700;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.5rem;">Premisas</div>
          ${premHtml}
        </div>
        <div style="background:${rule.bg};border:1px solid ${rule.color}33;border-radius:8px;padding:.9rem 1rem;">
          <div style="font-size:.72rem;font-weight:700;color:${rule.color};text-transform:uppercase;letter-spacing:.06em;margin-bottom:.5rem;">Variables</div>
          ${legendHtml}
        </div>
      </div>
      <div style="background:var(--accent-light);border:1px solid #fed7aa;border-radius:8px;padding:.75rem 1rem;margin-bottom:1rem;font-size:.88rem;color:#92400e;">
        <strong>❓ ${ex.question}</strong>
      </div>
      <button class="btn btn-outline" id="${btnId}" onclick="toggleExSolution('${solId}','${btnId}')" style="margin-bottom:.75rem;border-color:${rule.color};color:${rule.color};">
        👁 Ver Solución
      </button>
      <div id="${solId}" style="display:none;">
        <div style="border:1px solid var(--border);border-radius:10px;overflow:hidden;">
          <div style="background:var(--navy);color:white;padding:.6rem 1rem;font-size:.82rem;font-weight:600;">📋 Demostración formal — Regla: ${rule.rule}</div>
          <div class="step-by-step" style="padding:.5rem 1rem 1rem;">${stepsHtml}</div>
          <div style="background:var(--green-light);border-top:1px solid #bbf7d0;padding:.8rem 1rem;font-weight:700;color:var(--green);font-size:.9rem;">
            ∴ ${ex.conclusion}
          </div>
        </div>
      </div>
    </div>
  `;
  return card;
}

function toggleExSolution(solId, btnId) {
  const el = document.getElementById(solId);
  const btn = document.getElementById(btnId);
  if(!el) return;
  if(el.style.display === 'none') {
    el.style.display = 'block';
    el.style.animation = 'fadeIn .3s ease';
    if(btn) btn.textContent = '🙈 Ocultar Solución';
    if(!solSeen.has(solId)) { solSeen.add(solId); solCount++; updateSolProgress(); trackLogro('sol_seen', solCount); }
  } else {
    el.style.display = 'none';
    if(btn) btn.textContent = '👁 Ver Solución';
  }
}

function toggleSolution(id) { toggleExSolution(id, null); }

// ====================== PROOF BUILDER ======================
function insertSymbol(targetId, sym) {
  const el = document.getElementById(targetId);
  if(!el) return;
  const pos = el.selectionStart || el.value.length;
  el.value = el.value.slice(0, pos) + sym + el.value.slice(pos);
  el.focus();
  el.selectionStart = el.selectionEnd = pos + sym.length;
}

