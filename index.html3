});

// ====================== EQUIVALENCIAS ======================
const EQUIV_DATA = [
  { name:'Doble Negación', group:'Negación', color:'#3b82f6',
    left:'¬¬p', right:'p', symbol:'≡',
    description:'Negar dos veces una proposición equivale a la proposición original.',
    example:'¬¬(llueve) ≡ llueve', tip:'Muy usada para simplificar fórmulas con múltiples negaciones.' },
  { name:'De Morgan (AND)', group:'De Morgan', color:'#dc2626',
    left:'¬(p ∧ q)', right:'¬p ∨ ¬q', symbol:'≡',
    description:'La negación de una conjunción equivale a la disyunción de las negaciones.',
    example:'¬(llueve y hace frío) ≡ (no llueve) o (no hace frío)', tip:'Esencial para "mover" la negación hacia adentro de los paréntesis.' },
  { name:'De Morgan (OR)', group:'De Morgan', color:'#dc2626',
    left:'¬(p ∨ q)', right:'¬p ∧ ¬q', symbol:'≡',
    description:'La negación de una disyunción equivale a la conjunción de las negaciones.',
    example:'¬(llueve o hay viento) ≡ (no llueve) y (no hay viento)', tip:'Recuerda: al negar una disyunción, el ∨ cambia a ∧.' },
  { name:'Conmutatividad (∧)', group:'Conmutatividad', color:'#16a34a',
    left:'p ∧ q', right:'q ∧ p', symbol:'≡',
    description:'El orden de los términos en una conjunción no altera su valor de verdad.',
    example:'(estudio y trabajo) ≡ (trabajo y estudio)', tip:'Igual que en aritmética: a·b = b·a' },
  { name:'Conmutatividad (∨)', group:'Conmutatividad', color:'#16a34a',
    left:'p ∨ q', right:'q ∨ p', symbol:'≡',
    description:'El orden de los términos en una disyunción no altera su valor de verdad.',
    example:'(llueve o hace sol) ≡ (hace sol o llueve)', tip:'El orden en la disyunción es irrelevante para la verdad.' },
  { name:'Asociatividad (∧)', group:'Asociatividad', color:'#0891b2',
    left:'(p ∧ q) ∧ r', right:'p ∧ (q ∧ r)', symbol:'≡',
    description:'El agrupamiento de términos en una conjunción no altera el resultado.',
    example:'((A y B) y C) ≡ (A y (B y C))', tip:'Puedes reagrupar libremente sin cambiar el resultado.' },
  { name:'Asociatividad (∨)', group:'Asociatividad', color:'#0891b2',
    left:'(p ∨ q) ∨ r', right:'p ∨ (q ∨ r)', symbol:'≡',
    description:'El agrupamiento de términos en una disyunción no altera el resultado.',
    example:'((A o B) o C) ≡ (A o (B o C))', tip:'Igual que la suma: (a+b)+c = a+(b+c)' },
  { name:'Distribución (∧ sobre ∨)', group:'Distribución', color:'#7c3aed',
    left:'p ∧ (q ∨ r)', right:'(p ∧ q) ∨ (p ∧ r)', symbol:'≡',
    description:'La conjunción se distribuye sobre la disyunción.',
    example:'A y (B o C) ≡ (A y B) o (A y C)', tip:'Como en álgebra: a(b+c) = ab+ac' },
  { name:'Distribución (∨ sobre ∧)', group:'Distribución', color:'#7c3aed',
    left:'p ∨ (q ∧ r)', right:'(p ∨ q) ∧ (p ∨ r)', symbol:'≡',
    description:'La disyunción se distribuye sobre la conjunción.',
    example:'A o (B y C) ≡ (A o B) y (A o C)', tip:'Al revés que en aritmética: ∨ también distribuye.' },
  { name:'Implicación Material', group:'Condicional', color:'#f97316',
    left:'p → q', right:'¬p ∨ q', symbol:'≡',
    description:'Un condicional equivale a la disyunción de la negación del antecedente y el consecuente.',
    example:'(si llueve, me mojo) ≡ (no llueve) o (me mojo)', tip:'¡Muy importante! Permite eliminar el condicional en pruebas.' },
  { name:'Contrapositiva', group:'Condicional', color:'#f97316',
    left:'p → q', right:'¬q → ¬p', symbol:'≡',
    description:'Un condicional equivale a su contrapositiva (inversa y negada).',
    example:'(si llueve, me mojo) ≡ (si no me mojo, no llovió)', tip:'El Modus Tollens es básicamente aplicar la contrapositiva.' },
  { name:'Bicondicional', group:'Bicondicional', color:'#b45309',
    left:'p ↔ q', right:'(p → q) ∧ (q → p)', symbol:'≡',
    description:'Un bicondicional equivale a dos condicionales en ambas direcciones.',
    example:'(llueve ↔ hay nubes) ≡ (llueve→nubes) y (nubes→llueve)', tip:'El bicondicional es "condicional doble": si y solo si.' },
  { name:'Absorción (∧)', group:'Absorción', color:'#0d9488',
    left:'p ∧ (p ∨ q)', right:'p', symbol:'≡',
    description:'La conjunción de p con una disyunción que ya contiene p se simplifica a p.',
    example:'(estudio) y (estudio o trabajo) ≡ estudio', tip:'p ya garantiza p∨q, así que la disyunción es redundante.' },
  { name:'Absorción (∨)', group:'Absorción', color:'#0d9488',
    left:'p ∨ (p ∧ q)', right:'p', symbol:'≡',
    description:'La disyunción de p con una conjunción que ya contiene p se simplifica a p.',
    example:'(estudio) o (estudio y trabajo) ≡ estudio', tip:'Si p es verdadero, la disyunción ya es verdadera sin importar q.' },
  { name:'Identidad (∧)', group:'Identidad', color:'#9333ea',
    left:'p ∧ V', right:'p', symbol:'≡',
    description:'La conjunción de cualquier fórmula con una tautología (V) es la fórmula misma.',
    example:'(llueve) y (Verdadero) ≡ llueve', tip:'V es el elemento neutro de ∧.' },
  { name:'Identidad (∨)', group:'Identidad', color:'#9333ea',
    left:'p ∨ F', right:'p', symbol:'≡',
    description:'La disyunción de cualquier fórmula con una contradicción (F) es la fórmula misma.',
    example:'(llueve) o (Falso) ≡ llueve', tip:'F es el elemento neutro de ∨.' }
];

function buildEquivalencias() {
  const grid = document.getElementById('equiv-grid');
  if(!grid) return;

  // Group by category
  const groups = {};
  EQUIV_DATA.forEach(e => {
    if(!groups[e.group]) groups[e.group] = [];
    groups[e.group].push(e);
  });

  grid.innerHTML = '';
  Object.entries(groups).forEach(([groupName, items]) => {
    const section = document.createElement('div');
    section.style.marginBottom = '2rem';
    section.innerHTML = `<h3 style="font-weight:700;font-size:1rem;color:var(--navy);margin-bottom:.75rem;padding-bottom:.4rem;border-bottom:2px solid ${items[0].color}33;">${groupName}</h3>`;
    const innerGrid = document.createElement('div');
    innerGrid.style.cssText = 'display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1rem;';
    items.forEach((eq, idx) => {
      const card = document.createElement('div');
      card.style.cssText = `background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;cursor:pointer;transition:all .2s;`;
      card.onclick = () => card.classList.toggle('expanded');
      card.onmouseover = () => card.style.boxShadow = 'var(--shadow-lg)';
      card.onmouseout = () => card.style.boxShadow = 'var(--shadow)';
      card.innerHTML = `
        <div style="background:${eq.color}11;border-bottom:1px solid ${eq.color}22;padding:.9rem 1.1rem;display:flex;align-items:center;gap:.75rem;">
          <div style="background:${eq.color};color:white;border-radius:6px;padding:.25rem .6rem;font-size:.72rem;font-weight:700;">${eq.group.substring(0,3).toUpperCase()}</div>
          <div style="font-weight:600;font-size:.9rem;color:var(--navy);">${eq.name}</div>
        </div>
        <div style="padding:1rem 1.1rem;">
          <div style="display:flex;align-items:center;gap:.6rem;font-family:'DM Mono',monospace;font-size:.95rem;margin-bottom:.75rem;flex-wrap:wrap;">
            <span style="color:var(--navy);font-weight:600;">${eq.left}</span>
            <span style="color:${eq.color};font-weight:700;font-size:1.1rem;">${eq.symbol}</span>
            <span style="color:var(--navy);font-weight:600;">${eq.right}</span>
          </div>
          <p style="font-size:.84rem;color:var(--text2);margin-bottom:.6rem;line-height:1.6;">${eq.description}</p>
          <div style="background:${eq.color}0d;border-left:3px solid ${eq.color};padding:.5rem .8rem;border-radius:0 6px 6px 0;font-size:.81rem;color:var(--text2);margin-bottom:.5rem;font-style:italic;">${eq.example}</div>
          <div style="font-size:.79rem;color:${eq.color};font-weight:600;">💡 ${eq.tip}</div>
        </div>
      `;
      innerGrid.appendChild(card);
    });
    section.appendChild(innerGrid);
    grid.appendChild(section);
  });
}

// ====================== COMPLETA LA PRUEBA ======================
const CP_DATA = [
  { title:'Modus Ponens — completa la conclusión', rule:'Modus Ponens', premises:['p → q','p'],
    lines:[
      {formula:'p → q', reason:'Premisa', blank:false},
      {formula:'p', reason:'Premisa', blank:false},
      {formula:'?', reason:'Modus Ponens (MP) — líneas 1, 2', blank:'formula', answer:'q'}
    ], hint:'El consecuente del condicional cuando se cumple el antecedente.' },
  { title:'Modus Tollens — completa la regla', rule:'Modus Tollens', premises:['p → q','¬q'],
    lines:[
      {formula:'p → q', reason:'Premisa', blank:false},
      {formula:'¬q', reason:'Premisa', blank:false},
      {formula:'¬p', reason:'?', blank:'reason', answer:'Modus Tollens (MT) — líneas 1, 2'}
    ], hint:'Negamos el consecuente para negar el antecedente.' },
  { title:'Silogismo Hipotético — completa la conclusión', rule:'Silogismo Hipotético', premises:['p → q','q → r'],
    lines:[
      {formula:'p → q', reason:'Premisa', blank:false},
      {formula:'q → r', reason:'Premisa', blank:false},
      {formula:'?', reason:'Silogismo Hipotético (SH) — líneas 1, 2', blank:'formula', answer:'p → r'}
    ], hint:'Encadena los dos condicionales: p llega a r saltando q.' },
  { title:'Silogismo Disyuntivo — completa la conclusión', rule:'Silogismo Disyuntivo', premises:['p ∨ q','¬p'],
    lines:[
      {formula:'p ∨ q', reason:'Premisa', blank:false},
      {formula:'¬p', reason:'Premisa', blank:false},
      {formula:'?', reason:'Silogismo Disyuntivo (SD) — líneas 1, 2', blank:'formula', answer:'q'}
    ], hint:'Si una opción de la disyunción es falsa, la otra debe ser verdadera.' },
  { title:'Adición — completa la conclusión', rule:'Adición', premises:['p'],
    lines:[
      {formula:'p', reason:'Premisa', blank:false},
      {formula:'?', reason:'Adición (Ad) — línea 1', blank:'formula', answer:'p ∨ q'}
    ], hint:'De p verdadero podemos crear cualquier disyunción con p.' },
  { title:'Simplificación — completa la regla', rule:'Simplificación', premises:['p ∧ q'],
    lines:[
      {formula:'p ∧ q', reason:'Premisa', blank:false},
      {formula:'p', reason:'?', blank:'reason', answer:'Simplificación (Sim) — línea 1'}
    ], hint:'Extraemos un componente de la conjunción.' },
  { title:'Conjunción — completa la conclusión', rule:'Conjunción', premises:['p','q'],
    lines:[
      {formula:'p', reason:'Premisa', blank:false},
      {formula:'q', reason:'Premisa', blank:false},
      {formula:'?', reason:'Conjunción (Con) — líneas 1, 2', blank:'formula', answer:'p ∧ q'}
    ], hint:'Unimos dos verdades individuales en una sola conjunción.' },
  { title:'Absorción — completa la conclusión', rule:'Absorción', premises:['p → q'],
    lines:[
      {formula:'p → q', reason:'Premisa', blank:false},
      {formula:'?', reason:'Absorción (Abs) — línea 1', blank:'formula', answer:'p → (p ∧ q)'}
    ], hint:'El antecedente se "absorbe" en el consecuente como conjunción.' },
  { title:'Dilema Constructivo — completa la conclusión', rule:'Dilema Constructivo', premises:['(p → q) ∧ (r → s)','p ∨ r'],
    lines:[
      {formula:'(p → q) ∧ (r → s)', reason:'Premisa', blank:false},
      {formula:'p ∨ r', reason:'Premisa', blank:false},
      {formula:'?', reason:'Dilema Constructivo (DC) — líneas 1, 2', blank:'formula', answer:'q ∨ s'}
    ], hint:'La disyunción de los antecedentes produce la disyunción de los consecuentes.' },
  { title:'Dilema Destructivo — completa la regla', rule:'Dilema Destructivo', premises:['(p → q) ∧ (r → s)','¬q ∨ ¬s'],
    lines:[
      {formula:'(p → q) ∧ (r → s)', reason:'Premisa', blank:false},
      {formula:'¬q ∨ ¬s', reason:'Premisa', blank:false},
      {formula:'¬p ∨ ¬r', reason:'?', blank:'reason', answer:'Dilema Destructivo (DD) — líneas 1, 2'}
    ], hint:'Negamos los consecuentes para negar los antecedentes en disyunción.' }
];

let cpDeck = CP_DATA.map((_,i)=>i), cpIdx = 0;
let cpAnswered = {}, cpCorrect = 0;

function buildCompleta() {
  cpDeck = CP_DATA.map((_,i)=>i);
  cpIdx = 0; cpAnswered = {}; cpCorrect = 0;
  renderCP();
}

function renderCP() {
  document.getElementById('cp-current').textContent = cpIdx + 1;
  document.getElementById('cp-total').textContent = cpDeck.length;
  const ex = CP_DATA[cpDeck[cpIdx]];
  const card = document.getElementById('cp-card');
  const blankLine = ex.lines.find(l => l.blank);
  const answered = cpAnswered[cpDeck[cpIdx]];

  let linesHtml = ex.lines.map((line, i) => {
    const isLast = i === ex.lines.length - 1;
    if(line.blank === 'formula') {
      const val = answered ? answered.userAnswer : '';
      const correct = answered ? answered.correct : null;
      return `
        <div style="display:grid;grid-template-columns:36px 1fr 200px;align-items:center;padding:.6rem 1rem;border-bottom:1px solid var(--border);background:${isLast ? '#fffbeb' : ''};">
          <div style="font-size:.75rem;color:var(--slate);font-weight:600;">${i+1}</div>
          <div>
            ${answered
              ? `<div style="font-family:'DM Mono',monospace;font-weight:700;color:${correct?'var(--green)':'var(--red)'};">${correct?line.answer:val} ${correct?'✓':'✗'}</div>${!correct?`<div style="font-size:.78rem;color:var(--green);">Respuesta: ${line.answer}</div>`:''}`
              : `<input type="text" id="cp-blank" placeholder="Escribe la fórmula aquí..." style="width:100%;font-family:'DM Mono',monospace;padding:.4rem .6rem;border:2px dashed var(--accent);border-radius:6px;background:#fffbeb;font-size:.9rem;" onkeydown="if(event.key==='Enter')checkCP()">
                 <div style="display:flex;gap:.3rem;margin-top:.3rem;flex-wrap:wrap;">
                   ${['¬','∧','∨','→','↔','(',')'].map(s=>`<button onclick="(function(){var el=document.getElementById('cp-blank');el.value+=\`${s}\`;el.focus();})()" style="background:var(--slate-light);border:1px solid var(--border);border-radius:4px;padding:.15rem .45rem;font-family:'DM Mono',monospace;cursor:pointer;font-size:.85rem;">${s}</button>`).join('')}
                 </div>`
            }
          </div>
          <div style="font-size:.78rem;color:var(--slate);font-style:italic;">${line.reason}</div>
        </div>`;
    }
    if(line.blank === 'reason') {
      const val = answered ? answered.userAnswer : '';
      const correct = answered ? answered.correct : null;
      return `
        <div style="display:grid;grid-template-columns:36px 1fr 200px;align-items:center;padding:.6rem 1rem;border-bottom:1px solid var(--border);background:${isLast?'#fffbeb':''};">
          <div style="font-size:.75rem;color:var(--slate);font-weight:600;">${i+1}</div>
          <div style="font-family:'DM Mono',monospace;font-size:.9rem;font-weight:500;color:var(--navy);">${line.formula}</div>
          <div>
            ${answered
              ? `<div style="font-size:.8rem;font-weight:700;color:${correct?'var(--green)':'var(--red)'};">${correct?line.answer:val} ${correct?'✓':'✗'}</div>${!correct?`<div style="font-size:.75rem;color:var(--green);">${line.answer}</div>`:''}`
              : `<select id="cp-blank" style="width:100%;padding:.35rem .5rem;border:2px dashed var(--accent);border-radius:6px;background:#fffbeb;font-size:.78rem;">
                   <option value="">— Selecciona la regla —</option>
                   <option>Modus Ponens (MP) — líneas 1, 2</option>
                   <option>Modus Tollens (MT) — líneas 1, 2</option>
                   <option>Silogismo Hipotético (SH) — líneas 1, 2</option>
                   <option>Silogismo Disyuntivo (SD) — líneas 1, 2</option>
                   <option>Adición (Ad) — línea 1</option>
                   <option>Simplificación (Sim) — línea 1</option>
                   <option>Conjunción (Con) — líneas 1, 2</option>
                   <option>Absorción (Abs) — línea 1</option>
                   <option>Dilema Constructivo (DC) — líneas 1, 2</option>
                   <option>Dilema Destructivo (DD) — líneas 1, 2</option>
                 </select>`
            }
          </div>
        </div>`;
    }
    return `
      <div style="display:grid;grid-template-columns:36px 1fr 200px;align-items:center;padding:.6rem 1rem;border-bottom:1px solid var(--border);background:#fafafa;">
        <div style="font-size:.75rem;color:var(--slate);font-weight:600;">${i+1}</div>
        <div style="font-family:'DM Mono',monospace;font-size:.9rem;font-weight:500;color:var(--navy);">${line.formula}</div>
        <div style="font-size:.78rem;color:var(--slate);font-style:italic;">${line.reason}</div>
      </div>`;
  }).join('');

  card.innerHTML = `
    <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow-lg);overflow:hidden;margin-bottom:1rem;">
      <div style="background:var(--navy);color:white;padding:.9rem 1.25rem;display:flex;justify-content:space-between;align-items:center;">
        <div>
          <div style="font-family:'DM Serif Display',serif;font-size:1rem;">${ex.title}</div>
          <div style="color:#94a3b8;font-size:.78rem;margin-top:.15rem;">Regla: ${ex.rule}</div>
        </div>
        <div style="font-size:.78rem;background:rgba(255,255,255,.1);padding:.3rem .7rem;border-radius:6px;">
          ✅ ${cpCorrect}/${Object.keys(cpAnswered).length} correctas
        </div>
      </div>
      <div style="padding:.9rem 1.25rem;background:var(--accent-light);border-bottom:1px solid #fed7aa;font-size:.85rem;color:#92400e;">
        <strong>📋 Premisas:</strong> ${ex.premises.map(p=>`<code style="font-family:'DM Mono',monospace;background:white;border-radius:4px;padding:.1rem .4rem;">${p}</code>`).join('  ')}
      </div>
      <div style="display:grid;grid-template-columns:36px 1fr 200px;background:var(--slate-light);border-bottom:1px solid var(--border);padding:.45rem 1rem;">
        <div style="font-size:.72rem;font-weight:600;color:var(--slate);">#</div>
        <div style="font-size:.72rem;font-weight:600;color:var(--slate);">FÓRMULA</div>
        <div style="font-size:.72rem;font-weight:600;color:var(--slate);">JUSTIFICACIÓN</div>
      </div>
      ${linesHtml}
      <div style="padding:1rem 1.25rem;background:var(--blue-light);border-top:1px solid #bfdbfe;font-size:.83rem;color:#1d4ed8;">
        💡 <strong>Pista:</strong> ${ex.hint}
      </div>
    </div>
    ${!answered ? `<div style="display:flex;gap:.75rem;flex-wrap:wrap;">
      <button class="btn btn-primary" onclick="checkCP()">✅ Verificar respuesta</button>
      <button class="btn btn-outline" onclick="nextCP()">Saltar →</button>
    </div>` : `<div style="display:flex;gap:.75rem;flex-wrap:wrap;">
      <button class="btn btn-primary" onclick="nextCP()">Siguiente →</button>
      <button class="btn btn-outline" onclick="prevCP()">← Anterior</button>
    </div>`}
  `;
}

function checkCP() {
  const ex = CP_DATA[cpDeck[cpIdx]];
  const blankLine = ex.lines.find(l => l.blank);
  const el = document.getElementById('cp-blank');
  if(!el) return;
  const userAnswer = el.value.trim();
  if(!userAnswer) { alert('Escribe o selecciona tu respuesta primero.'); return; }
  const correct = userAnswer.replace(/\s+/g,'') === blankLine.answer.replace(/\s+/g,'');
  cpAnswered[cpDeck[cpIdx]] = { userAnswer, correct };
  if(correct) { cpCorrect++; trackLogro('cp_correct'); }
  trackLogro('cp_attempt');
  renderCP();
}

function nextCP() { if(cpIdx < cpDeck.length-1) { cpIdx++; renderCP(); } else { cpIdx=0; renderCP(); } }
function prevCP() { if(cpIdx > 0) { cpIdx--; renderCP(); } else { cpIdx=cpDeck.length-1; renderCP(); } }
function shuffleCP() { cpDeck=fisherYates(cpDeck); cpIdx=0; cpAnswered={}; cpCorrect=0; renderCP(); }

// ====================== FORMALIZADOR ======================
const FZ_EXAMPLES = [
  { label:'Modus Ponens', text:'Si llueve, me mojo.\nLlueve.\nPor lo tanto, me mojo.' },
  { label:'Modus Tollens', text:'Si hay fuego, hay humo.\nNo hay humo.\nEn consecuencia, no hay fuego.' },
  { label:'Sil. Disyuntivo', text:'O el sistema falla por hardware o falla por software.\nNo falla por hardware.\nPor lo tanto, falla por software.' },
  { label:'Sil. Hipotético', text:'Si estudio, apruebo.\nSi apruebo, me gradúo.\nPor lo tanto, si estudio, me gradúo.' },
  { label:'Conjunción', text:'El servidor está activo.\nEl servidor tiene conexión.\nPor lo tanto, el servidor está activo y tiene conexión.' }
];

const FZ_PATTERNS = [
  { regex:/si\s+(.+?)[,\.]\s*(entonces\s+)?(.+)/i, type:'condicional', build:(m)=>({ vars:[{letter:'p',text:m[1].trim()},{letter:'q',text:m[3].trim()}], formula:'p → q' }) },
  { regex:/(.+?)\s+(solo si|solamente si)\s+(.+)/i, type:'condicional_inv', build:(m)=>({ vars:[{letter:'p',text:m[1].trim()},{letter:'q',text:m[3].trim()}], formula:'p → q' }) },
  { regex:/(.+?)\s+si y solo si\s+(.+)/i, type:'bicondicional', build:(m)=>({ vars:[{letter:'p',text:m[1].trim()},{letter:'q',text:m[2].trim()}], formula:'p ↔ q' }) },
  { regex:/(.+?)\s+(y|pero|además)\s+(.+)/i, type:'conjuncion', build:(m)=>({ vars:[{letter:'p',text:m[1].trim()},{letter:'q',text:m[3].trim()}], formula:'p ∧ q' }) },
  { regex:/[oa]\s+(.+?)\s+o\s+(.+)/i, type:'disyuncion', build:(m)=>({ vars:[{letter:'p',text:m[1].trim()},{letter:'q',text:m[2].trim()}], formula:'p ∨ q' }) },
  { regex:/^(no\s+|no es cierto que\s+|es falso que\s+)(.+)/i, type:'negacion', build:(m)=>({ vars:[{letter:'p',text:m[2].trim()}], formula:'¬p' }) },
  { regex:/^(por lo tanto|en consecuencia|luego|entonces|por tanto)[,\s]+(.+)/i, type:'conclusion', build:(m)=>({ vars:[{letter:'∴',text:m[2].trim()}], formula:'(conclusión)' }) }
];

function buildFormalizador() {
  const btns = document.getElementById('fz-examples-btns');
  if(!btns) return;
  FZ_EXAMPLES.forEach(ex => {
    const b = document.createElement('button');
    b.className = 'btn btn-outline';
    b.style.fontSize = '.78rem';
    b.textContent = ex.label;
    b.onclick = () => { document.getElementById('fz-input').value = ex.text; formalize(); };
    btns.appendChild(b);
  });
}

function formalize() {
  const raw = document.getElementById('fz-input').value.trim();
  if(!raw) { alert('Escribe un argumento primero.'); return; }
  const lines = raw.split('\n').map(l=>l.trim()).filter(l=>l);
  const result = document.getElementById('fz-result');

  const analyzed = lines.map(line => {
    let found = null;
    for(const pat of FZ_PATTERNS) {
      const m = line.match(pat.regex);
      if(m) { found = { type: pat.type, data: pat.build(m), original: line }; break; }
    }
    if(!found) found = { type:'simple', data:{ vars:[{letter:'p',text:line}], formula:'p' }, original: line };
    return found;
  });

  // Assign consistent variable letters
  const varMap = {};
  let letterIdx = 0;
  const letters = ['p','q','r','s','t'];
  const usedVars = [];

  analyzed.forEach(a => {
    if(!a.data.vars) return;
    a.data.vars.forEach(v => {
      if(v.letter === '∴') return;
      const key = v.text.toLowerCase().replace(/\s+/g,' ');
      if(!varMap[key]) { varMap[key] = letters[letterIdx++] || 'x'; }
      v.assignedLetter = varMap[key];
      if(!usedVars.find(u=>u.letter===varMap[key])) usedVars.push({letter:varMap[key], text:v.text});
    });
  });

  // Build output
  const varDefHtml = usedVars.map(v =>
    `<div style="display:flex;align-items:baseline;gap:.5rem;padding:.2rem 0;">
      <span style="font-family:'DM Mono',monospace;font-weight:700;color:var(--blue);min-width:20px;">${v.letter}</span>
      <span style="color:var(--text2);font-size:.88rem;">= "${v.text}"</span>
    </div>`
  ).join('');

  const formulasHtml = analyzed.map((a, i) => {
    let fml = a.data.formula;
    if(a.data.vars) {
      a.data.vars.forEach(v => {
        if(v.assignedLetter) fml = fml.replace(new RegExp(v.letter,'g'), v.assignedLetter);
      });
    }
    const isConcl = a.type === 'conclusion';
    return `
      <div style="display:flex;align-items:flex-start;gap:1rem;padding:.6rem 0;border-bottom:1px solid var(--border);">
        <div style="font-size:.78rem;color:var(--slate);min-width:20px;padding-top:.1rem;">${isConcl?'∴':i+1}</div>
        <div style="flex:1;">
          <div style="font-size:.84rem;color:var(--text2);font-style:italic;margin-bottom:.2rem;">"${a.original}"</div>
          <div style="font-family:'DM Mono',monospace;font-weight:700;color:${isConcl?'var(--red)':'var(--navy)'};font-size:1rem;">${isConcl?'∴ ':''} ${fml}</div>
          <div style="font-size:.75rem;color:var(--blue);margin-top:.15rem;">Tipo: ${a.type.replace('_',' ')}</div>
        </div>
      </div>`;
  }).join('');

  result.style.display = 'block';
  result.innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;">
      <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;">
        <div style="background:var(--green);color:white;padding:.75rem 1.25rem;font-weight:600;font-size:.88rem;">✅ Variables Identificadas</div>
        <div style="padding:1.1rem 1.25rem;">${varDefHtml || '<p style="color:var(--slate);font-size:.85rem;">No se identificaron variables.</p>'}</div>
      </div>
      <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;">
        <div style="background:var(--blue);color:white;padding:.75rem 1.25rem;font-weight:600;font-size:.88rem;">🔣 Formalización</div>
        <div style="padding:1.1rem 1.25rem;">${formulasHtml}</div>
      </div>
    </div>
    <div style="margin-top:1rem;padding:.9rem 1.1rem;background:var(--accent-light);border:1px solid #fed7aa;border-radius:10px;font-size:.83rem;color:#92400e;">
      <strong>⚠️ Nota:</strong> El formalizador detecta patrones comunes. Revisa siempre la formalización y ajústala según el contexto exacto de las premisas.
    </div>
  `;
  trackLogro('formalizado');
}

// ====================== VERIFICADOR ======================
function buildVerificador() {
  const ex = document.getElementById('vf-examples');
  if(!ex) return;
  const examples = [
    { label:'Modus Ponens', premises:'p → q\np', conclusion:'q' },
    { label:'Modus Tollens', premises:'p → q\n¬q', conclusion:'¬p' },
    { label:'Sil. Disyuntivo', premises:'p ∨ q\n¬p', conclusion:'q' },
    { label:'Afirm. Consecuente (falacia)', premises:'p → q\nq', conclusion:'p' },
    { label:'Neg. Antecedente (falacia)', premises:'p → q\n¬p', conclusion:'¬q' }
  ];
  examples.forEach(e => {
    const btn = document.createElement('button');
    btn.className = 'btn btn-outline';
    btn.style.cssText = 'font-size:.78rem;justify-content:flex-start;';
    btn.textContent = e.label;
    btn.onclick = () => {
      document.getElementById('vf-premises').value = e.premises;
      document.getElementById('vf-conclusion').value = e.conclusion;
      verifyArgument();
    };
    ex.appendChild(btn);
  });
}

function verifyArgument() {
  const premRaw = document.getElementById('vf-premises').value.trim();
  const conRaw = document.getElementById('vf-conclusion').value.trim();
  const res = document.getElementById('vf-result');
  res.style.display = 'none';
  if(!premRaw || !conRaw) { alert('Completa las premisas y la conclusión.'); return; }

  try {
    const premLines = premRaw.split('\n').map(l=>l.trim()).filter(l=>l);
    const premTrees = premLines.map(l => parseFormula(tokenize(l)));
    const conTree = parseFormula(tokenize(conRaw));

    // Collect all variables
    const varSet = new Set();
    [...premTrees, conTree].forEach(t => getVars(t).forEach(v => varSet.add(v)));
    const vars = [...varSet].sort();
    if(vars.length > 4) { alert('Máximo 4 variables para verificar.'); return; }

    const n = vars.length;
    const counterexamples = [];
    let valid = true;

    for(let mask = 0; mask < Math.pow(2,n); mask++) {
      const vals = {};
      vars.forEach((v,i) => { vals[v] = Boolean((mask >> (n-1-i)) & 1); });
      const allPremsTrue = premTrees.every(t => evalTree(t, vals));
      if(allPremsTrue) {
        const conTrue = evalTree(conTree, vals);
        if(!conTrue) { valid = false; counterexamples.push({...vals}); }
      }
    }

    const color = valid ? 'var(--green)' : 'var(--red)';
    const bg = valid ? 'var(--green-light)' : 'var(--red-light)';
    const border = valid ? '#bbf7d0' : 'var(--red-mid)';

    let html = `
      <div style="background:${bg};border:2px solid ${border};border-radius:12px;padding:1.25rem 1.5rem;margin-bottom:1rem;">
        <div style="font-weight:700;font-size:1.1rem;color:${color};margin-bottom:.4rem;">${valid ? '✅ ARGUMENTO VÁLIDO' : '❌ ARGUMENTO INVÁLIDO'}</div>
        <div style="font-size:.9rem;color:var(--text2);">${valid
          ? 'En todas las filas donde las premisas son verdaderas, la conclusión también lo es.'
          : `Se encontraron <strong>${counterexamples.length}</strong> contraejemplo(s) donde las premisas son verdaderas pero la conclusión es falsa.`
        }</div>
      </div>`;

    if(!valid && counterexamples.length > 0) {
      html += `<div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;margin-bottom:1rem;">
        <div style="background:var(--navy);color:white;padding:.65rem 1.25rem;font-size:.85rem;font-weight:600;">Contraejemplos (premisas V pero conclusión F):</div>
        <div style="overflow-x:auto;"><table style="font-size:.85rem;min-width:100%;"><thead><tr>
          ${vars.map(v=>`<th>${v}</th>`).join('')}<th style="background:#7f1d1d;color:white;">${conRaw}</th>
        </tr></thead><tbody>
        ${counterexamples.slice(0,4).map(ce => `<tr>${vars.map(v=>`<td class="${ce[v]?'true-val':'false-val'}">${ce[v]?'V':'F'}</td>`).join('')}<td class="false-val" style="font-weight:700;">F</td></tr>`).join('')}
        </tbody></table></div></div>`;
    }

    res.style.display = 'block';
    res.innerHTML = html;
    trackLogro('verificado');
  } catch(e) {
    res.style.display = 'block';
    res.innerHTML = `<div class="alert alert-warning"><strong>Error:</strong> ${e.message}. Verifica la sintaxis de tus fórmulas.</div>`;
  }
}

// ====================== ÁRBOL SINTÁCTICO ======================
function loadTreeEx(f) { document.getElementById('tree-formula').value = f; generateTree(); }

function generateTree() {
  const raw = document.getElementById('tree-formula').value.trim();
  const err = document.getElementById('tree-error');
  const res = document.getElementById('tree-result');
  err.style.display = 'none'; res.style.display = 'none';
  if(!raw) return;
  try {
    const tree = parseFormula(tokenize(raw));
    document.getElementById('tree-formula-display').textContent = `Árbol sintáctico de:  ${raw}`;
    document.getElementById('tree-container').innerHTML = renderTreeSVG(tree, raw);
    res.style.display = 'block';
    res.scrollIntoView({behavior:'smooth',block:'nearest'});
    trackLogro('tree_generated');
  } catch(e) {
    err.style.display = 'block';
    err.textContent = 'Error: ' + e.message;
  }
}

function renderTreeSVG(root, raw) {
  const NODE_W = 90, NODE_H = 36, V_GAP = 56, H_GAP = 16;
  const opLabels = {AND:'∧', OR:'∨', IMP:'→', IFF:'↔', NOT:'¬'};
  const opColors = {AND:'#16a34a', OR:'#f97316', IMP:'#3b82f6', IFF:'#b45309', NOT:'#dc2626', VAR:'#1e293b'};

  function layoutTree(node) {
    if(node.op === 'VAR') return { node, w:NODE_W, x:0, y:0, children:[] };
    const children = node.op === 'NOT' ? [layoutTree(node.e)] : [layoutTree(node.l), layoutTree(node.r)];
    const totalW = children.reduce((s,c)=>s+c.w,0) + H_GAP*(children.length-1);
    let cx = 0;
    children.forEach(c => { c.x = cx + c.w/2; cx += c.w + H_GAP; });
    return { node, w:Math.max(totalW, NODE_W), x:0, y:0, children };
  }

  function computePositions(layout, ox, oy) {
    layout.ax = ox + layout.w/2;
    layout.ay = oy;
    layout.children.forEach(c => computePositions(c, ox + c.x - c.w/2, oy + NODE_H + V_GAP));
  }

  function getMaxDepth(layout) {
    if(!layout.children.length) return 1;
    return 1 + Math.max(...layout.children.map(getMaxDepth));
  }

  function collectNodes(layout, arr=[]) {
    arr.push(layout);
    layout.children.forEach(c=>collectNodes(c,arr));
    return arr;
  }

  const layout = layoutTree(root);
  computePositions(layout, 20, 30);
  const allNodes = collectNodes(layout);
  const svgW = layout.w + 40;
  const depth = getMaxDepth(layout);
  const svgH = depth * (NODE_H + V_GAP) + 40;

  let edges = '';
  allNodes.forEach(n => {
    n.children.forEach(c => {
      edges += `<line x1="${n.ax}" y1="${n.ay+NODE_H/2}" x2="${c.ax}" y2="${c.ay+NODE_H/2}" stroke="#94a3b8" stroke-width="1.5"/>`;
    });
  });

  let nodes = '';
  allNodes.forEach(n => {
    const label = n.node.op === 'VAR' ? n.node.name : opLabels[n.node.op] || n.node.op;
    const col = opColors[n.node.op] || '#1e293b';
    const isLeaf = n.node.op === 'VAR';
    nodes += `
      <rect x="${n.ax - NODE_W/2}" y="${n.ay}" width="${NODE_W}" height="${NODE_H}" rx="8"
        fill="${isLeaf ? '#f8fafc' : col+'1a'}" stroke="${col}" stroke-width="${isLeaf?1:2}"/>
      <text x="${n.ax}" y="${n.ay + NODE_H/2 + 1}" text-anchor="middle" dominant-baseline="central"
        font-family="'DM Mono',monospace" font-size="${isLeaf?13:15}" font-weight="${isLeaf?400:700}" fill="${col}">${label}</text>
    `;
    if(!isLeaf) {
      const fullLabel = n.node.op === 'NOT' ? `¬(${treeToStr(n.node.e)})` : `${treeToStr(n.node.l)} ${opLabels[n.node.op]} ${treeToStr(n.node.r)}`;
      nodes += `<title>${fullLabel}</title>`;
    }
  });

  return `<svg width="100%" viewBox="0 0 ${svgW} ${svgH}" style="min-height:${svgH}px;max-width:100%;">
    <defs><marker id="ta" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="4" markerHeight="4" orient="auto-start-reverse">
      <circle cx="5" cy="5" r="3" fill="#94a3b8"/></marker></defs>
    ${edges}${nodes}
  </svg>`;
}

// ====================== DUELO ======================
let duelState = {};

function buildDuelo() { /* initialized on start */ }

function startDuelo() {
  const p1 = document.getElementById('p1-name').value || 'Jugador 1';
  const p2 = document.getElementById('p2-name').value || 'Jugador 2';
  const rounds = parseInt(document.getElementById('duelo-rounds').value);
  const timeLimit = parseInt(document.getElementById('duelo-time').value);
  const deck = fisherYates(QUIZ_QUESTIONS).slice(0, rounds);
  duelState = { p1, p2, deck, rounds, timeLimit, idx:0, currentPlayer:1, scores:{1:0, 2:0}, timer:null };
  document.getElementById('duelo-setup').style.display = 'none';
  document.getElementById('duelo-results').style.display = 'none';
  document.getElementById('duelo-game').style.display = 'block';
  renderDuelo();
}

function renderDuelo() {
  const s = duelState;
  if(s.idx >= s.deck.length) { showDueloResults(); return; }
  const q = s.deck[s.idx];
  const pName = s.currentPlayer === 1 ? s.p1 : s.p2;
  const pColor = s.currentPlayer === 1 ? '#3b82f6' : '#dc2626';
  clearInterval(s.timer);
  let timeLeft = s.timeLimit;

  const game = document.getElementById('duelo-game');
  game.innerHTML = `
    <div style="background:white;border:2px solid ${pColor};border-radius:14px;box-shadow:var(--shadow-lg);overflow:hidden;">
      <div style="background:${pColor};color:white;padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;">
        <div>
          <div style="font-size:.75rem;opacity:.75;text-transform:uppercase;letter-spacing:.08em;">Turno de</div>
          <div style="font-family:'DM Serif Display',serif;font-size:1.3rem;">${pName}</div>
        </div>
        <div style="display:flex;gap:2rem;align-items:center;">
          <div style="text-align:center;"><div style="font-family:'DM Serif Display',serif;font-size:1.4rem;">${s.scores[1]}</div><div style="font-size:.72rem;opacity:.75;">${s.p1}</div></div>
          <div style="font-size:1.2rem;opacity:.5;">vs</div>
          <div style="text-align:center;"><div style="font-family:'DM Serif Display',serif;font-size:1.4rem;">${s.scores[2]}</div><div style="font-size:.72rem;opacity:.75;">${s.p2}</div></div>
          <div style="background:rgba(255,255,255,.2);border-radius:8px;padding:.4rem .9rem;text-align:center;">
            <div style="font-family:'DM Serif Display',serif;font-size:1.6rem;" id="duel-timer">${timeLeft}</div>
            <div style="font-size:.7rem;opacity:.75;">seg</div>
          </div>
        </div>
      </div>
      <div style="padding:1.5rem;">
        <div style="font-size:.78rem;color:var(--slate);text-transform:uppercase;letter-spacing:.08em;font-weight:600;margin-bottom:.5rem;">Pregunta ${s.idx+1} de ${s.rounds}</div>
        <div style="font-size:1rem;font-weight:500;color:var(--navy);margin-bottom:1.25rem;">${q.q}</div>
        <div style="background:var(--slate-light);border:1px solid var(--border);border-radius:10px;padding:.9rem 1.1rem;font-family:'DM Mono',monospace;margin-bottom:1.25rem;">
          ${q.premises.split('\n').map(p=>`<div>${p}</div>`).join('')}
          <div style="border-top:1px solid var(--border);margin-top:.4rem;padding-top:.4rem;color:var(--red);font-weight:600;">${q.conclusion}</div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.6rem;" id="duel-opts">
          ${q.opts.map(opt=>`
            <button onclick="answerDuelo('${opt.replace(/'/g,"\\'")}',this)" style="background:white;border:1.5px solid var(--border);border-radius:10px;padding:.75rem;font-family:'DM Mono',monospace;font-size:.88rem;cursor:pointer;text-align:left;transition:all .15s;" onmouseover="this.style.borderColor='${pColor}';this.style.background='${pColor}11'" onmouseout="this.style.borderColor='var(--border)';this.style.background='white'">${opt}</button>
          `).join('')}
        </div>
        <div id="duel-feedback" style="display:none;margin-top:1rem;border-radius:10px;padding:.9rem 1.1rem;font-size:.88rem;"></div>
      </div>
    </div>
  `;

  s.timer = safeSetInterval(() => {
    timeLeft--;
    const el = document.getElementById('duel-timer');
    if(el) el.textContent = timeLeft;
    if(el) el.style.color = timeLeft <= 5 ? '#fbbf24' : 'white';
    if(timeLeft <= 0) { clearInterval(s.timer); timeUp(); }
  }, 1000);
}

function answerDuelo(ans, btn) {
  clearInterval(duelState.timer);
  const q = duelState.deck[duelState.idx];
  const correct = ans === q.answer;
  if(correct) duelState.scores[duelState.currentPlayer]++;
  document.querySelectorAll('#duel-opts button').forEach(b => {
    b.disabled = true;
    if(b.textContent.trim() === q.answer) b.style.cssText += 'border-color:var(--green);background:var(--green-light);font-weight:700;';
    else if(b === btn && !correct) b.style.cssText += 'border-color:var(--red);background:var(--red-light);';
  });
  const fb = document.getElementById('duel-feedback');
  fb.style.display = 'block';
  fb.style.background = correct ? 'var(--green-light)' : 'var(--red-light)';
  fb.style.border = `1px solid ${correct?'#bbf7d0':'var(--red-mid)'}`;
  fb.style.color = correct ? 'var(--green)' : 'var(--red)';
  fb.innerHTML = `<strong>${correct ? '✅ ¡Correcto! +1 punto' : '❌ Incorrecto'}</strong> — Respuesta: ${q.answer}`;
  setTimeout(() => {
    duelState.idx++;
    duelState.currentPlayer = duelState.currentPlayer === 1 ? 2 : 1;
    renderDuelo();
  }, 1800);
}

function timeUp() {
  document.querySelectorAll('#duel-opts button').forEach(b => b.disabled = true);
  const fb = document.getElementById('duel-feedback');
  if(fb) { fb.style.display='block'; fb.style.cssText+='background:var(--accent-light);border:1px solid #fed7aa;color:#92400e;'; fb.innerHTML='⏱️ ¡Tiempo! Sin puntos.'; }
  safeSetTimeout(() => { duelState.idx++; duelState.currentPlayer = duelState.currentPlayer===1?2:1; renderDuelo(); }, 1500);
}

function showDueloResults() {
  clearInterval(duelState.timer);
  document.getElementById('duelo-game').style.display = 'none';
  const res = document.getElementById('duelo-results');
  res.style.display = 'block';
  const s = duelState;
  const winner = s.scores[1] > s.scores[2] ? s.p1 : s.scores[2] > s.scores[1] ? s.p2 : null;
  res.innerHTML = `
    <div class="results-card">
      <div style="font-size:3rem;margin-bottom:1rem;">${winner ? '🏆' : '🤝'}</div>
      <div style="font-family:'DM Serif Display',serif;font-size:1.6rem;color:var(--navy);margin-bottom:.5rem;">${winner ? `¡Ganó ${winner}!` : '¡Empate!'}</div>
      <div style="display:flex;justify-content:center;gap:3rem;margin:1.5rem 0;flex-wrap:wrap;">
        <div style="text-align:center;padding:1.25rem 2rem;background:${s.scores[1]>=s.scores[2]?'var(--blue-light)':'var(--slate-light)'};border-radius:12px;border:${s.scores[1]>s.scores[2]?'2px solid var(--blue)':'1px solid var(--border)'};">
          <div style="font-size:.85rem;color:var(--slate);">🔵 ${s.p1}</div>
          <div style="font-family:'DM Serif Display',serif;font-size:2.5rem;color:var(--blue);">${s.scores[1]}</div>
        </div>
        <div style="text-align:center;padding:1.25rem 2rem;background:${s.scores[2]>=s.scores[1]?'var(--red-light)':'var(--slate-light)'};border-radius:12px;border:${s.scores[2]>s.scores[1]?'2px solid var(--red)':'1px solid var(--border)'};">
          <div style="font-size:.85rem;color:var(--slate);">🔴 ${s.p2}</div>
          <div style="font-family:'DM Serif Display',serif;font-size:2.5rem;color:var(--red);">${s.scores[2]}</div>
        </div>
      </div>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <button class="btn btn-primary" onclick="document.getElementById('duelo-setup').style.display='block';document.getElementById('duelo-results').style.display='none';">🔄 Jugar de nuevo</button>
        <button class="btn btn-outline" onclick="showPage('logros')">🏆 Ver Logros</button>
      </div>
    </div>`;
  trackLogro('duelo_completado');
}

// ====================== LOGROS ======================
const LOGROS_DEF = [
  { id:'primer_quiz', icon:'🎯', name:'Primera Prueba', desc:'Completa tu primer quiz', condition: s => s.quiz_answered >= 1 },
  { id:'quiz_perfecto', icon:'🏆', name:'Quiz Perfecto', desc:'Obtén 20/20 en el quiz', condition: s => s.quiz_perfect },
  { id:'quiz_10', icon:'📝', name:'Estudiante Dedicado', desc:'Responde 10 preguntas del quiz', condition: s => s.quiz_answered >= 10 },
  { id:'flashcard_5', icon:'🃏', name:'Memorizador', desc:'Domina 5 flashcards', condition: s => s.fc_easy >= 5 },
  { id:'flashcard_all', icon:'🧠', name:'Maestro de Reglas', desc:'Domina las 10 flashcards', condition: s => s.fc_easy >= 10 },
  { id:'ejercicio_5', icon:'✏️', name:'Practicante', desc:'Ve la solución de 5 ejercicios', condition: s => s.sol_seen >= 5 },
  { id:'ejercicio_all', icon:'📚', name:'Completo', desc:'Ve todos los 20 ejercicios', condition: s => s.sol_seen >= 20 },
  { id:'cp_5', icon:'🧩', name:'Completador', desc:'Responde 5 ejercicios de "Completa"', condition: s => s.cp_attempts >= 5 },
  { id:'cp_correcto', icon:'✅', name:'Sin Errores', desc:'Acierta 3 en "Completa la Prueba"', condition: s => s.cp_correct >= 3 },
  { id:'tabla_generada', icon:'📊', name:'Analista', desc:'Genera una tabla de verdad', condition: s => s.tables_generated >= 1 },
  { id:'formalizador_used', icon:'🗣️', name:'Lingüista Lógico', desc:'Usa el formalizador', condition: s => s.formalizations >= 1 },
  { id:'verificador_used', icon:'🔍', name:'Verificador', desc:'Verifica un argumento', condition: s => s.verifications >= 1 },
  { id:'arbol_generado', icon:'🌳', name:'Árbol Sintáctico', desc:'Genera un árbol sintáctico', condition: s => s.trees_generated >= 1 },
  { id:'duelo_won', icon:'⚔️', name:'Duelista', desc:'Completa un duelo 1 vs 1', condition: s => s.duelos >= 1 },
  { id:'superviviente', icon:'❤️', name:'Superviviente', desc:'Juega el modo supervivencia', condition: s => s.surv_played >= 1 },
  { id:'surv_10', icon:'🔥', name:'En Racha', desc:'Llega a 10 correctas en supervivencia', condition: s => s.surv_best >= 10 },
  { id:'contrarreloj', icon:'⏱️', name:'Velocista', desc:'Completa una partida de contrarreloj', condition: s => s.crl_played >= 1 },
  { id:'detective', icon:'🔍', name:'Detective', desc:'Resuelve un caso del Detective Lógico', condition: s => s.mystery_played >= 1 },
  { id:'torneo', icon:'🏟️', name:'Campeón de Torneo', desc:'Completa un torneo de 4 jugadores', condition: s => s.torneo_played >= 1 },
  { id:'vi_perfecto', icon:'🎯', name:'Detector de Falacias', desc:'Acierta 15+ en Válido/Inválido', condition: s => s.vi_correct >= 15 },
  { id:'explorador', icon:'🗺️', name:'Explorador', desc:'Visita todas las secciones', condition: s => s.pages_visited >= 10 },
  { id:'err_first', icon:'🔎', name:'Ojo Crítico', desc:'Completa tu primer caso de Encuentra el Error', condition: s => s.err_played >= 1 },
  { id:'err_correct_5', icon:'🧐', name:'Juez Lógico', desc:'Detecta correctamente 5 errores', condition: s => s.err_correct >= 5 },
  { id:'err_perfect', icon:'⚖️', name:'Corrector Perfecto', desc:'Completa un set sin fallar ningún error', condition: s => s.err_perfect >= 1 },
  { id:'cadena_first', icon:'🔗', name:'Eslabonador', desc:'Completa tu primera Cadena Lógica', condition: s => s.cadena_played >= 1 },
  { id:'cadena_perfect', icon:'⛓️', name:'Cadena de Oro', desc:'Resuelve una Cadena Lógica perfecta', condition: s => s.cadena_perfect >= 1 },
  { id:'cadena_5', icon:'🏅', name:'Constructor Formal', desc:'Completa 5 cadenas lógicas', condition: s => s.cadena_played >= 5 }
];

const logroStats = {
  quiz_answered:0, quiz_perfect:false, fc_easy:0, sol_seen:0,
  cp_attempts:0, cp_correct:0, tables_generated:0, formalizations:0,
  verifications:0, trees_generated:0, duelos:0, vi_correct:0,
  pages_visited:0, surv_played:0, crl_played:0, mystery_played:0,
  torneo_played:0, surv_best:0, err_played:0, err_correct:0, err_perfect:0,
  cadena_played:0, cadena_perfect:0
};
const unlockedLogros = new Set();

function trackLogro(event, value=1) {
  if(event==='quiz_answer') logroStats.quiz_answered += value;
  if(event==='quiz_perfect') logroStats.quiz_perfect = true;
  if(event==='fc_easy') logroStats.fc_easy = value;
  if(event==='sol_seen') logroStats.sol_seen = value;
  if(event==='cp_attempt') logroStats.cp_attempts++;
  if(event==='cp_correct') logroStats.cp_correct++;
  if(event==='table_generated') logroStats.tables_generated++;
  if(event==='formalizado') logroStats.formalizations++;
  if(event==='verificado') logroStats.verifications++;
  if(event==='tree_generated') logroStats.trees_generated++;
  if(event==='duelo_completado') logroStats.duelos++;
  if(event==='vi_correct') logroStats.vi_correct = value;
  if(event==='page_visited') logroStats.pages_visited++;
  if(event==='surv_played') { logroStats.surv_played++; if(value > logroStats.surv_best) logroStats.surv_best = value; }
  if(event==='crl_played') logroStats.crl_played++;
  if(event==='mystery_played') logroStats.mystery_played++;
  if(event==='torneo_completado') logroStats.torneo_played++;
  if(event==='err_played') logroStats.err_played++;
  if(event==='err_correct') logroStats.err_correct++;
  if(event==='cadena_played') logroStats.cadena_played++;
  if(event==='cadena_perfect') logroStats.cadena_perfect++;
  if(event==='err_finished') {
    // Check if perfect: all answered correctly in this session
    if(errState.pool && errState.correct === errState.pool.length && errState.pool.length > 0)
      logroStats.err_perfect++;
  }
  checkLogros();
}

function checkLogros() {
  LOGROS_DEF.forEach(l => {
    if(!unlockedLogros.has(l.id) && l.condition(logroStats)) {
      unlockedLogros.add(l.id);
      showLogroBadge(l);
    }
  });
  if(document.getElementById('page-logros')?.classList.contains('active')) buildLogros();
}

function showLogroBadge(logro) {
  const toast = document.createElement('div');
  toast.style.cssText = 'position:fixed;bottom:1.5rem;right:1.5rem;background:var(--navy);color:white;border-radius:12px;padding:1rem 1.25rem;box-shadow:0 8px 32px rgba(0,0,0,.3);z-index:9999;display:flex;align-items:center;gap:.75rem;animation:slideInRight .35s cubic-bezier(.22,.68,0,1.2) both;max-width:300px;border-left:4px solid var(--accent);';
  toast.innerHTML = `<div style="font-size:2rem;">${logro.icon}</div><div><div style="font-weight:700;font-size:.9rem;">¡Logro desbloqueado!</div><div style="font-size:.82rem;color:#94a3b8;margin-top:.1rem;">${logro.name}: ${logro.desc}</div></div>`;
  document.body.appendChild(toast);
  setTimeout(() => toast.style.animation='fadeOut .4s ease forwards', 3000);
  setTimeout(() => toast.remove(), 3450);
}

function buildLogros() {
  const grid = document.getElementById('logros-grid');
  const stats = document.getElementById('logros-stats');
  if(!grid) return;
  grid.innerHTML = '';
  LOGROS_DEF.forEach(l => {
    const unlocked = unlockedLogros.has(l.id);
    const card = document.createElement('div');
    card.style.cssText = `background:white;border:${unlocked?'2px solid var(--accent)':'1px solid var(--border)'};border-radius:12px;padding:1.25rem;box-shadow:var(--shadow);text-align:center;transition:all .2s;${!unlocked?'opacity:.5;filter:grayscale(1);':''}`;
    card.innerHTML = `
      <div style="font-size:2.5rem;margin-bottom:.5rem;">${l.icon}</div>
      <div style="font-weight:700;font-size:.88rem;color:${unlocked?'var(--navy)':'var(--slate)'};margin-bottom:.25rem;">${l.name}</div>
      <div style="font-size:.78rem;color:var(--slate);">${l.desc}</div>
      ${unlocked?'<div style="margin-top:.5rem;font-size:.75rem;color:var(--accent);font-weight:600;">✓ Desbloqueado</div>':''}
    `;
    grid.appendChild(card);
  });

  if(stats) stats.innerHTML = [
    { label:'Preguntas en Quiz',     val: logroStats.quiz_answered },
    { label:'Flashcards dominadas',  val: logroStats.fc_easy },
    { label:'Ejercicios revisados',  val: logroStats.sol_seen },
    { label:'Tablas generadas',      val: logroStats.tables_generated },
    { label:'Partidas supervivencia',val: logroStats.surv_played },
    { label:'Partidas contrarreloj', val: logroStats.crl_played },
    { label:'Casos detective',       val: logroStats.mystery_played },
    { label:'Duelos jugados',        val: logroStats.duelos },
    { label:'Torneos completados',   val: logroStats.torneo_played },
    { label:'Errores detectados',      val: logroStats.err_correct },
    { label:'Cadenas completadas',      val: logroStats.cadena_played },
    { label:'Logros desbloqueados',  val: unlockedLogros.size + '/' + LOGROS_DEF.length },
  ].map(s=>`
    <div style="background:var(--slate-light);border-radius:8px;padding:.75rem 1rem;text-align:center;">
      <div style="font-family:'DM Serif Display',serif;font-size:1.4rem;color:var(--navy);">${s.val}</div>
      <div style="font-size:.75rem;color:var(--slate);">${s.label}</div>
    </div>`).join('');
}

// ====================== GENERADOR DE EXAMEN ======================
function generateExam() {
  const num = parseInt(document.getElementById('ex-num').value);
  const type = document.getElementById('ex-type').value;
  const course = document.getElementById('ex-course').value;
  const teacher = document.getElementById('ex-teacher').value;
  const date = document.getElementById('ex-date').value;
  const title = document.getElementById('ex-title').value;

  let pool = [];
  if(type === 'identify' || type === 'mixed') pool = [...QUIZ_QUESTIONS];
  if(type === 'validinvalid' || type === 'mixed') pool = [...pool, ...VI_DATA.slice(0,10).map(q=>({
    q: q.context, premises: q.arg, conclusion: q.valid?'VÁLIDO':'INVÁLIDO',
    answer: q.valid?'VÁLIDO':'INVÁLIDO', opts:['VÁLIDO','INVÁLIDO'], explain:q.explanation, isVI:true
  }))];

  const selected = fisherYates(pool).slice(0,num);

  const questionsHtml = selected.map((q, i) => `
    <div style="margin-bottom:1.5rem;padding-bottom:1.5rem;border-bottom:1px solid #ddd;">
      <div style="font-weight:bold;margin-bottom:.5rem;">${i+1}. ${q.q || q.context}</div>
      <div style="font-family:monospace;background:#f5f5f5;padding:.6rem .8rem;border-radius:4px;margin-bottom:.75rem;font-size:.9rem;white-space:pre-line;">${q.premises}</div>
      ${!q.isVI ? `<div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem;">${q.opts.map((o,j)=>`<div>( ) ${o}</div>`).join('')}</div>` : `<div>( ) VÁLIDO &nbsp;&nbsp; ( ) INVÁLIDO</div>`}
      <div style="margin-top:.6rem;height:30px;border-bottom:1px solid #aaa;"></div>
    </div>`).join('');

  const answerKey = selected.map((q,i)=>`<div style="margin:.2rem 0;">${i+1}. <strong>${q.answer}</strong></div>`).join('');

  const html = `
    <div style="background:white;border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow);overflow:hidden;">
      <div style="background:var(--navy);color:white;padding:.85rem 1.25rem;display:flex;justify-content:space-between;align-items:center;">
        <div style="font-weight:600;">Vista Previa del Examen</div>
        <button onclick="printExam()" class="btn btn-accent" style="font-size:.8rem;padding:.35rem .8rem;">🖨️ Imprimir</button>
      </div>
      <div style="padding:1.5rem;" id="exam-printable">
        <div style="text-align:center;border-bottom:2px solid #333;padding-bottom:1rem;margin-bottom:1.5rem;">
          <div style="font-size:.85rem;color:#555;">${course} — ${teacher}</div>
          <div style="font-size:1.3rem;font-weight:bold;margin:.3rem 0;">${title}</div>
          <div style="font-size:.82rem;color:#666;">Fecha: ${date || 'Por definir'}</div>
        </div>
        <div style="display:flex;gap:2rem;margin-bottom:1.5rem;font-size:.88rem;">
          <div>Nombre: ___________________________________</div>
          <div>Matrícula: _________________</div>
          <div>Nota: ________</div>
        </div>
        <div style="font-size:.82rem;color:#555;margin-bottom:1.25rem;padding:.6rem;background:#f9f9f9;border-radius:4px;">
          <strong>Instrucciones:</strong> Para cada argumento, selecciona la opción correcta o escribe la respuesta según corresponda. Cada pregunta vale ${Math.round(100/num)} puntos.
        </div>
        ${questionsHtml}
        <div style="page-break-before:always;margin-top:2rem;padding-top:1rem;border-top:2px dashed #aaa;">
          <div style="font-weight:bold;margin-bottom:.75rem;">📋 Clave de Respuestas (Uso exclusivo del profesor)</div>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:.3rem;">${answerKey}</div>
        </div>
      </div>
    </div>`;

  const preview = document.getElementById('exam-preview');
  preview.style.display = 'block';
  preview.innerHTML = html;
  preview.scrollIntoView({behavior:'smooth',block:'nearest'});
}

function printExam() {
  const content = document.getElementById('exam-printable');
  if(!content) { generateExam(); return; }
  const w = window.open('','_blank');
  w.document.write(`<html><head><title>Examen</title>
    <style>body{font-family:Arial,sans-serif;padding:2cm;font-size:11pt;}
    @media print{.no-print{display:none!important;}}</style></head>
    <body>${content.innerHTML}<scr'+'ipt>window.print();window.close();<\/scr'+'ipt></body></html>`);
  w.document.close();
}

// ====================== FLASHCARDS ======================
const FC_DATA = [
  { rule:'Modus Ponens', short:'MP', form:'p → q,  p  ∴  q', color:'#3b82f6', bg:'#eff6ff',
    premise:'p → q\np', conclusion:'q',
    explanation:'Si el condicional es verdadero y el antecedente se cumple, el consecuente es necesariamente verdadero.',
    example:'Si tienes fiebre (p), te recetan medicamento (q). Tienes fiebre. ∴ Te recetan medicamento.' },
  { rule:'Modus Tollens', short:'MT', form:'p → q,  ¬q  ∴  ¬p', color:'#dc2626', bg:'#fef2f2',
    premise:'p → q\n¬q', conclusion:'¬p',
    explanation:'Si el consecuente es falso, el antecedente debe ser también falso. Niega de atrás hacia adelante.',
    example:'Si hay fuego (p) hay humo (q). No hay humo (¬q). ∴ No hay fuego (¬p).' },
  { rule:'Silogismo Hipotético', short:'SH', form:'p→q,  q→r  ∴  p→r', color:'#7c3aed', bg:'#f5f3ff',
    premise:'p → q\nq → r', conclusion:'p → r',
    explanation:'Encadena dos condicionales cuando el consecuente del primero es el antecedente del segundo.',
    example:'Si estudio (p) apruebo (q). Si apruebo (q) me gradúo (r). ∴ Si estudio, me gradúo (p→r).' },
  { rule:'Silogismo Disyuntivo', short:'SD', form:'p ∨ q,  ¬p  ∴  q', color:'#f97316', bg:'#fff7ed',
    premise:'p ∨ q\n¬p', conclusion:'q',
    explanation:'Si una disyunción es verdadera y una de sus partes es falsa, la otra debe ser verdadera.',
    example:'O hay corriente (p) o hay batería (q). No hay corriente (¬p). ∴ Hay batería (q).' },
  { rule:'Adición', short:'Ad', form:'p  ∴  p ∨ q', color:'#16a34a', bg:'#f0fdf4',
    premise:'p', conclusion:'p ∨ q',
    explanation:'De una verdad podemos construir una disyunción con cualquier otra proposición, ya que basta que una sea verdadera.',
    example:'Hoy es lunes (p). ∴ Hoy es lunes o mañana llueve (p ∨ q). q puede ser cualquier cosa.' },
  { rule:'Simplificación', short:'Sim', form:'p ∧ q  ∴  p', color:'#0891b2', bg:'#ecfeff',
    premise:'p ∧ q', conclusion:'p  (o  q)',
    explanation:'De una conjunción verdadera podemos extraer cualquiera de sus componentes por separado.',
    example:'El sistema está activo y conectado (p ∧ q). ∴ El sistema está activo (p).' },
  { rule:'Conjunción', short:'Con', form:'p,  q  ∴  p ∧ q', color:'#0d9488', bg:'#f0fdfa',
    premise:'p\nq', conclusion:'p ∧ q',
    explanation:'Dos verdades individuales se pueden unir en una sola conjunción. Inversa de Simplificación.',
    example:'Tengo capital (p). Tengo personal (q). ∴ Tengo capital y personal (p ∧ q).' },
  { rule:'Absorción', short:'Abs', form:'p→q  ∴  p→(p∧q)', color:'#b45309', bg:'#fffbeb',
    premise:'p → q', conclusion:'p → (p ∧ q)',
    explanation:'Si p implica q, entonces cuando p ocurra tendremos tanto p como q juntos en el consecuente.',
    example:'Si eres alumno (p) tienes carnet (q). ∴ Si eres alumno, eres alumno Y tienes carnet (p→(p∧q)).' },
  { rule:'Dilema Constructivo', short:'DC', form:'(p→q)∧(r→s),  p∨r  ∴  q∨s', color:'#9333ea', bg:'#faf5ff',
    premise:'(p → q) ∧ (r → s)\np ∨ r', conclusion:'q ∨ s',
    explanation:'Tenemos dos planes y al menos uno de sus antecedentes ocurrirá. Garantizamos que al menos un consecuente ocurrirá.',
    example:'Sol→parque, lluvia→película. O hay sol o llueve. ∴ O vamos al parque o vemos película.' },
  { rule:'Dilema Destructivo', short:'DD', form:'(p→q)∧(r→s),  ¬q∨¬s  ∴  ¬p∨¬r', color:'#be123c', bg:'#fff1f2',
    premise:'(p → q) ∧ (r → s)\n¬q ∨ ¬s', conclusion:'¬p ∨ ¬r',
    explanation:'Si al menos un consecuente es falso, al menos un antecedente también debe serlo. MT aplicado a dos condicionales.',
    example:'Apruebo→celebro, contratan→descanso. Ni celebro ni descanso. ∴ O no aprobé o no me contrataron.' }
];

let fcDeck = [], fcIndex = 0, fcFlipped = false;
let fcRatings = {}, fcEasy = 0, fcHard = 0;

function buildFlashcards() {
  fcDeck = FC_DATA.map((_, i) => i);
  fcIndex = 0; fcFlipped = false; fcRatings = {}; fcEasy = 0; fcHard = 0;
  renderFCStrip();
  renderFC();
}

function setFlashMode(mode) {
  if(mode === 'hard') {
    const hard = Object.entries(fcRatings).filter(([,v]) => v === 'hard').map(([k]) => parseInt(k));
    if(!hard.length) { alert('Aún no has marcado ninguna tarjeta como difícil. Estudia primero todas.'); return; }
    fcDeck = hard;
  } else {
    fcDeck = FC_DATA.map((_, i) => i);
  }
  fcIndex = 0; fcFlipped = false;
  renderFCStrip(); renderFC();
}

function shuffleFlash() {
  fcDeck = fisherYates(fcDeck);
  fcIndex = 0; fcFlipped = false;
  renderFCStrip(); renderFC();
}

function renderFC() {
  const idx = fcDeck[fcIndex];
  const d = FC_DATA[idx];
  document.getElementById('fc-current').textContent = fcIndex + 1;
  document.getElementById('fc-total').textContent = fcDeck.length;

  // Front
  document.getElementById('fc-front-header').style.background = d.color;
  document.getElementById('fc-rule-name').textContent = d.rule;
  document.getElementById('fc-premises-display').innerHTML = d.premise.split('\n').map(p => `<div>${p}</div>`).join('');

  // Back
  document.getElementById('fc-back-header').style.background = d.bg;
  document.getElementById('fc-back-header').style.color = d.color;
  document.getElementById('fc-rule-name-back').textContent = d.rule;
  document.getElementById('fc-form-label').textContent = d.short;
  document.getElementById('fc-full-form').style.background = d.bg;
  document.getElementById('fc-full-form').style.color = d.color;
  document.getElementById('fc-full-form').innerHTML = `${d.premise.replace(/\n/g,'&nbsp;&nbsp;&nbsp;')} &nbsp; <strong>∴ ${d.conclusion}</strong>`;
  document.getElementById('fc-explanation-back').textContent = d.explanation;
  document.getElementById('fc-example-back').textContent = d.example;

  // Reset flip
  fcFlipped = false;
  document.getElementById('fc-card').style.transform = 'rotateY(0deg)';

  // Stats
  const seen = Object.keys(fcRatings).length;
  document.getElementById('fc-easy-count').textContent = fcEasy;
  document.getElementById('fc-hard-count').textContent = fcHard;
  document.getElementById('fc-unseen-count').textContent = fcDeck.length - seen;
  document.getElementById('fc-score-display').textContent = `${fcEasy} dominadas`;
  renderFCStrip();
}

function flipCard() {
  fcFlipped = !fcFlipped;
  document.getElementById('fc-card').style.transform = fcFlipped ? 'rotateY(180deg)' : 'rotateY(0deg)';
}

function nextCard() {
  if(fcIndex < fcDeck.length - 1) { fcIndex++; renderFC(); }
  else { fcIndex = 0; renderFC(); }
}

function prevCard() {
  if(fcIndex > 0) { fcIndex--; renderFC(); }
  else { fcIndex = fcDeck.length - 1; renderFC(); }
}

function rateCard(rating) {
  const idx = fcDeck[fcIndex];
  const prev = fcRatings[idx];
  fcRatings[idx] = rating;
  if(rating === 'easy') { if(prev !== 'easy') { fcEasy++; if(prev === 'hard') fcHard = Math.max(0, fcHard-1); } }
  else { if(prev !== 'hard') { fcHard++; if(prev === 'easy') fcEasy = Math.max(0, fcEasy-1); } }
  trackLogro('fc_easy', fcEasy);
  renderFCStrip();
  nextCard();
}

function renderFCStrip() {
  const c = document.getElementById('fc-strip');
  if(!c) return;
  c.innerHTML = '';
  fcDeck.forEach((cardIdx, i) => {
    const d = document.createElement('div');
    const r = fcRatings[cardIdx];
    d.style.cssText = `height:8px;border-radius:4px;flex:1;min-width:12px;transition:background .2s;background:${i===fcIndex ? '#f97316' : r==='easy' ? '#16a34a' : r==='hard' ? '#dc2626' : '#e2e8f0'};`;
    d.title = FC_DATA[cardIdx].rule;
    d.onclick = () => { fcIndex = i; renderFC(); };
    d.style.cursor = 'pointer';
    c.appendChild(d);
  });
}

// ====================== VÁLIDO / INVÁLIDO ======================
const VI_DATA = [
  { context:'Un estudiante razona así:', arg:'Si estudio (p), apruebo (q)\nEstudio (p)\n∴ Apruebo (q)', valid:true,
    name:'Modus Ponens', explanation:'✅ VÁLIDO — Modus Ponens. El antecedente (p) se cumple, por lo que el consecuente (q) se sigue necesariamente.' },
  { context:'Un argumento sobre el clima:', arg:'Si hay nubes (p), llueve (q)\nLlueve (q)\n∴ Hay nubes (p)', valid:false,
    name:'Falacia: Afirmación del Consecuente', explanation:'❌ INVÁLIDO — Falacia de afirmación del consecuente. Saber que q es verdadera NO nos dice nada sobre p. Podría llover sin nubes de tormenta, o las nubes aparecer después.' },
  { context:'Razonamiento de una empresa:', arg:'Si bajan los costos (p), aumentan las ganancias (q)\nNo bajan los costos (¬p)\n∴ No aumentan las ganancias (¬q)', valid:false,
    name:'Falacia: Negación del Antecedente', explanation:'❌ INVÁLIDO — Falacia de negación del antecedente. El condicional solo dice lo que pasa cuando p es verdadero. Si p es falso, q puede ser verdadero o falso por otras razones.' },
  { context:'Un médico diagnostica:', arg:'Si tiene infección (p), tiene fiebre (q)\nNo tiene fiebre (¬q)\n∴ No tiene infección (¬p)', valid:true,
    name:'Modus Tollens', explanation:'✅ VÁLIDO — Modus Tollens. Al fallar el consecuente (¬q), necesariamente falla el antecedente (¬p). Si la infección causaría fiebre, y no hay fiebre, no hay infección.' },
  { context:'Un argumento sobre transporte:', arg:'O tomo el bus (p) o llego tarde (q)\nNo tomo el bus (¬p)\n∴ Llego tarde (q)', valid:true,
    name:'Silogismo Disyuntivo', explanation:'✅ VÁLIDO — Silogismo Disyuntivo. Había dos opciones; al descartar una (¬p) la otra (q) es necesaria.' },
  { context:'Razonamiento sobre un sistema:', arg:'El sistema funciona (p) y está actualizado (q)\n∴ El sistema funciona (p)', valid:true,
    name:'Simplificación', explanation:'✅ VÁLIDO — Simplificación. De la conjunción (p ∧ q) extraemos p. Si ambas son verdaderas, cada una individualmente también lo es.' },
  { context:'Un estudiante concluye:', arg:'Si paso el examen (p), me gradúo (q)\nMe gradúo (q)\n∴ Pasé el examen (p)', valid:false,
    name:'Falacia: Afirmación del Consecuente', explanation:'❌ INVÁLIDO — Falacia de afirmación del consecuente. Podría haberse graduado por otra vía (convalidaciones, etc.). El consecuente verdadero no garantiza el antecedente.' },
  { context:'Razonamiento en cadena:', arg:'Si hay inversión (p), hay empleo (q)\nSi hay empleo (q), hay consumo (r)\n∴ Si hay inversión (p), hay consumo (r)', valid:true,
    name:'Silogismo Hipotético', explanation:'✅ VÁLIDO — Silogismo Hipotético. Encadenamos p→q y q→r para obtener p→r directamente.' },
  { context:'Un argumento sobre tecnología:', arg:'Si actualizo el software (p), mejora el rendimiento (q)\n∴ Si actualizo el software (p), actualizo Y mejora (p ∧ q)', valid:true,
    name:'Absorción', explanation:'✅ VÁLIDO — Absorción. Si p→q entonces p→(p∧q). Cuando actualizas (p), como eso implica q, tendrás tanto p como q.' },
  { context:'Un razonamiento incompleto:', arg:'Si llueve (p), me mojo (q)\nMe mojo (q)\n∴ Llueve (p)', valid:false,
    name:'Falacia: Afirmación del Consecuente', explanation:'❌ INVÁLIDO — Clásico error. Mojarme (q) puede ocurrir por otras razones: ducharme, caer al mar, etc. El condicional no es un bicondicional.' },
  { context:'Un argumento sobre resultados:', arg:'Estudié (p)\nDescansé bien (q)\n∴ Estudié y descansé bien (p ∧ q)', valid:true,
    name:'Conjunción', explanation:'✅ VÁLIDO — Conjunción. Tenemos ambas proposiciones verdaderas por separado y las unimos en una conjunción.' },
  { context:'Razonamiento sobre una elección:', arg:'Si gana el partido A (p), hay reforma (q)\nSi gana el partido B (r), hay estabilidad (s)\nO gana A o gana B (p ∨ r)\n∴ O hay reforma o hay estabilidad (q ∨ s)', valid:true,
    name:'Dilema Constructivo', explanation:'✅ VÁLIDO — Dilema Constructivo. Tenemos dos condicionales y la disyunción de sus antecedentes, lo que garantiza la disyunción de sus consecuentes.' },
  { context:'Deducción sobre un proyecto:', arg:'Si apruebo el proyecto (p), recibo fondos (q)\nNo apruebo el proyecto (¬p)\n∴ No recibo fondos (¬q)', valid:false,
    name:'Falacia: Negación del Antecedente', explanation:'❌ INVÁLIDO — Falacia de negación del antecedente. Podría recibir fondos de otra fuente aunque no apruebe este proyecto específico.' },
  { context:'Un argumento sencillo:', arg:'Hoy es martes (p)\n∴ Hoy es martes o mañana es festivo (p ∨ q)', valid:true,
    name:'Adición', explanation:'✅ VÁLIDO — Adición. De p verdadero podemos construir p ∨ q con cualquier q, ya que la disyunción solo requiere que una parte sea verdadera.' },
  { context:'Razonamiento sobre consecuencias negativas:', arg:'Si hay sequía (p), hay hambre (q)\nSi hay guerra (r), hay hambre (q)\n∴ Si hay sequía, hay guerra (p → r)', valid:false,
    name:'Falacia: Consecuentes iguales no implican relación', explanation:'❌ INVÁLIDO — Error lógico. Que dos condiciones distintas lleven al mismo resultado no significa que estén relacionadas entre sí. p→q y r→q no permiten concluir p→r.' },
  { context:'Un detective razona:', arg:'Si el acusado es culpable (p), su coartada es falsa (q)\nSu coartada es falsa (q)\n∴ El acusado es culpable (p)', valid:false,
    name:'Falacia: Afirmación del Consecuente', explanation:'❌ INVÁLIDO — ¡Cuidado! Que la coartada sea falsa no prueba culpabilidad. Podría haber mentido por otra razón. Este error ha llevado a condenas injustas.' },
  { context:'Argumento sobre condiciones:', arg:'Tengo dinero (p) y tiempo libre (q)\n∴ Tengo tiempo libre (q)', valid:true,
    name:'Simplificación', explanation:'✅ VÁLIDO — Simplificación. Extraemos q de la conjunción p ∧ q. Si ambas son ciertas, cada una por sí sola también.' },
  { context:'Razonamiento sobre opciones:', arg:'O me quedo estudiando (p) o salgo a pasear (q)\nSalgo a pasear (q)\n∴ No me quedé estudiando (¬p)', valid:false,
    name:'Falacia: Disyunción no exclusiva', explanation:'❌ INVÁLIDO — La disyunción lógica (∨) NO es exclusiva. Que q sea verdadero no significa que p sea falso. Podría tanto estudiar como pasear.' },
  { context:'Argumento empresarial:', arg:'Si reducimos costos (p), sobrevivimos (q)\nSi innovamos (r), crecemos (s)\nNo sobrevivimos (¬q) o no crecemos (¬s)\n∴ No reducimos costos (¬p) o no innovamos (¬r)', valid:true,
    name:'Dilema Destructivo', explanation:'✅ VÁLIDO — Dilema Destructivo. Al negar en disyunción los consecuentes (¬q ∨ ¬s), concluimos la negación en disyunción de los antecedentes (¬p ∨ ¬r).' },
  { context:'Un razonamiento filosófico:', arg:'Si existe libre albedrío (p), somos responsables de nuestros actos (q)\nSomos responsables de nuestros actos (q)\n∴ Existe el libre albedrío (p)', valid:false,
    name:'Falacia: Afirmación del Consecuente', explanation:'❌ INVÁLIDO — Podría haber otras bases para la responsabilidad moral que no dependan del libre albedrío. El consecuente verdadero no confirma el antecedente.' }
];

let viIndex = 0, viCorrect = 0, viWrong = 0, viStreak = 0, viAnswered = [], viDeck = [];

function buildVI() {
  viDeck = fisherYates([...Array(VI_DATA.length).keys()]);
  viIndex = 0; viCorrect = 0; viWrong = 0; viStreak = 0; viAnswered = [];
  renderVI();
  buildVIDots();
}

function renderVI() {
  const idx = viDeck[viIndex];
  const q = VI_DATA[idx];
  document.getElementById('vi-num').textContent = `Argumento ${viIndex + 1} de ${VI_DATA.length}`;
  document.getElementById('vi-context').textContent = q.context;
  document.getElementById('vi-argument').innerHTML = q.arg.split('\n').map(l => `<div>${l}</div>`).join('');
  document.getElementById('vi-feedback').style.display = 'none';
  document.getElementById('vi-next').style.display = 'none';
  document.getElementById('vi-btn-valid').disabled = false;
  document.getElementById('vi-btn-invalid').disabled = false;
  document.getElementById('vi-btn-valid').style.opacity = '1';
  document.getElementById('vi-btn-invalid').style.opacity = '1';
  updateVIScores();
}

function answerVI(userSaysValid) {
  const idx = viDeck[viIndex];
  const q = VI_DATA[idx];
  const correct = userSaysValid === q.valid;
  if(correct) { viCorrect++; viStreak++; } else { viWrong++; viStreak = 0; }
  viAnswered.push(correct);
  document.getElementById('vi-btn-valid').disabled = true;
  document.getElementById('vi-btn-invalid').disabled = true;
  document.getElementById('vi-btn-valid').style.opacity = userSaysValid ? '1' : '.4';
  document.getElementById('vi-btn-invalid').style.opacity = !userSaysValid ? '1' : '.4';
  const fb = document.getElementById('vi-feedback');
  fb.style.display = 'block';
  fb.style.background = correct ? 'var(--green-light)' : 'var(--red-light)';
  fb.style.border = `1px solid ${correct ? '#bbf7d0' : 'var(--red-mid)'}`;
  fb.style.color = correct ? '#15803d' : '#991b1b';
  const streakBonus = correct && viStreak >= 3 ? `<span style="background:#f97316;color:white;border-radius:20px;padding:.1rem .55rem;font-size:.75rem;font-weight:700;margin-left:.5rem;">🔥 Racha x${viStreak}</span>` : '';
  fb.innerHTML = `<strong>${correct ? '✅ ¡Correcto!' : '❌ Incorrecto'} — ${q.name}</strong>${streakBonus}<br><span style="font-size:.88rem;line-height:1.6;">${q.explanation}</span>`;
  updateVIScores();
  buildVIDots();
  const nextBtn = document.getElementById('vi-next');
  nextBtn.style.display = 'inline-flex';
  nextBtn.textContent = viIndex + 1 < VI_DATA.length ? 'Siguiente →' : 'Ver Resultados →';
}

function nextVI() {
  viIndex++;
  if(viIndex >= VI_DATA.length) { showVIResults(); return; }
  renderVI();
}

function showVIResults() {
  document.querySelector('#page-valido .quiz-container, #page-valido > div:first-child')?.remove();
  document.getElementById('vi-results').style.display = 'block';
  const pct = Math.round(viCorrect / VI_DATA.length * 100);
  document.getElementById('vi-res-score').textContent = `${viCorrect}/${VI_DATA.length}`;
  trackLogro('vi_correct', viCorrect);
  let emoji = '💪', label = 'Sigue practicando, las falacias son difíciles.';
  if(pct >= 90) { emoji = '🏆'; label = '¡Excelente! Distingues perfectamente los argumentos válidos de las falacias.'; }
  else if(pct >= 70) { emoji = '🎯'; label = '¡Muy bien! Tienes buen ojo para detectar falacias.'; }
  else if(pct >= 50) { emoji = '📖'; label = 'Vas bien. Repasa especialmente la afirmación del consecuente y la negación del antecedente.'; }
  document.getElementById('vi-res-emoji').textContent = emoji;
  document.getElementById('vi-res-label').textContent = label;
}

function restartVI() {
  document.getElementById('vi-results').style.display = 'none';
  buildVI();
  // Re-show the game area
  document.querySelectorAll('#page-valido > div').forEach(d => {
    if(d.id !== 'vi-results') d.style.display = '';
  });
}

function updateVIScores() {
  document.getElementById('vi-correct').textContent = viCorrect;
  document.getElementById('vi-wrong').textContent = viWrong;
  document.getElementById('vi-streak').textContent = viStreak;
}

function buildVIDots() {
  const c = document.getElementById('vi-dots');
  if(!c) return;
  c.innerHTML = '';
  VI_DATA.forEach((_, i) => {
    const d = document.createElement('div');
    d.style.cssText = `width:10px;height:10px;border-radius:50%;transition:background .2s;background:${i===viIndex ? '#f97316' : i<viAnswered.length ? (viAnswered[i]?'#16a34a':'#dc2626') : '#e2e8f0'};`;
    c.appendChild(d);
  });
}

// ====================== TABLAS DE VERDAD ======================
function loadTTExample(formula) {
  document.getElementById('tt-formula').value = formula;
  generateTT();
}

function tokenize(expr) {
  const tokens = [];
  let i = 0;
  while(i < expr.length) {
    const c = expr[i];
    if(c === ' ') { i++; continue; }
    if(c === '¬') { tokens.push({type:'NOT'}); i++; continue; }
    if(c === '∧') { tokens.push({type:'AND'}); i++; continue; }
    if(c === '∨') { tokens.push({type:'OR'}); i++; continue; }
    if(c === '→') { tokens.push({type:'IMP'}); i++; continue; }
    if(c === '↔') { tokens.push({type:'IFF'}); i++; continue; }
    if(c === '(') { tokens.push({type:'LPAREN'}); i++; continue; }
    if(c === ')') { tokens.push({type:'RPAREN'}); i++; continue; }
    if(/[a-z]/.test(c)) { tokens.push({type:'VAR', name:c}); i++; continue; }
    throw new Error(`Símbolo desconocido: "${c}"`);
  }
  return tokens;
}

function parseFormula(tokens) {
  let pos = 0;
  function peek() { return tokens[pos]; }
  function consume() { return tokens[pos++]; }
  function parseIff() {
    let left = parseImp();
    while(peek()?.type === 'IFF') { consume(); left = {op:'IFF', l:left, r:parseImp()}; }
    return left;
  }
  function parseImp() {
    let left = parseOr();
    while(peek()?.type === 'IMP') { consume(); left = {op:'IMP', l:left, r:parseOr()}; }
    return left;
  }
  function parseOr() {
    let left = parseAnd();
    while(peek()?.type === 'OR') { consume(); left = {op:'OR', l:left, r:parseAnd()}; }
    return left;
  }
  function parseAnd() {
    let left = parseNot();
    while(peek()?.type === 'AND') { consume(); left = {op:'AND', l:left, r:parseNot()}; }
    return left;
  }
  function parseNot() {
    if(peek()?.type === 'NOT') { consume(); return {op:'NOT', e:parseNot()}; }
    return parseAtom();
  }
  function parseAtom() {
    const t = peek();
    if(!t) throw new Error('Fórmula incompleta');
    if(t.type === 'VAR') { consume(); return {op:'VAR', name:t.name}; }
    if(t.type === 'LPAREN') {
      consume();
      const e = parseIff();
      if(peek()?.type !== 'RPAREN') throw new Error('Paréntesis sin cerrar');
      consume();
      return e;
    }
    throw new Error(`Token inesperado: ${t.type}`);
  }
  const tree = parseIff();
  if(pos < tokens.length) throw new Error('Caracteres sobrantes en la fórmula');
  return tree;
}

function evalTree(tree, vals) {
  if(tree.op === 'VAR') return vals[tree.name];
  if(tree.op === 'NOT') return !evalTree(tree.e, vals);
  if(tree.op === 'AND') return evalTree(tree.l, vals) && evalTree(tree.r, vals);
  if(tree.op === 'OR')  return evalTree(tree.l, vals) || evalTree(tree.r, vals);
  if(tree.op === 'IMP') return !evalTree(tree.l, vals) || evalTree(tree.r, vals);
  if(tree.op === 'IFF') return evalTree(tree.l, vals) === evalTree(tree.r, vals);
}

function getVars(tree) {
  const vars = new Set();
  function walk(n) {
    if(n.op === 'VAR') { vars.add(n.name); return; }
    if(n.op === 'NOT') { walk(n.e); return; }
    walk(n.l); walk(n.r);
  }
  walk(tree);
  return [...vars].sort();
}

// Serialize a tree back to a readable string
function treeToStr(tree) {
  if(tree.op === 'VAR') return tree.name;
  if(tree.op === 'NOT') {
    const inner = treeToStr(tree.e);
    // Only add parens around inner if it's a binary op
    const needParen = tree.e.op !== 'VAR' && tree.e.op !== 'NOT';
    return '¬' + (needParen ? '(' + inner + ')' : inner);
  }
  const opSyms = { AND:'∧', OR:'∨', IMP:'→', IFF:'↔' };
  return '(' + treeToStr(tree.l) + ' ' + opSyms[tree.op] + ' ' + treeToStr(tree.r) + ')';
}

// Collect all unique non-trivial subformulas in bottom-up order
// Returns array of {label, tree} — variables excluded (shown separately), root is last
function collectSubformulas(root, vars) {
  const seen = new Set();
  const result = [];
  const varSet = new Set(vars);

  function walk(node) {
    if(node.op === 'VAR') return; // variables are shown in their own columns
    // recurse children first (bottom-up)
    if(node.op === 'NOT') { walk(node.e); }
    else { walk(node.l); walk(node.r); }

    const label = treeToStr(node);
    // Strip outer parens from root-level binary ops for cleaner display
    const display = label.startsWith('(') && label.endsWith(')')
      ? label.slice(1, -1)
      : label;

    if(!seen.has(label)) {
      seen.add(label);
      result.push({ label: display, tree: node });
    }
  }
  walk(root);
  return result;
}

function generateTT() {
  const rawExpr = document.getElementById('tt-formula').value.trim();
  const errEl = document.getElementById('tt-error');
  const resEl = document.getElementById('tt-result');
  errEl.style.display = 'none';
  resEl.style.display = 'none';

  if(!rawExpr) {
    errEl.style.display = 'block';
    errEl.textContent = 'Escribe una fórmula para generar la tabla.';
    return;
  }

  try {
    const tokens = tokenize(rawExpr);
    const tree = parseFormula(tokens);
    const vars = getVars(tree);

    if(vars.length > 4) {
      errEl.style.display = 'block';
      errEl.textContent = 'Máximo 4 variables (p, q, r, s) para mantener la tabla manejable.';
      return;
    }
    if(vars.length === 0) {
      errEl.style.display = 'block';
      errEl.textContent = 'La fórmula debe contener al menos una variable.';
      return;
    }

    // Collect subformulas bottom-up
    const subformulas = collectSubformulas(tree, vars);
    // The last subformula IS the root (full formula)
    // If the root is just a variable (single var formula), handle gracefully
    const hasIntermediates = subformulas.length > 1;

    // Generate all rows
    const n = vars.length;
    const numRows = Math.pow(2, n);
    const allRows = [];
    for(let mask = 0; mask < numRows; mask++) {
      const vals = {};
      vars.forEach((v, i) => { vals[v] = Boolean((mask >> (n - 1 - i)) & 1); });
      const subResults = subformulas.map(sf => evalTree(sf.tree, vals));
      const finalResult = subResults[subResults.length - 1];
      allRows.push({ vals, subResults, finalResult });
    }

    // Verdict
    const allTrue  = allRows.every(r => r.finalResult);
    const allFalse = allRows.every(r => !r.finalResult);
    const verdictColor = allTrue ? 'var(--green)' : allFalse ? 'var(--red)' : 'var(--blue)';
    const verdictBg    = allTrue ? 'var(--green-light)' : allFalse ? 'var(--red-light)' : 'var(--blue-light)';
    const verdictBorder= allTrue ? '#bbf7d0' : allFalse ? 'var(--red-mid)' : '#bfdbfe';
    const verdictMsg   = allTrue
      ? '✅ TAUTOLOGÍA — La fórmula es verdadera para todas las combinaciones posibles.'
      : allFalse
      ? '❌ CONTRADICCIÓN — La fórmula es falsa para todas las combinaciones posibles.'
      : '🔄 CONTINGENCIA — La fórmula es verdadera en algunos casos y falsa en otros.';

    const vEl = document.getElementById('tt-verdict');
    vEl.style.background = verdictBg;
    vEl.style.border = `1px solid ${verdictBorder}`;
    vEl.style.color = verdictColor;
    vEl.textContent = verdictMsg;
    document.getElementById('tt-formula-display').textContent = `Tabla de verdad para:  ${rawExpr}`;

    // ---- Build table ----
    // Column groups:
    // 1. Variables (gray header)
    // 2. Intermediate subformulas (blue-ish header) — only if they exist and aren't just the root
    // 3. Final formula (navy header, highlighted)

    const intermediates = subformulas.slice(0, -1); // all except last
    const rootSF = subformulas[subformulas.length - 1];
    // Strip outer parens from root label for display
    const rootLabel = rawExpr; // always show exactly what user typed

    let html = '<table style="font-size:.88rem;min-width:100%;">';

    // ---- HEADER ROW 1: group labels ----
    html += '<thead>';
    if(hasIntermediates && intermediates.length > 0) {
      html += '<tr>';
      html += `<th colspan="${vars.length}" style="background:#1e293b;font-size:.72rem;letter-spacing:.08em;font-weight:600;padding:.4rem .8rem;text-align:center;color:#94a3b8;border-right:2px solid #334155;">VARIABLES</th>`;
      if(intermediates.length > 0) {
        html += `<th colspan="${intermediates.length}" style="background:#1e3a5f;font-size:.72rem;letter-spacing:.08em;font-weight:600;padding:.4rem .8rem;text-align:center;color:#93c5fd;border-right:2px solid #334155;">SUBFÓRMULAS INTERMEDIAS</th>`;
      }
      html += `<th colspan="1" style="background:#1e3a5f;font-size:.72rem;letter-spacing:.08em;font-weight:600;padding:.4rem .8rem;text-align:center;color:#fbbf24;">RESULTADO FINAL</th>`;
      html += '</tr>';
    }

    // ---- HEADER ROW 2: column labels ----
    html += '<tr>';
    vars.forEach(v => {
      html += `<th style="background:#1e293b;color:white;padding:.55rem .9rem;font-family:'DM Mono',monospace;font-size:.9rem;border-right:1px solid #334155;">${v}</th>`;
    });
    intermediates.forEach(sf => {
      html += `<th style="background:#1e3a5f;color:#bfdbfe;padding:.55rem .9rem;font-family:'DM Mono',monospace;font-size:.82rem;border-right:1px solid #1e40af;white-space:nowrap;">${sf.label}</th>`;
    });
    html += `<th style="background:#1d4ed8;color:white;padding:.55rem .9rem;font-family:'DM Mono',monospace;font-size:.85rem;font-weight:700;white-space:nowrap;">${rootLabel}</th>`;
    html += '</tr>';
    html += '</thead><tbody>';

    // ---- DATA ROWS ----
    allRows.forEach((row, ri) => {
      html += `<tr style="${ri % 2 === 1 ? 'background:#f8fafc;' : ''}">`;
      // Variable columns
      vars.forEach(v => {
        const val = row.vals[v];
        html += `<td class="${val ? 'true-val' : 'false-val'}" style="font-weight:600;border-right:1px solid #e2e8f0;">${val ? 'V' : 'F'}</td>`;
      });
      // Intermediate subformula columns
      row.subResults.slice(0, -1).forEach(val => {
        html += `<td class="${val ? 'true-val' : 'false-val'}" style="border-right:1px solid #dbeafe;background:${ri%2===1?'#f0f7ff':'#f8fbff'};">${val ? 'V' : 'F'}</td>`;
      });
      // Final result column
      const finalVal = row.finalResult;
      html += `<td class="${finalVal ? 'true-val' : 'false-val'}" style="font-weight:800;font-size:1rem;background:${finalVal ? '#f0fdf4' : '#fef2f2'};">${finalVal ? 'V' : 'F'}</td>`;
      html += '</tr>';
    });

    html += '</tbody></table>';

    // Legend below table
    if(hasIntermediates && intermediates.length > 0) {
      html += `<div style="padding:.9rem 1.25rem;background:#f8fafc;border-top:1px solid #e2e8f0;font-size:.8rem;color:#64748b;">`;
      html += `<strong style="color:#1e293b;">Leyenda de subfórmulas intermedias:</strong><br>`;
      html += `<div style="display:flex;flex-wrap:wrap;gap:.5rem .75rem;margin-top:.4rem;">`;
      intermediates.forEach((sf, i) => {
        html += `<span style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:4px;padding:.2rem .55rem;font-family:'DM Mono',monospace;font-size:.78rem;color:#1d4ed8;">${sf.label}</span>`;
      });
      html += `</div></div>`;
    }

    document.getElementById('tt-table-container').innerHTML = html;
    resEl.style.display = 'block';
    resEl.scrollIntoView({ behavior:'smooth', block:'nearest' });
    trackLogro('table_generated');

  } catch(e) {
    errEl.style.display = 'block';
    errEl.innerHTML = `<strong>Error al procesar la fórmula:</strong> ${e.message}.<br><small>Verifica los paréntesis y conectores. Usa letras minúsculas (p, q, r, s) y los símbolos del botón.</small>`;
  }
}

// ====================== SHARED GAME UTILS ======================
function setGameOpt(hiddenId, btn, val) {
  const group = btn.getAttribute('data-group');
  document.querySelectorAll(`[data-group="${group}"]`).forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const hidden = document.getElementById(hiddenId);
  if(hidden) hidden.value = val;
}
function setDueloOpt(hiddenId, btn, val) { setGameOpt(hiddenId, btn, val); }

function makeTimerRing(total, current, color='#f97316') {
  const r = 28, circ = 2 * Math.PI * r;
  const pct = current / total;
  const dash = circ * pct;
  const col = current <= 5 ? '#dc2626' : color;
  return `<div class="timer-ring" style="width:72px;height:72px;">
    <svg width="72" height="72" viewBox="0 0 72 72">
      <circle cx="36" cy="36" r="${r}" fill="none" stroke="#334155" stroke-width="5"/>
      <circle cx="36" cy="36" r="${r}" fill="none" stroke="${col}" stroke-width="5"
        stroke-dasharray="${dash} ${circ}" stroke-linecap="round" style="transition:stroke-dasharray .9s linear,stroke .3s;"/>
    </svg>
    <span class="timer-val" style="color:${col};">${current}</span>
  </div>`;
}

function makeAnswerGrid(opts, answer, onAnswerFn, disabled=false) {
  return `<div style="display:grid;grid-template-columns:1fr 1fr;gap:.6rem;">${opts.map(opt =>
    `<button onclick="${disabled?'':onAnswerFn+'(\''+opt.replace(/'/g,"\\'")+'\')'}" 
      style="background:white;border:1.5px solid var(--border);border-radius:10px;padding:.75rem 1rem;font-family:'DM Mono',monospace;font-size:.85rem;cursor:${disabled?'default':'pointer'};text-align:left;transition:all .15s;"
      onmouseover="if(!this.disabled){this.style.borderColor='var(--accent)';this.style.background='var(--accent-light)';}"
      onmouseout="if(!this.disabled){this.style.borderColor='var(--border)';this.style.background='white';}"
      ${disabled?'disabled':''}>
      ${opt}
    </button>`).join('')}</div>`;
}

function makeQuestionBox(q, extraInfo='') {
  return `
    <div style="font-size:.78rem;color:var(--slate);text-transform:uppercase;letter-spacing:.08em;font-weight:600;margin-bottom:.5rem;">${extraInfo}</div>
    <div style="font-size:.98rem;font-weight:500;color:var(--navy);margin-bottom:1rem;line-height:1.55;">${q.q}</div>
    <div style="background:var(--slate-light);border:1px solid var(--border);border-radius:10px;padding:.9rem 1.1rem;font-family:'DM Mono',monospace;font-size:.9rem;margin-bottom:1.25rem;">
      ${q.premises.split('\n').map(p=>`<div>${p}</div>`).join('')}
      <div style="border-top:1px solid var(--border);margin-top:.5rem;padding-top:.5rem;color:var(--red);font-weight:700;">${q.conclusion}</div>
    </div>`;
}

// ====================== MODO SUPERVIVENCIA ======================
const SURV_RULES = [
  { id:'Modus Ponens',         short:'MP',  color:'#3b82f6', bg:'#eff6ff' },
  { id:'Modus Tollens',        short:'MT',  color:'#dc2626', bg:'#fef2f2' },
  { id:'Silogismo Hipotético', short:'SH',  color:'#7c3aed', bg:'#f5f3ff' },
  { id:'Silogismo Disyuntivo', short:'SD',  color:'#f97316', bg:'#fff7ed' },
  { id:'Adición',              short:'Ad',  color:'#16a34a', bg:'#f0fdf4' },
  { id:'Simplificación',       short:'Sim', color:'#0891b2', bg:'#ecfeff' },
  { id:'Conjunción',           short:'Con', color:'#0d9488', bg:'#f0fdfa' },
  { id:'Absorción',            short:'Abs', color:'#b45309', bg:'#fffbeb' },
  { id:'Dilema Constructivo',  short:'DC',  color:'#9333ea', bg:'#faf5ff' },
  { id:'Dilema Destructivo',   short:'DD',  color:'#be123c', bg:'#fff1f2' },
];

// Maps quiz answer → rule id (for filtering)
const SURV_RULE_MAP = {
  'Modus Ponens':         'Modus Ponens',
  'Modus Tollens':        'Modus Tollens',
  'Silogismo Hipotético': 'Silogismo Hipotético',
  'Silogismo Disyuntivo': 'Silogismo Disyuntivo',
  'Adición':              'Adición',
  'Simplificación':       'Simplificación',
  'Conjunción':           'Conjunción',
  'Absorción':            'Absorción',
  'Dilema Constructivo':  'Dilema Constructivo',
  'Dilema Destructivo':   'Dilema Destructivo',
};

let survSelectedRules = new Set(SURV_RULES.map(r => r.id)); // all selected by default
let survState = {};
let survRecord = 0;

function buildSurvivalRuleList() {
  const list = document.getElementById('surv-rule-list');
  if(!list) return;
  list.innerHTML = '';
  SURV_RULES.forEach(rule => {
    const qCount = QUIZ_QUESTIONS.filter(q => SURV_RULE_MAP[q.answer] === rule.id).length;
    const row = document.createElement('label');
    row.style.cssText = `display:flex;align-items:center;gap:.75rem;padding:.55rem .8rem;border-radius:8px;cursor:pointer;border:1.5px solid ${survSelectedRules.has(rule.id) ? rule.color : 'var(--border)'};background:${survSelectedRules.has(rule.id) ? rule.bg : 'white'};transition:all .15s;`;
    row.innerHTML = `
      <input type="checkbox" id="surv-rule-${rule.id.replace(/\s/g,'-')}"
        ${survSelectedRules.has(rule.id) ? 'checked' : ''}
        onchange="survToggleRule('${rule.id}',this)"
        style="width:16px;height:16px;accent-color:${rule.color};cursor:pointer;flex:0 0 16px;">
      <span style="background:${rule.color};color:white;border-radius:4px;padding:.1rem .45rem;font-size:.7rem;font-weight:700;font-family:'DM Mono',monospace;flex:0 0 auto;">${rule.short}</span>
      <span style="font-size:.85rem;font-weight:${survSelectedRules.has(rule.id)?'600':'400'};color:${survSelectedRules.has(rule.id)?'var(--navy)':'var(--slate)'};">${rule.id}</span>
      <span style="margin-left:auto;font-size:.75rem;color:var(--slate);">${qCount} preg.</span>
    `;
    list.appendChild(row);
  });
  updateSurvCount();
}

function survToggleRule(ruleId, checkbox) {
  if(checkbox.checked) survSelectedRules.add(ruleId);
  else survSelectedRules.delete(ruleId);
  buildSurvivalRuleList(); // re-render to update colors
  updateSurvCount();
}

function survSelectAll() {
  survSelectedRules = new Set(SURV_RULES.map(r => r.id));
  buildSurvivalRuleList();
}

function survSelectNone() {
  survSelectedRules.clear();
  buildSurvivalRuleList();
}

function updateSurvCount() {
  const selected = [...survSelectedRules];
  const total = QUIZ_QUESTIONS.filter(q => selected.includes(SURV_RULE_MAP[q.answer])).length;
  const el = document.getElementById('surv-count-num');
  if(el) el.textContent = total;
  const btn = document.getElementById('surv-start-btn');
  if(btn) {
    btn.disabled = total === 0;
    btn.style.opacity = total === 0 ? '.5' : '1';
    btn.style.cursor = total === 0 ? 'not-allowed' : 'pointer';
  }
}

function startSurvival() {
  const lives = parseInt(document.getElementById('surv-lives').value);
  const timeLimit = parseInt(document.getElementById('surv-time').value);
  const order = document.getElementById('surv-order').value;

  // Filter questions by selected rules
  const selected = [...survSelectedRules];
  if(selected.length === 0) { alert('Selecciona al menos una regla para practicar.'); return; }

  let pool = QUIZ_QUESTIONS.filter(q => selected.includes(SURV_RULE_MAP[q.answer]));
  if(pool.length === 0) { alert('No hay preguntas disponibles para las reglas seleccionadas.'); return; }

  // Sort: random or by rule (sequential)
  if(order === 'random') {
    pool = fisherYates(pool);
  } else {
    // Group by rule in SURV_RULES order, then cycle
    const grouped = [];
    SURV_RULES.forEach(r => {
      if(selected.includes(r.id)) {
        grouped.push(...pool.filter(q => SURV_RULE_MAP[q.answer] === r.id));
      }
    });
    pool = grouped;
  }

  // Extend pool so it never runs out (repeat shuffled copies)
  const bigPool = [];
  while(bigPool.length < 200) bigPool.push(...(order === 'random' ? fisherYates(pool) : pool));

  survState = {
    lives: lives >= 99 ? Infinity : lives,
    maxLives: lives >= 99 ? 99 : lives,
    infinite: lives >= 99,
    timeLimit,
    pool: bigPool,
    selectedRules: selected,
    idx: 0, streak: 0, maxStreak: 0,
    timer: null, done: false,
    rulesStats: Object.fromEntries(selected.map(r => [r, { correct:0, wrong:0 }]))
  };

  document.getElementById('surv-setup').style.display = 'none';
  document.getElementById('surv-game').style.display = 'block';
  renderSurvival();
}

function renderSurvival() {
  window._survLocked = false;
  const s = survState;
  if(s.done) { endSurvival(); return; }
  const q = s.pool[s.idx % s.pool.length];
  clearInterval(s.timer);
  let timeLeft = s.timeLimit || 999;

  // Build lives display
  const livesHtml = s.infinite
    ? `<span style="font-size:1.1rem;">♾️ Infinitas</span>`
    : Array.from({length: s.maxLives}, (_, i) =>
        `<span style="font-size:1.1rem;">${i < s.lives ? '❤️' : '🖤'}</span>`).join('');

  // Streak display
  const streakHtml = s.streak >= 2
    ? `<div style="background:linear-gradient(135deg,#f97316,#dc2626);color:white;border-radius:8px;padding:.3rem .8rem;font-size:.82rem;font-weight:700;display:flex;align-items:center;gap:.35rem;">🔥 Racha x${s.streak} ${s.streak>=5?'⚡':''}</div>`
    : `<div style="color:#64748b;font-size:.8rem;">Racha: ${s.streak}</div>`;

  // Active rules pills
  const rulesPillsHtml = s.selectedRules.map(rid => {
    const rule = SURV_RULES.find(r => r.id === rid);
    const stats = s.rulesStats[rid];
    const total = stats.correct + stats.wrong;
    const pct = total > 0 ? Math.round(stats.correct / total * 100) : null;
    return `<span style="display:inline-flex;align-items:center;gap:.3rem;background:${rule.bg};border:1px solid ${rule.color}33;border-radius:6px;padding:.2rem .55rem;font-size:.72rem;">
      <span style="background:${rule.color};color:white;border-radius:3px;padding:.05rem .35rem;font-weight:700;font-family:'DM Mono',monospace;">${rule.short}</span>
      ${pct !== null ? `<span style="color:${rule.color};font-weight:600;">${pct}%</span>` : ''}
    </span>`;
  }).join('');

  // Current question's rule label
  const qRule = SURV_RULE_MAP[q.answer];
  const qRuleObj = SURV_RULES.find(r => r.id === qRule);

  document.getElementById('surv-game').innerHTML = `
    <div style="background:white;border:1px solid var(--border);border-radius:14px;box-shadow:var(--shadow-lg);overflow:hidden;margin-bottom:1rem;">
      <div style="background:var(--navy);color:white;padding:1rem 1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:.75rem;margin-bottom:.75rem;">
          <div>
            <div style="display:flex;align-items:center;justify-content:space-between;width:100%;">
              <div style="font-family:'DM Serif Display',serif;font-size:1.05rem;">❤️ Modo Supervivencia</div>
              <button id="surv-exit-btn" style="background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.25);color:#cbd5e1;border-radius:8px;padding:.3rem .8rem;font-size:.75rem;cursor:pointer;font-family:inherit;">⬅ Salir</button>
            </div>
            <div style="margin-top:.35rem;">${livesHtml}</div>
          </div>
          <div style="display:flex;gap:1.5rem;align-items:center;">
            <div style="text-align:center;"><div style="font-family:'DM Serif Display',serif;font-size:1.8rem;color:var(--accent);">${s.idx}</div><div style="font-size:.7rem;color:#94a3b8;">Correctas</div></div>
            <div style="text-align:center;">${streakHtml}</div>
            ${s.timeLimit > 0 ? `<div id="surv-timer-ring">${makeTimerRing(s.timeLimit, timeLeft)}</div>` : ''}
          </div>
        </div>
        <div style="display:flex;gap:.35rem;flex-wrap:wrap;">${rulesPillsHtml}</div>
      </div>

      <div style="padding:1.5rem;">
        <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem;">
          <span style="font-size:.72rem;font-weight:600;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;">Pregunta ${s.idx + 1}</span>
          ${qRuleObj ? `<span style="background:${qRuleObj.bg};border:1px solid ${qRuleObj.color}33;color:${qRuleObj.color};border-radius:4px;padding:.15rem .55rem;font-size:.72rem;font-weight:700;font-family:'DM Mono',monospace;">${qRuleObj.short}</span>` : ''}
        </div>
        ${makeQuestionBox(q)}
        <div id="surv-opts">${makeAnswerGrid(q.opts, q.answer, 'answerSurvival')}</div>
        <div id="surv-feedback" style="display:none;margin-top:1rem;border-radius:10px;padding:.9rem 1.1rem;font-size:.88rem;"></div>
      </div>
    </div>`;

  // Attach interactive buttons
  (function(){
    var exitBtn = document.getElementById('surv-exit-btn');
    if(exitBtn) exitBtn.addEventListener('click', function(){
      if(confirm('¿Salir y volver a la configuración?')) {
        clearInterval(survState.timer);
        document.getElementById('surv-game').style.display='none';
        document.getElementById('surv-setup').style.display='block';
      }
    });
    // surv-next-btn se registra en answerSurvival/survTimerUp directamente
  })();

  if(s.timeLimit > 0) {
    s.timer = safeSetInterval(() => {
      timeLeft--;
      const ring = document.getElementById('surv-timer-ring');
      if(ring) ring.innerHTML = makeTimerRing(s.timeLimit, timeLeft);
      if(timeLeft <= 0) { clearInterval(s.timer); survTimerUp(); }
    }, 1000);
  }
}

function answerSurvival(ans) {
  if(window._survLocked) return;
  window._survLocked = true;
  clearInterval(survState.timer);
  const q = survState.pool[survState.idx % survState.pool.length];
  const correct = ans === q.answer;
  const qRule = SURV_RULE_MAP[q.answer];

  // Update stats
  if(survState.rulesStats[qRule]) {
    if(correct) survState.rulesStats[qRule].correct++;
    else survState.rulesStats[qRule].wrong++;
  }

  // Style buttons
  const opts = document.getElementById('surv-opts');
  if(opts) {
    opts.querySelectorAll('button').forEach(b => {
      b.disabled = true;
      if(b.textContent.trim() === q.answer) { b.style.borderColor='var(--green)'; b.style.background='var(--green-light)'; b.style.fontWeight='700'; }
      else if(b.textContent.trim() === ans && !correct) { b.style.borderColor='var(--red)'; b.style.background='var(--red-light)'; }
    });
  }

  const fb = document.getElementById('surv-feedback');
  if(fb) {
    fb.style.display = 'block';
    fb.style.background = correct ? 'var(--green-light)' : 'var(--red-light)';
    fb.style.border = `1px solid ${correct ? '#bbf7d0' : 'var(--red-mid)'}`;
    fb.style.color = correct ? 'var(--green)' : '#991b1b';
    const streakMsg = correct && survState.streak >= 4 ? ` 🔥 ¡Racha de ${survState.streak + 1}!` : '';
    fb.innerHTML = correct
      ? `<strong>✅ ¡Correcto!${streakMsg}</strong> — ${q.explain}<div style="margin-top:.3rem;font-size:.8rem;color:var(--green);font-weight:600;">Regla: ${q.answer}</div><div style="margin-top:.6rem;"><button id="surv-next-btn" class="btn btn-primary" style="font-size:.8rem;padding:.35rem 1rem;background:var(--green);">Siguiente →</button></div>`
      : `<strong>❌ Incorrecto. ${survState.infinite ? '' : 'Vida perdida.'}</strong> Respuesta correcta: <strong>${q.answer}</strong><div style="font-size:.83rem;margin-top:.3rem;color:#991b1b;">${q.explain}</div><div style="margin-top:.6rem;"><button id="surv-next-btn" class="btn btn-primary" style="font-size:.8rem;padding:.35rem 1rem;">Continuar →</button></div>`;
  }

  if(correct) {
    survState.idx++;
    survState.streak++;
    survState.maxStreak = Math.max(survState.maxStreak, survState.streak);
  } else {
    survState.streak = 0;
    if(!survState.infinite) {
      survState.lives--;
      if(survState.lives <= 0) survState.done = true;
    }
  }
  // Avance controlado por el estudiante — no hay auto-avance
  setTimeout(function(){
    var nb = document.getElementById('surv-next-btn');
    if(nb) nb.addEventListener('click', function(){ renderSurvival(); });
  }, 50);
}

function survTimerUp() {
  const q = survState.pool[survState.idx % survState.pool.length];
  survState.streak = 0;
  if(!survState.infinite) {
    survState.lives--;
    if(survState.lives <= 0) survState.done = true;
  }
  // Avanzar índice igual que cuando se responde incorrectamente
  survState.idx++;

  // Deshabilitar botones de respuesta para que no se puedan pulsar
  const opts = document.getElementById('surv-opts');
  if(opts) {
    opts.querySelectorAll('button').forEach(b => {
      b.disabled = true;
      if(b.textContent.trim() === q.answer) {
        b.style.borderColor = 'var(--green)';
        b.style.background = 'var(--green-light)';
        b.style.fontWeight = '700';
      }
    });
  }

  // Mostrar feedback con botón Siguiente
  const fb = document.getElementById('surv-feedback');
  if(fb) {
    fb.style.display = 'block';
    fb.style.background = 'var(--accent-light)';
    fb.style.border = '1px solid #fed7aa';
    fb.style.color = '#92400e';
    fb.innerHTML = `<strong>⏱️ ¡Tiempo agotado! ${survState.infinite ? '' : 'Vida perdida.'}</strong> Respuesta correcta: <strong>${q.answer}</strong><div style="font-size:.83rem;margin-top:.3rem;">${q.explain}</div><div style="margin-top:.6rem;"><button id="surv-next-btn" class="btn btn-primary" style="font-size:.8rem;padding:.35rem 1rem;">Continuar →</button></div>`;
    const nb = document.getElementById('surv-next-btn');
    if(nb) nb.addEventListener('click', function(){ renderSurvival(); });
  }
}

function endSurvival() {
  if(survState.idx > survRecord) {
    survRecord = survState.idx;
    const r = document.getElementById('surv-record');
    if(r) r.textContent = survRecord + ' preguntas';
  }

  // Per-rule stats table
  const statsHtml = Object.entries(survState.rulesStats).map(([rid, stats]) => {
    const rule = SURV_RULES.find(r => r.id === rid);
    const total = stats.correct + stats.wrong;
    const pct = total > 0 ? Math.round(stats.correct / total * 100) : 0;
    const barColor = pct >= 70 ? 'var(--green)' : pct >= 40 ? 'var(--accent)' : 'var(--red)';
    return `
      <div style="display:flex;align-items:center;gap:.75rem;padding:.4rem 0;border-bottom:1px solid var(--border);">
        <span style="background:${rule.color};color:white;border-radius:4px;padding:.1rem .45rem;font-size:.7rem;font-weight:700;font-family:'DM Mono',monospace;flex:0 0 auto;">${rule.short}</span>
        <span style="font-size:.82rem;color:var(--text2);flex:1;">${rid}</span>
        <div style="width:80px;height:6px;background:var(--border);border-radius:3px;overflow:hidden;flex:0 0 80px;">
          <div style="height:100%;background:${barColor};width:${pct}%;border-radius:3px;"></div>
        </div>
        <span style="font-size:.78rem;font-weight:600;color:${barColor};min-width:36px;text-align:right;">${pct}%</span>
        <span style="font-size:.72rem;color:var(--slate);min-width:60px;text-align:right;">${stats.correct}/${total}</span>
      </div>`;
  }).join('');

  const emoji = survState.idx >= 20 ? '🏆' : survState.idx >= 10 ? '🎉' : '💪';

  document.getElementById('surv-game').innerHTML = `
    <div style="background:white;border:1px solid var(--border);border-radius:14px;box-shadow:var(--shadow-lg);overflow:hidden;">
      <div style="background:var(--navy);color:white;padding:1.5rem;text-align:center;">
        <div style="font-size:3rem;margin-bottom:.5rem;">${emoji}</div>
        <div style="font-family:'DM Serif Display',serif;font-size:2.2rem;">${survState.idx} correctas</div>
        <div style="color:#94a3b8;margin-top:.3rem;">Mejor racha: ${survState.maxStreak} · Reglas practicadas: ${survState.selectedRules.length}</div>
      </div>
      <div style="padding:1.5rem;">
        <div style="font-weight:700;font-size:.9rem;margin-bottom:.75rem;color:var(--navy);">📊 Tu rendimiento por regla</div>
        ${statsHtml}
        <div style="margin-top:1.5rem;display:flex;gap:.75rem;flex-wrap:wrap;justify-content:center;">
          <button class="btn btn-primary" onclick="document.getElementById('surv-setup').style.display='block';document.getElementById('surv-game').style.display='none';">🔄 Configurar y jugar de nuevo</button>
          <button class="btn btn-outline" onclick="showPage('flashcards')">🃏 Repasar Flashcards</button>
        </div>
      </div>
    </div>`;
  trackLogro('surv_played', survState.idx);
}

// ====================== CONTRARRELOJ ======================
let crlState = {}, crlRecord = 0;

function startContrarreloj() {
  const duration = parseInt(document.getElementById('crl-duration').value);
  const scoring = document.getElementById('crl-scoring').value;
  const deck = fisherYates([...QUIZ_QUESTIONS, ...QUIZ_QUESTIONS]);
  crlState = { duration, timeLeft: duration, scoring, deck, idx: 0, score: 0, correct: 0, wrong: 0, timer: null };
  document.getElementById('crl-setup').style.display = 'none';
  document.getElementById('crl-game').style.display = 'block';
  renderCRL();

  crlState.timer = safeSetInterval(() => {
    crlState.timeLeft--;
    const el = document.getElementById('crl-global-timer');
    if(el) {
      el.textContent = crlState.timeLeft + 's';
      el.style.color = crlState.timeLeft <= 10 ? '#dc2626' : 'var(--accent)';
    }
    const bar = document.getElementById('crl-time-bar');
    if(bar) bar.style.width = (crlState.timeLeft / crlState.duration * 100) + '%';
    if(crlState.timeLeft <= 0) { clearInterval(crlState.timer); endCRL(); }
  }, 1000);
}

function renderCRL() {
  window._crlLocked = false;
  const s = crlState;
  const q = s.deck[s.idx % s.deck.length];
  document.getElementById('crl-game').innerHTML = `
    <div style="background:white;border:1px solid var(--border);border-radius:14px;box-shadow:var(--shadow-lg);overflow:hidden;">
      <div style="background:var(--navy);color:white;padding:.75rem 1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.5rem;flex-wrap:wrap;gap:.5rem;">
          <div style="display:flex;align-items:center;gap:.75rem;">
            <div style="font-family:'DM Serif Display',serif;font-size:1.05rem;">⏱️ Contrarreloj</div>
            <button id="crl-exit-btn" style="background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.25);color:#cbd5e1;border-radius:8px;padding:.25rem .7rem;font-size:.72rem;cursor:pointer;font-family:inherit;">⬅ Salir</button>
          </div>
          <div style="display:flex;gap:1.5rem;align-items:center;">
            <div style="text-align:center;"><div style="font-family:'DM Serif Display',serif;font-size:1.6rem;color:var(--accent);" id="crl-score-disp">${s.score}</div><div style="font-size:.7rem;color:#94a3b8;">Puntos</div></div>
            <div style="text-align:center;"><div style="font-family:'DM Serif Display',serif;font-size:1.6rem;color:var(--green);">${s.correct}</div><div style="font-size:.7rem;color:#94a3b8;">✅</div></div>
            <div style="text-align:center;"><div style="font-family:'DM Serif Display',serif;font-size:1.6rem;color:var(--red);">${s.wrong}</div><div style="font-size:.7rem;color:#94a3b8;">❌</div></div>
            <div style="background:rgba(255,255,255,.1);border-radius:8px;padding:.3rem .8rem;font-family:'DM Serif Display',serif;font-size:1.6rem;" id="crl-global-timer">${s.timeLeft}s</div>
          </div>
        </div>
        <div style="height:5px;background:rgba(255,255,255,.15);border-radius:3px;">
          <div id="crl-time-bar" style="height:100%;background:var(--accent);border-radius:3px;transition:width 1s linear;width:${s.timeLeft/s.duration*100}%;"></div>
        </div>
      </div>
      <div style="padding:1.5rem;">
        ${makeQuestionBox(q, `Pregunta ${s.idx + 1}`)}
        <div>${makeAnswerGrid(q.opts, q.answer, 'answerCRL')}</div>
        <div id="crl-feedback" style="display:none;margin-top:.75rem;border-radius:8px;padding:.6rem .9rem;font-size:.85rem;"></div>
      </div>
    </div>`;
  // Attach exit button
  (function(){
    var eb = document.getElementById('crl-exit-btn');
    if(eb) eb.addEventListener('click', function(){
      if(confirm('¿Salir y volver a la configuración? Se perderá la partida.')) {
        clearInterval(crlState.timer);
        document.getElementById('crl-game').style.display='none';
        document.getElementById('crl-setup').style.display='block';
      }
    });
  })();
}

function answerCRL(ans) {
  if(window._crlLocked) return;
  window._crlLocked = true;

  const s = crlState;
  const q = s.deck[s.idx % s.deck.length];
  const correct = ans === q.answer;
  const points = correct ? (s.scoring === 'speed' ? Math.max(1, s.timeLeft) : 10) : 0;
  if(correct) { s.correct++; s.score += points; } else { s.wrong++; }
  s.idx++;

  // Disable all answer buttons immediately
  document.querySelectorAll('#crl-game button[onclick^="answerCRL"]').forEach(b => {
    b.disabled = true;
    b.style.cursor = 'default';
    b.onclick = null;
    b.removeAttribute('onclick');
    if(b.textContent.trim() === q.answer) { b.style.borderColor='var(--green)'; b.style.background='var(--green-light)'; b.style.fontWeight='700'; }
    else if(b.textContent.trim() === ans && !correct) { b.style.borderColor='var(--red)'; b.style.background='var(--red-light)'; }
  });

  // Flash feedback briefly then move on
  const fb = document.getElementById('crl-feedback');
  if(fb) {
    fb.style.display = 'block';
    fb.style.background = correct ? 'var(--green-light)' : 'var(--red-light)';
    fb.style.color = correct ? 'var(--green)' : 'var(--red)';
    fb.innerHTML = correct
      ? `<strong>✅ +${points} pts — ${q.answer}</strong><div style="font-size:.8rem;margin-top:.2rem;">${q.explain}</div><div style="margin-top:.5rem;"><button id="crl-next-btn" class="btn btn-primary" style="font-size:.8rem;padding:.35rem .9rem;background:var(--green);">Siguiente →</button></div>`
      : `<strong>❌ Respuesta correcta: ${q.answer}</strong><div style="font-size:.8rem;margin-top:.2rem;">${q.explain}</div><div style="margin-top:.5rem;"><button id="crl-next-btn" class="btn btn-primary" style="font-size:.8rem;padding:.35rem .9rem;">Continuar →</button></div>`;
  }
  // Avance controlado por el estudiante — no hay auto-avance
  setTimeout(function(){
    var nb = document.getElementById('crl-next-btn');
    if(nb) nb.addEventListener('click', function(){
      window._crlLocked = false;
      if(crlState.timeLeft > 0) renderCRL();
    });
  }, 50);
}

function endCRL() {
  const s = crlState;
  if(s.score > crlRecord) { crlRecord = s.score; const r = document.getElementById('crl-record'); if(r) r.textContent = crlRecord + ' puntos'; }
  const acc = s.correct + s.wrong > 0 ? Math.round(s.correct / (s.correct + s.wrong) * 100) : 0;
  document.getElementById('crl-game').innerHTML = `
    <div class="results-card">
      <div style="font-size:3rem;margin-bottom:1rem;">${s.score >= 100 ? '🏆' : s.score >= 50 ? '🎉' : '📚'}</div>
      <div style="font-family:'DM Serif Display',serif;font-size:2.5rem;color:var(--accent);">${s.score} pts</div>
      <div style="color:var(--slate);margin:.5rem 0 1.5rem;">${s.correct} correctas · ${s.wrong} incorrectas · ${acc}% precisión</div>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <button class="btn btn-primary" onclick="document.getElementById('crl-setup').style.display='block';document.getElementById('crl-game').style.display='none';">🔄 Jugar de nuevo</button>
        <button class="btn btn-outline" onclick="showPage('duelo')">⚔️ Retar a alguien</button>
      </div>
    </div>`;
  trackLogro('crl_played');
}

// ====================== DETECTIVE LÓGICO ======================
const MYSTERY_CASES = [
  { diff:'easy', title:'El Semáforo Apagado', icon:'🚦',
    story:'El técnico municipal recibe un reporte: "Si hay corte de luz en la zona, los semáforos se apagan. Esta mañana los semáforos de la Av. Principal están apagados."',
    premises:['Si hay corte de luz, los semáforos se apagan','Los semáforos están apagados'],
    formal:['p → q', 'q'],
    question:'¿Qué puede concluir el técnico con certeza lógica?',
    opts:['Definitivamente hay corte de luz','No puede concluir que hay corte de luz','Los semáforos no funcionan por otro motivo','El corte de luz es en otra zona'],
    answer:'No puede concluir que hay corte de luz',
    rule:'Falacia: Afirmación del Consecuente',
    explain:'El técnico comete la falacia de afirmar el consecuente. Que los semáforos estén apagados (q) no implica que hay corte de luz (p). Puede haber otras causas: falla técnica, mantenimiento, etc.' },
  { diff:'easy', title:'La Nota Desaparecida', icon:'📝',
    story:'"Si el estudiante no entregó la tarea, su nota será 0. La nota del estudiante es 0."',
    premises:['Si no entregó la tarea, la nota es 0','La nota es 0'],
    formal:['p → q', 'q'],
    question:'¿Podemos concluir que el estudiante no entregó la tarea?',
    opts:['Sí, definitivamente no la entregó','No, la nota 0 puede tener otra causa','Sí, porque la nota 0 confirma la ausencia','Solo si el profesor lo confirma'],
    answer:'No, la nota 0 puede tener otra causa',
    rule:'Falacia: Afirmación del Consecuente',
    explain:'La nota 0 podría deberse a trampa, ausencia al examen, u otras razones. No podemos concluir la causa exacta solo del resultado.' },
  { diff:'medium', title:'El Crimen del Museo', icon:'🏛️',
    story:'El detective Holmes analiza: "Si el ladrón conocía el sistema de seguridad, dejó la alarma desactivada. Hoy la alarma está desactivada. Además, si dejó la alarma desactivada, tiene acceso interno."',
    premises:['Si conoce la seguridad → dejó alarma desactivada','La alarma está desactivada','Si dejó alarma desactivada → tiene acceso interno'],
    formal:['p → q', 'q', 'q → r'],
    question:'¿Qué puede concluir Holmes con certeza?',
    opts:['El ladrón conoce el sistema de seguridad','El ladrón tiene acceso interno','El ladrón es un empleado del museo','No se puede concluir nada'],
    answer:'El ladrón tiene acceso interno',
    rule:'Modus Ponens + Falacia',
    explain:'Aunque no podemos confirmar que conoce el sistema (falacia del consecuente), SÍ podemos confirmar por MP que tiene acceso interno: la alarma está desactivada (q) y q→r, entonces r.' },
  { diff:'medium', title:'El Servidor Caído', icon:'💻',
    story:'El administrador de sistemas sabe: "Si el servidor está sobrecargado o hay un ataque DDoS, la web se cae. La web no se ha caído."',
    premises:['Si hay sobrecarga o ataque → web caída','La web NO está caída'],
    formal:['(p ∨ q) → r', '¬r'],
    question:'¿Qué puede concluir el administrador?',
    opts:['El servidor no está sobrecargado','No hay ataque DDoS','No hay sobrecarga Y no hay ataque','Solo hay sobrecarga sin ataque'],
    answer:'No hay sobrecarga Y no hay ataque',
    rule:'Modus Tollens aplicado',
    explain:'Si (p∨q)→r y ¬r, por MT concluimos ¬(p∨q). Por De Morgan, ¬(p∨q) ≡ ¬p ∧ ¬q. Es decir: ni hay sobrecarga ni ataque.' },
  { diff:'hard', title:'El Testigo Mentiroso', icon:'🎭',
    story:'El fiscal razona: "Si el acusado es culpable, el testigo miente o las pruebas son falsas. El testigo no miente. Las pruebas son válidas."',
    premises:['Si culpable → (testigo miente ∨ pruebas falsas)','El testigo NO miente','Las pruebas SON válidas (no son falsas)'],
    formal:['p → (q ∨ r)', '¬q', '¬r'],
    question:'¿Qué concluye el fiscal?',
    opts:['El acusado es culpable','El acusado no es culpable','No hay suficiente evidencia','El testigo podría mentir en el futuro'],
    answer:'El acusado no es culpable',
    rule:'Modus Tollens + Silogismo Disyuntivo',
    explain:'De ¬q y ¬r tenemos ¬(q∨r) (De Morgan). Tenemos p→(q∨r) y ¬(q∨r), aplicando MT obtenemos ¬p: el acusado no es culpable.' },
  { diff:'hard', title:'La Cadena de Responsabilidad', icon:'⚖️',
    story:'"Si el gerente aprueba → el departamento ejecuta. Si el departamento ejecuta → el proyecto avanza. Si el proyecto avanza → hay resultados. El gerente aprobó."',
    premises:['Gerente aprueba → departamento ejecuta','Departamento ejecuta → proyecto avanza','Proyecto avanza → hay resultados','El gerente aprobó'],
    formal:['p → q', 'q → r', 'r → s', 'p'],
    question:'¿Qué podemos concluir con certeza?',
    opts:['Solo que el departamento ejecuta','Que hay resultados','Que el proyecto avanza pero nada más','Que el gerente volverá a aprobar'],
    answer:'Que hay resultados',
    rule:'Silogismo Hipotético + Modus Ponens',
    explain:'Encadenando: p→q, q→r, r→s → obtenemos p→s (SH aplicado dos veces). Tenemos p (gerente aprobó), por MP concluimos s: hay resultados.' }
];

let mysteryState = {};

function startMystery() {
  const diff = document.getElementById('mystery-diff').value;
  const timeLimit = parseInt(document.getElementById('mystery-time').value);
  const cases = fisherYates(MYSTERY_CASES.filter(c => diff === 'easy' ? c.diff==='easy' : diff === 'medium' ? ['easy','medium'].includes(c.diff) : true))
    ;
  mysteryState = { cases, idx:0, score:0, correct:0, timeLimit, timer:null };
  document.getElementById('mystery-setup').style.display = 'none';
  document.getElementById('mystery-game').style.display = 'block';
  renderMystery();
}

function renderMystery() {
  const s = mysteryState;
  if(s.idx >= s.cases.length) { endMystery(); return; }
  const c = s.cases[s.idx];
  clearInterval(s.timer);
  let timeLeft = s.timeLimit || 999;

  const diffBadge = {easy:'🟢 Fácil', medium:'🟡 Medio', hard:'🔴 Difícil'}[c.diff];
  const optsHtml = c.opts.map(opt => `
    <button onclick="answerMystery('${opt.replace(/'/g,"\\'")}')"
      style="background:white;border:1.5px solid var(--border);border-radius:10px;padding:.75rem 1rem;font-size:.88rem;cursor:pointer;text-align:left;width:100%;font-family:inherit;transition:all .15s;margin-bottom:.5rem;"
      onmouseover="this.style.borderColor='var(--purple)';this.style.background='#faf5ff';"
      onmouseout="this.style.borderColor='var(--border)';this.style.background='white';">
      ${opt}
    </button>`).join('');

  document.getElementById('mystery-game').innerHTML = `
    <div style="background:white;border:1px solid var(--border);border-radius:14px;box-shadow:var(--shadow-lg);overflow:hidden;">
      <div style="background:linear-gradient(135deg,#1e1b4b,#312e81);color:white;padding:1.25rem 1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:.75rem;">
          <div>
            <div style="font-size:.72rem;color:#a5b4fc;text-transform:uppercase;letter-spacing:.08em;margin-bottom:.3rem;">Caso ${s.idx+1} de ${s.cases.length} · ${diffBadge}</div>
            <div style="font-family:'DM Serif Display',serif;font-size:1.3rem;">${c.icon} ${c.title}</div>
          </div>
          <div style="display:flex;gap:1.25rem;align-items:center;">
            <div style="text-align:center;"><div style="font-family:'DM Serif Display',serif;font-size:1.5rem;color:#fbbf24;">${s.score}</div><div style="font-size:.7rem;color:#a5b4fc;">Puntos</div></div>
            ${s.timeLimit > 0 ? `<div id="mystery-timer-ring">${makeTimerRing(s.timeLimit, timeLeft, '#a5b4fc')}</div>` : ''}
          </div>
        </div>
      </div>
      <div style="padding:1.5rem;">
        <div style="background:#f5f3ff;border:1px solid #e9d5ff;border-radius:10px;padding:1rem 1.25rem;margin-bottom:1.25rem;font-size:.9rem;color:#4c1d95;line-height:1.65;">
          📋 <strong>El caso:</strong> ${c.story}
        </div>
        <div style="margin-bottom:1.25rem;">
          <div style="font-size:.78rem;font-weight:700;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.6rem;">Pistas formales:</div>
          ${c.premises.map((p,i)=>`<div style="display:flex;gap:.6rem;padding:.3rem 0;font-size:.88rem;"><span style="color:var(--slate);min-width:16px;">${i+1}.</span><span>${p}</span></div>`).join('')}
        </div>
        <div style="font-weight:600;color:var(--navy);margin-bottom:.75rem;">🔍 ${c.question}</div>
        <div id="mystery-opts">${optsHtml}</div>
        <div id="mystery-feedback" style="display:none;margin-top:1rem;border-radius:10px;padding:1rem 1.25rem;"></div>
      </div>
    </div>`;

  if(s.timeLimit > 0) {
    s.timer = safeSetInterval(() => {
      timeLeft--;
      const ring = document.getElementById('mystery-timer-ring');
      if(ring) ring.innerHTML = makeTimerRing(s.timeLimit, timeLeft, '#a5b4fc');
      if(timeLeft <= 0) { clearInterval(s.timer); mysteryTimeUp(c); }
    }, 1000);
  }
}

function answerMystery(ans) {
  clearInterval(mysteryState.timer);
  const c = mysteryState.cases[mysteryState.idx];
  const correct = ans === c.answer;
  if(correct) { mysteryState.score += 25; mysteryState.correct++; }
  document.querySelectorAll('#mystery-opts button').forEach(b => {
    b.disabled = true;
    if(b.textContent.trim() === c.answer) { b.style.borderColor='var(--green)'; b.style.background='var(--green-light)'; b.style.fontWeight='700'; }
    else if(b.textContent.trim() === ans && !correct) { b.style.borderColor='var(--red)'; b.style.background='var(--red-light)'; }
  });
  const fb = document.getElementById('mystery-feedback');
  fb.style.display = 'block';
  fb.style.background = correct ? 'var(--green-light)' : 'var(--red-light)';
  fb.style.border = `1px solid ${correct ? '#bbf7d0' : 'var(--red-mid)'}`;
  fb.innerHTML = `<strong style="color:${correct?'var(--green)':'var(--red)'};">${correct?'✅ ¡Caso resuelto!':'❌ Deducción incorrecta'}</strong>
    <div style="font-size:.85rem;color:var(--text2);margin-top:.5rem;"><strong>Regla aplicada:</strong> ${c.rule}</div>
    <div style="font-size:.85rem;color:var(--text2);margin-top:.3rem;">${c.explain}</div>
    <button onclick="mysteryNext()" class="btn btn-primary" style="margin-top:.75rem;font-size:.85rem;">Siguiente caso →</button>`;
}

function mysteryTimeUp(c) {
  clearInterval(mysteryState.timer);
  document.querySelectorAll('#mystery-opts button').forEach(b => {
    b.disabled = true;
    if(b.textContent.trim() === c.answer) { b.style.borderColor='var(--green)'; b.style.background='var(--green-light)'; b.style.fontWeight='700'; }
  });
  const fb = document.getElementById('mystery-feedback');
  if(fb) {
    fb.style.display = 'block';
    fb.style.background = 'var(--accent-light)';
    fb.style.border = '1px solid #fed7aa';
    fb.innerHTML = `<strong style="color:#92400e;">⏱️ ¡Tiempo agotado!</strong> Respuesta correcta: <strong>${c.answer}</strong>
      <div style="font-size:.85rem;margin-top:.4rem;color:var(--text2);">${c.explain}</div>
      <button onclick="mysteryNext()" class="btn btn-primary" style="margin-top:.75rem;font-size:.85rem;">Siguiente →</button>`;
  }
}

function mysteryNext() { mysteryState.idx++; renderMystery(); }

function endMystery() {
  const s = mysteryState;
  trackLogro('mystery_played');
  document.getElementById('mystery-game').innerHTML = `
    <div class="results-card">
      <div style="font-size:3rem;margin-bottom:1rem;">${s.correct===s.cases.length?'🏆':s.correct>=s.cases.length/2?'🔍':'📚'}</div>
      <div style="font-family:'DM Serif Display',serif;font-size:2.2rem;color:var(--navy);">${s.score} puntos</div>
      <div style="color:var(--slate);margin:.5rem 0 1.5rem;">${s.correct} de ${s.cases.length} casos resueltos correctamente</div>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <button class="btn btn-primary" onclick="document.getElementById('mystery-setup').style.display='block';document.getElementById('mystery-game').style.display='none';">🔄 Nuevos casos</button>
        <button class="btn btn-outline" onclick="showPage('valido')">⚖️ Más detección de falacias</button>
      </div>
    </div>`;
}

// ====================== TORNEO ======================
let torneoState = {};

function startTorneo() {
  const players = [
    document.getElementById('t-p1').value || 'Jugador 1',
    document.getElementById('t-p2').value || 'Jugador 2',
    document.getElementById('t-p3').value || 'Jugador 3',
    document.getElementById('t-p4').value || 'Jugador 4'
  ];
  const rounds = parseInt(document.getElementById('torneo-rounds').value);
  const timeLimit = parseInt(document.getElementById('torneo-time').value);
  torneoState = {
    players, rounds, timeLimit,
    phase: 'semi', // semi → final
    semi1: { p1: players[0], p2: players[1], scores: [0,0] },
    semi2: { p1: players[2], p2: players[3], scores: [0,0] },
    final: null,
    currentMatch: 'semi1', currentPlayer: 0,
    deck: fisherYates(QUIZ_QUESTIONS),
    qIdx: 0, timer: null
  };
  document.getElementById('torneo-setup').style.display = 'none';
  updateTorneoBracket();
  renderTorneoRound();
}

function updateTorneoBracket() {
  const s = torneoState;
  const bracket = document.getElementById('torneo-bracket');
  bracket.style.display = 'block';
  const getScore = (match, i) => s[match] ? s[match].scores[i] : '-';
  const winner = (match) => {
    if(!s[match]) return '?';
    if(s[match].scores[0] > s[match].scores[1]) return s[match].p1;
    if(s[match].scores[1] > s[match].scores[0]) return s[match].p2;
    return '?';
  };
  bracket.innerHTML = `
    <div style="background:white;border:1px solid var(--border);border-radius:12px;padding:1.25rem;box-shadow:var(--shadow);">
      <div style="font-weight:700;font-size:.9rem;margin-bottom:1rem;color:var(--navy);">🏟️ Cuadro del Torneo</div>
      <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:1rem;align-items:center;">
        <div>
          <div style="font-size:.72rem;font-weight:600;color:var(--slate);text-transform:uppercase;margin-bottom:.5rem;">Semifinal 1</div>
          <div style="background:var(--blue-light);border-radius:8px;padding:.6rem .9rem;margin-bottom:.3rem;display:flex;justify-content:space-between;"><span style="font-size:.88rem;">${s.semi1.p1}</span><strong style="color:var(--blue);">${getScore('semi1',0)}</strong></div>
          <div style="background:var(--blue-light);border-radius:8px;padding:.6rem .9rem;display:flex;justify-content:space-between;"><span style="font-size:.88rem;">${s.semi1.p2}</span><strong style="color:var(--blue);">${getScore('semi1',1)}</strong></div>
        </div>
        <div style="text-align:center;color:var(--slate);font-size:.8rem;">→ Final ←</div>
        <div>
          <div style="font-size:.72rem;font-weight:600;color:var(--slate);text-transform:uppercase;margin-bottom:.5rem;">Semifinal 2</div>
          <div style="background:var(--red-light);border-radius:8px;padding:.6rem .9rem;margin-bottom:.3rem;display:flex;justify-content:space-between;"><span style="font-size:.88rem;">${s.semi2.p1}</span><strong style="color:var(--red);">${getScore('semi2',0)}</strong></div>
          <div style="background:var(--red-light);border-radius:8px;padding:.6rem .9rem;display:flex;justify-content:space-between;"><span style="font-size:.88rem;">${s.semi2.p2}</span><strong style="color:var(--red);">${getScore('semi2',1)}</strong></div>
        </div>
      </div>
      ${s.final ? `<div style="margin-top:1rem;padding:.75rem;background:var(--accent-light);border-radius:8px;text-align:center;font-weight:600;color:#92400e;">🏆 Final: ${s.final.p1} vs ${s.final.p2}</div>` : ''}
    </div>`;
}

function renderTorneoRound() {
  const s = torneoState;
  const match = s[s.currentMatch];
  const pName = s.currentPlayer === 0 ? match.p1 : match.p2;
  const pColor = s.currentPlayer === 0 ? '#3b82f6' : '#dc2626';
  const roundLabel = s.currentMatch === 'final' ? '🏆 FINAL' : s.currentMatch === 'semi1' ? '⚔️ Semifinal 1' : '⚔️ Semifinal 2';

  clearInterval(s.timer);
  let timeLeft = s.timeLimit;
  const q = s.deck[s.qIdx % s.deck.length];

  document.getElementById('torneo-game').style.display = 'block';
  document.getElementById('torneo-game').innerHTML = `
    <div style="background:white;border:2px solid ${pColor};border-radius:14px;box-shadow:var(--shadow-lg);overflow:hidden;">
      <div style="background:${pColor};color:white;padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;">
        <div>
          <div style="font-size:.75rem;opacity:.8;">${roundLabel} · Pregunta ${s.qIdx % s.rounds + 1}/${s.rounds}</div>
          <div style="font-family:'DM Serif Display',serif;font-size:1.2rem;margin-top:.1rem;">Turno: ${pName}</div>
        </div>
        <div style="display:flex;gap:1.5rem;align-items:center;">
          <div style="text-align:center;background:rgba(255,255,255,.15);border-radius:8px;padding:.3rem .9rem;">
            <div style="font-family:'DM Serif Display',serif;font-size:1.2rem;">${match.scores[0]} — ${match.scores[1]}</div>
            <div style="font-size:.7rem;opacity:.75;">${match.p1} vs ${match.p2}</div>
          </div>
          <div id="torneo-timer-ring">${makeTimerRing(s.timeLimit, timeLeft)}</div>
        </div>
      </div>
      <div style="padding:1.5rem;">
        ${makeQuestionBox(q)}
        <div id="torneo-opts">${makeAnswerGrid(q.opts, q.answer, 'answerTorneo')}</div>
        <div id="torneo-feedback" style="display:none;margin-top:1rem;border-radius:10px;padding:.9rem 1.1rem;font-size:.88rem;"></div>
      </div>
    </div>`;

  s.timer = safeSetInterval(() => {
    timeLeft--;
    const ring = document.getElementById('torneo-timer-ring');
    if(ring) ring.innerHTML = makeTimerRing(s.timeLimit, timeLeft);
    if(timeLeft <= 0) { clearInterval(s.timer); torneoTimeUp(); }
  }, 1000);
}

function answerTorneo(ans) {
  clearInterval(torneoState.timer);
  const s = torneoState;
  const match = s[s.currentMatch];
  const q = s.deck[s.qIdx % s.deck.length];
  const correct = ans === q.answer;
  if(correct) match.scores[s.currentPlayer]++;

  document.querySelectorAll('#torneo-opts button').forEach(b => {
    b.disabled = true;
    if(b.textContent.trim() === q.answer) { b.style.borderColor='var(--green)'; b.style.background='var(--green-light)'; b.style.fontWeight='700'; }
    else if(b.textContent.trim() === ans && !correct) { b.style.borderColor='var(--red)'; b.style.background='var(--red-light)'; }
  });
  const fb = document.getElementById('torneo-feedback');
  fb.style.display = 'block';
  fb.style.background = correct ? 'var(--green-light)' : 'var(--red-light)';
  fb.style.color = correct ? 'var(--green)' : 'var(--red)';
  fb.innerHTML = `<strong>${correct ? '✅ +1 punto' : '❌ Sin punto'}</strong> — Respuesta: <strong>${q.answer}</strong><br><div style="font-size:.82rem;margin-top:.3rem;opacity:.85;">${q.explain}</div>`;

  setTimeout(() => {
    s.qIdx++;
    s.currentPlayer = s.currentPlayer === 0 ? 1 : 0;
    // Check if this match is over: every player has answered s.rounds questions
    // qIdx counts total answers; match ends when qIdx reaches 2 * rounds (each player answered rounds times)
    if(s.qIdx >= s.rounds * 2) {
      s.qIdx = 0;
      advanceTorneo();
    } else {
      updateTorneoBracket();
      renderTorneoRound();
    }
  }, 1500);
}

function torneoTimeUp() {
  const s = torneoState;
  const match = s[s.currentMatch];
  const fb = document.getElementById('torneo-feedback');
  if(fb) { fb.style.display='block'; fb.style.background='var(--accent-light)'; fb.style.color='#92400e'; fb.textContent='⏱️ ¡Tiempo! Sin punto.'; }
  setTimeout(() => {
    s.qIdx++;
    s.currentPlayer = s.currentPlayer === 0 ? 1 : 0;
    if(s.qIdx >= s.rounds * 2) {
      s.qIdx = 0;
      advanceTorneo();
    } else {
      updateTorneoBracket();
      renderTorneoRound();
    }
  }, 1200);
}

function advanceTorneo() {
  const s = torneoState;
  const match = s[s.currentMatch];
  const winnerName = match.scores[0] > match.scores[1] ? match.p1 : match.scores[1] > match.scores[0] ? match.p2 : (Math.random()>.5 ? match.p1 : match.p2);

  if(s.currentMatch === 'semi1') {
    s.currentMatch = 'semi2';
    s.currentPlayer = 0;
    s.qIdx = 0;
    s.deck = fisherYates(QUIZ_QUESTIONS); // Reshuffle for new match
    updateTorneoBracket();
    // Show transition
    document.getElementById('torneo-game').innerHTML = `
      <div style="background:white;border:1px solid var(--border);border-radius:14px;padding:2rem;text-align:center;box-shadow:var(--shadow);">
        <div style="font-size:2.5rem;margin-bottom:.75rem;">🏆</div>
        <div style="font-family:'DM Serif Display',serif;font-size:1.4rem;margin-bottom:.5rem;">${winnerName} pasa a la Final</div>
        <div style="color:var(--slate);margin-bottom:1.5rem;">Marcador: ${match.p1} ${match.scores[0]} — ${match.scores[1]} ${match.p2}</div>
        <button class="btn btn-primary" onclick="renderTorneoRound()">Comenzar Semifinal 2 →</button>
      </div>`;
  } else if(s.currentMatch === 'semi2') {
    const winner1 = s.semi1.scores[0] > s.semi1.scores[1] ? s.semi1.p1 : s.semi1.scores[1] > s.semi1.scores[0] ? s.semi1.p2 : (Math.random()>.5 ? s.semi1.p1 : s.semi1.p2);
    const winner2 = s.semi2.scores[0] > s.semi2.scores[1] ? s.semi2.p1 : s.semi2.scores[1] > s.semi2.scores[0] ? s.semi2.p2 : (Math.random()>.5 ? s.semi2.p1 : s.semi2.p2);
    s.final = { p1: winner1, p2: winner2, scores: [0, 0] };
    s.currentMatch = 'final';
    s.currentPlayer = 0;
    s.qIdx = 0;
    s.deck = fisherYates(QUIZ_QUESTIONS); // Reshuffle for final
    updateTorneoBracket();
    document.getElementById('torneo-game').innerHTML = `
      <div style="background:linear-gradient(135deg,var(--navy),var(--navy2));color:white;border-radius:14px;padding:2rem;text-align:center;box-shadow:var(--shadow-lg);">
        <div style="font-size:2.5rem;margin-bottom:.75rem;">🏆</div>
        <div style="font-family:'DM Serif Display',serif;font-size:1.6rem;margin-bottom:.5rem;">¡GRAN FINAL!</div>
        <div style="color:#94a3b8;margin-bottom:1.5rem;">${winner1} vs ${winner2}</div>
        <button class="btn btn-accent" style="font-size:1rem;padding:.75rem 2rem;" onclick="renderTorneoRound()">⚔️ ¡Comenzar la Final!</button>
      </div>`;
  } else {
    // Tournament over
    const champion = s.final.scores[0] > s.final.scores[1] ? s.final.p1 : s.final.scores[1] > s.final.scores[0] ? s.final.p2 : (Math.random()>.5 ? s.final.p1 : s.final.p2);
    document.getElementById('torneo-results').style.display = 'block';
    document.getElementById('torneo-game').style.display = 'none';
    document.getElementById('torneo-results').innerHTML = `
      <div class="results-card" style="border:3px solid var(--accent);">
        <div style="font-size:3.5rem;margin-bottom:1rem;">🏆</div>
        <div style="font-family:'DM Serif Display',serif;font-size:2rem;color:var(--accent);margin-bottom:.3rem;">¡CAMPEÓN!</div>
        <div style="font-family:'DM Serif Display',serif;font-size:2.5rem;color:var(--navy);margin-bottom:1rem;">${champion}</div>
        <div style="color:var(--slate);margin-bottom:1.5rem;">Final: ${s.final.p1} ${s.final.scores[0]} — ${s.final.scores[1]} ${s.final.p2}</div>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
          <button class="btn btn-primary" onclick="document.getElementById('torneo-setup').style.display='block';document.getElementById('torneo-results').style.display='none';document.getElementById('torneo-bracket').style.display='none';document.getElementById('torneo-game').style.display='none';">🔄 Nuevo Torneo</button>
        </div>
      </div>`;
    trackLogro('torneo_completado');
  }
}
// ====================== ENCUENTRA EL ERROR ======================
