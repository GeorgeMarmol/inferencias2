  },
  {
    rule: 'Dilema Destructivo',
    title: 'Regla 10 — Dilema Destructivo (DD)',
    context: 'Si apruebo, celebro. Si me contrato, descanso. Ni celebro ni descanso. ¿Qué concluyes?',
    name: 'Regla 10: Dilema Destructivo',
    premises: ['p → q', 'r → s', '¬q ∨ ¬s'],
    goal: '¬p ∨ ¬r',
    steps: [
      { formula: 'p → q', justification: 'Premisa', isPremise: true },
      { formula: 'r → s', justification: 'Premisa', isPremise: true },
      { formula: '¬q ∨ ¬s', justification: 'Premisa', isPremise: true },
      { formula: '(p → q) ∧ (r → s)', justification: 'Conjunción (Con) — líneas 1, 2', isPremise: false },
      { formula: '¬p ∨ ¬r', justification: 'Dilema Destructivo (DD) — líneas 4, 3', isPremise: false }
