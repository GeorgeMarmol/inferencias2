    ],
    goal: 's',
    steps: [
      { formula: '¬p',    reason: 'Modus Tollens (MT) — líneas 1, 2',          hint: 'Niega el antecedente con MT.' },
      { formula: '¬r',    reason: 'Modus Tollens (MT) — líneas 1, 2',          hint: '¿Qué más puedes negar? Pista: necesitas ¬r. Busca otra premisa útil.' },
      { formula: 's',     reason: 'Silogismo Disyuntivo (SD) — líneas 3, 5',   hint: 'Con ¬r y r∨s aplica SD.' }
    ],
    // Override: step 2 needs special handling — ¬p isn't used for ¬r
    // We'll use a simpler version
    override: true,
    stepsOverride: [
      { formula: '¬p', reason: 'Modus Tollens (MT) — líneas 1, 2',        hint: 'De p→q y ¬q obtienes ¬p por MT.' },
      { formula: 's',  reason: 'Silogismo Disyuntivo (SD) — líneas 3, ?', hint: 'Necesitas negar r. Revisa: ¿tienes ¬r en algún lado?' }
    ]
  },
  {
    diff: 'medio',
    title: 'Reto 7 — Absorción + MP',
    legend: { p: 'Eres ciudadano', q: 'Tienes derechos' },
    premises: [
      { formula: 'p → q', reason: 'Premisa' },
      { formula: 'p',     reason: 'Premisa' }
    ],
    goal: 'p ∧ q',
    steps: [
      { formula: 'p → (p ∧ q)', reason: 'Absorción (Abs) — línea 1',           hint: 'Aplica Absorción al condicional.' },
      { formula: 'p ∧ q',       reason: 'Modus Ponens (MP) — líneas 3, 2',     hint: 'Ahora tienes p→(p∧q) y p. Aplica MP.' }
    ]
  },
  // ─── DIFÍCIL ───
  {
    diff: 'dificil',
    title: 'Reto 8 — Cadena completa (4 pasos)',
    legend: { p: 'Hay financiamiento', q: 'Se inicia el proyecto', r: 'Se contrata personal', s: 'Hay producción' },
    premises: [
      { formula: 'p → q', reason: 'Premisa' },
      { formula: 'q → r', reason: 'Premisa' },
      { formula: 'r → s', reason: 'Premisa' },
      { formula: 'p',     reason: 'Premisa' }
    ],
    goal: 's',
    steps: [
      { formula: 'p → r', reason: 'Silogismo Hipotético (SH) — líneas 1, 2', hint: 'Encadena las líneas 1 y 2.' },
      { formula: 'p → s', reason: 'Silogismo Hipotético (SH) — líneas 5, 3', hint: 'Encadena el resultado con la línea 3.' },
      { formula: 's',     reason: 'Modus Ponens (MP) — líneas 6, 4',          hint: 'Tienes p→s y p. Aplica MP.' }
    ]
  },
  {
    diff: 'dificil',
    title: 'Reto 9 — Dilema Constructivo',
    legend: { p: 'Llueve', q: 'Nos quedamos en casa', r: 'Hace sol', s: 'Vamos al parque' },
    premises: [
      { formula: 'p → q', reason: 'Premisa' },
      { formula: 'r → s', reason: 'Premisa' },
      { formula: 'p ∨ r', reason: 'Premisa' }
    ],
    goal: 'q ∨ s',
    steps: [
      { formula: '(p → q) ∧ (r → s)', reason: 'Conjunción (Con) — líneas 1, 2',         hint: 'Une los dos condicionales con Conjunción.' },
      { formula: 'q ∨ s',              reason: 'Dilema Constructivo (DC) — líneas 4, 3', hint: 'Tienes la conjunción de condicionales y p∨r. Aplica DC.' }
    ]
  },
  {
    diff: 'dificil',
    title: 'Reto 10 — Demostración larga (5 pasos)',
    legend: { p: 'El sistema tiene energía', q: 'El procesador funciona', r: 'La memoria está activa', s: 'El software ejecuta', t: 'Hay output' },
    premises: [
      { formula: 'p → q', reason: 'Premisa' },
      { formula: 'q → r', reason: 'Premisa' },
      { formula: 'r → s', reason: 'Premisa' },
      { formula: 's → t', reason: 'Premisa' },
      { formula: 'p',     reason: 'Premisa' }
    ],
    goal: 't',
    steps: [
      { formula: 'p → r', reason: 'Silogismo Hipotético (SH) — líneas 1, 2', hint: 'Encadena líneas 1 y 2.' },
      { formula: 'p → s', reason: 'Silogismo Hipotético (SH) — líneas 6, 3', hint: 'Encadena el resultado anterior con línea 3.' },
      { formula: 'p → t', reason: 'Silogismo Hipotético (SH) — líneas 7, 4', hint: 'Encadena con línea 4.' },
      { formula: 't',     reason: 'Modus Ponens (MP) — líneas 8, 5',          hint: 'Tienes p→t y p. Aplica MP.' }
    ]
  }
];

// Remove the bad override reto 7 — replace with correct one (already correct above as Absorción)
// (The override:true entry will be filtered in startCadenaGame)

let cadenaState = {};

function startCadenaGame() {
  var diff = document.getElementById('cadena-diff').value;
  var hints = document.getElementById('cadena-hints').value;
  // Filter out any entries with override:true (malformed data)
  var pool = (diff === 'todos' ? CADENA_DATA.slice() : CADENA_DATA.filter(function(e){ return e.diff === diff; }))
    .filter(function(e){ return !e.override; });
  if(!pool.length){ alert('No hay cadenas para esa dificultad.'); return; }
  pool = fisherYates(pool);
  cadenaState = { pool:pool, idx:0, correct:0, hints:hints, solved:0 };
  document.getElementById('cadena-setup').style.display = 'none';
  document.getElementById('cadena-results').style.display = 'none';
  document.getElementById('cadena-game').style.display = 'block';
  renderCadena();
}

function cadenaRestart() {
  document.getElementById('cadena-game').style.display = 'none';
  document.getElementById('cadena-results').style.display = 'none';
  document.getElementById('cadena-setup').style.display = 'block';
}

function renderCadena() {
  var s = cadenaState;
  if(s.idx >= s.pool.length){ endCadenaGame(); return; }
  var ex = s.pool[s.idx];
  var totalLines = ex.premises.length + ex.steps.length;
  var diffColors = {facil:'#16a34a', medio:'#d97706', dificil:'#dc2626'};
  var diffLabels = {facil:'🟢 Fácil', medio:'🟡 Medio', dificil:'🔴 Difícil'};
  var col = diffColors[ex.diff] || '#64748b';

  // Build legend HTML
  var legendHtml = Object.entries(ex.legend).map(function(e){
    return '<span style="display:inline-flex;align-items:center;gap:.3rem;margin-right:.75rem;margin-bottom:.3rem;font-size:.83rem;">'
      + '<code style="background:var(--slate-light);border:1px solid var(--border);border-radius:4px;padding:.1rem .4rem;font-weight:700;color:var(--blue);">' + e[0] + '</code>'
      + '<span style="color:var(--text2);">= ' + e[1] + '</span></span>';
  }).join('');

  // Shuffle the steps for the bank
  var shuffled = fisherYates(ex.steps);

  // Generate unique IDs for this render
  var renderKey = 'cd_' + s.idx + '_' + Date.now();

  // Build premise rows (fixed)
  var premiseRowsHtml = ex.premises.map(function(p, i){
    return '<div class="cadena-proof-row" style="display:grid;grid-template-columns:36px 1fr 1fr;align-items:center;padding:.6rem 1rem;border-bottom:1px solid var(--border);background:#fafafa;">'
      + '<div style="font-size:.75rem;color:var(--slate);font-weight:700;">' + (i+1) + '</div>'
      + '<div style="font-size:.9rem;color:var(--navy);font-weight:500;">' + p.formula + '</div>'
      + '<div style="font-size:.75rem;color:var(--slate);font-style:italic;">' + p.reason + '</div>'
      + '</div>';
  }).join('');

  // Build drop slots for derived steps
  var dropSlotsHtml = ex.steps.map(function(step, i){
    var lineNum = ex.premises.length + i + 1;
    var isGoal = i === ex.steps.length - 1;
    return '<div class="cadena-slot" data-slot="' + i + '" '
      + 'style="display:grid;grid-template-columns:36px 1fr 1fr;align-items:center;padding:.6rem 1rem;border-bottom:1px solid var(--border);'
      + 'min-height:48px;background:' + (isGoal ? '#fffbeb' : 'white') + ';transition:background .15s;" '
      + 'ondragover="cadDragOver(event)" ondrop="cadDrop(event,' + i + ')" ondragleave="cadDragLeave(event)">'
      + '<div style="font-size:.75rem;color:var(--slate);font-weight:700;">' + lineNum + '</div>'
      + '<div class="cadena-slot-content" style="display:flex;align-items:center;gap:.4rem;min-height:28px;">'
        + '<span style="font-size:.78rem;color:#94a3b8;font-style:italic;">Arrastra un paso aquí...</span>'
      + '</div>'
      + '<div class="cadena-slot-reason" style="font-size:.75rem;color:var(--slate);font-style:italic;"></div>'
      + '</div>';
  }).join('');

  // Build step bank (draggable chips)
  var bankHtml = shuffled.map(function(step, i){
    var origIdx = ex.steps.indexOf(step);
    return '<div class="cadena-chip" draggable="true" data-origidx="' + origIdx + '" '
      + 'style="display:inline-flex;align-items:center;gap:.5rem;background:white;border:1.5px solid var(--border);border-radius:8px;'
      + 'padding:.5rem .9rem;cursor:grab;font-size:.88rem;font-weight:500;color:var(--navy);box-shadow:var(--shadow);'
      + 'margin:.25rem;transition:all .15s;user-select:none;" '
      + 'ondragstart="cadDragStart(event,' + origIdx + ')" ondragend="cadDragEnd(event)">'
      + step.formula
      + (s.hints === 'si' ? '<span style="font-size:.7rem;color:var(--slate);font-style:italic;margin-left:.3rem;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="' + step.hint + '">💡</span>' : '')
      + '</div>';
  }).join('');

  // Also build a "reasons bank" (auto-filled when formula is placed, but shown separately)
  var reasonsHtml = ex.steps.map(function(step, i){
    return '<div style="font-size:.75rem;color:var(--blue);padding:.2rem 0;">Línea ' + (ex.premises.length + i + 1) + ': ' + step.reason + '</div>';
  }).join('');

  document.getElementById('cadena-game').innerHTML =
    '<div style="background:white;border:1px solid var(--border);border-radius:14px;box-shadow:var(--shadow-lg);overflow:hidden;margin-bottom:1rem;">'

    // Header
    + '<div style="background:var(--navy);color:white;padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.75rem;">'
      + '<div>'
        + '<div style="font-size:.72rem;color:#94a3b8;text-transform:uppercase;letter-spacing:.08em;margin-bottom:.2rem;">Cadena ' + (s.idx+1) + ' de ' + s.pool.length + ' &nbsp;·&nbsp; <span style="color:' + col + ';">' + (diffLabels[ex.diff]||ex.diff) + '</span></div>'
        + '<div style="font-size:1.15rem;font-weight:600;">🔗 ' + ex.title + '</div>'
      + '</div>'
      + '<div style="display:flex;gap:1.25rem;align-items:center;">'
        + '<div style="text-align:center;"><div style="font-size:1.4rem;color:var(--green);font-weight:700;">' + s.correct + '</div><div style="font-size:.7rem;color:#94a3b8;">Perfectas</div></div>'
        + '<div style="text-align:center;"><div style="font-size:1.2rem;color:#94a3b8;font-weight:700;">' + (s.idx+1) + '/' + s.pool.length + '</div><div style="font-size:.7rem;color:#94a3b8;">Progreso</div></div>'
      + '</div>'
    + '</div>'

    // Context + legend
    + '<div style="padding:.85rem 1.5rem;background:#f0fdf4;border-bottom:1px solid #bbf7d0;">'
      + '<div style="font-size:.83rem;color:#15803d;font-weight:600;margin-bottom:.4rem;">Meta: demostrar <code style="background:white;border:1px solid #bbf7d0;border-radius:4px;padding:.1rem .45rem;font-weight:700;">' + ex.goal + '</code></div>'
      + '<div style="display:flex;flex-wrap:wrap;">' + legendHtml + '</div>'
    + '</div>'

    // Proof table header
    + '<div style="display:grid;grid-template-columns:36px 1fr 1fr;background:var(--slate-light);border-bottom:1px solid var(--border);padding:.45rem 1rem;">'
      + '<div style="font-size:.72rem;font-weight:700;color:var(--slate);">#</div>'
      + '<div style="font-size:.72rem;font-weight:700;color:var(--slate);">FÓRMULA</div>'
      + '<div style="font-size:.72rem;font-weight:700;color:var(--slate);">JUSTIFICACIÓN</div>'
    + '</div>'

    // Premise rows (fixed)
    + premiseRowsHtml

    // Drop slots
    + '<div id="cadena-drop-zone">' + dropSlotsHtml + '</div>'

    // Step bank
    + '<div style="padding:1rem 1.5rem;background:#f8fafc;border-top:2px dashed var(--border);">'
      + '<div style="font-size:.78rem;font-weight:700;color:var(--slate);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.6rem;">📦 Pasos disponibles — arrastra cada uno al slot correcto:</div>'
      + '<div id="cadena-bank" style="display:flex;flex-wrap:wrap;min-height:48px;padding:.25rem;border-radius:8px;transition:background .15s;">' + bankHtml + '</div>'
    + '</div>'

    // Feedback area
    + '<div id="cadena-feedback" style="display:none;padding:1rem 1.5rem;"></div>'

    // Action buttons
    + '<div style="padding:1rem 1.5rem;border-top:1px solid var(--border);display:flex;gap:.75rem;flex-wrap:wrap;">'
      + '<button class="btn btn-primary" id="cadena-verify-btn" style="background:var(--green);">✅ Verificar cadena</button>'
      + '<button class="btn btn-outline" id="cadena-reset-btn">↺ Reiniciar</button>'
      + '<button class="btn btn-outline" id="cadena-back-btn">↩ Cambiar configuración</button>'
    + '</div>'
    + '</div>';

  // Store current exercise state for drag-drop
  cadenaState.currentSlots = new Array(ex.steps.length).fill(null);

  // Attach event listeners
  document.getElementById('cadena-verify-btn').addEventListener('click', verifyCadena);
  document.getElementById('cadena-reset-btn').addEventListener('click', function(){ renderCadena(); });
  document.getElementById('cadena-back-btn').addEventListener('click', cadenaRestart);

  // Touch support for mobile
  document.querySelectorAll('.cadena-chip').forEach(function(chip){
    chip.addEventListener('touchstart', cadTouchStart, { passive: true });
    chip.addEventListener('touchend', cadTouchEnd);
  });
}

// ── Drag-and-drop handlers ──────────────────────────────────
var cadDraggedIdx = null;
var cadDraggedFromSlot = null;  // null = from bank, number = from slot

function cadDragStart(e, origIdx) {
  cadDraggedIdx = origIdx;
  cadDraggedFromSlot = null;
  e.dataTransfer.effectAllowed = 'move';
  e.target.style.opacity = '0.5';
}

function cadDragEnd(e) {
  e.target.style.opacity = '1';
}

function cadDragOver(e) {
  e.preventDefault();
  e.currentTarget.style.background = '#ecfdf5';
  e.currentTarget.style.borderLeft = '3px solid var(--green)';
}

function cadDragLeave(e) {
  e.currentTarget.style.background = '';
  e.currentTarget.style.borderLeft = '';
}

function cadDrop(e, slotIdx) {
  e.preventDefault();
  e.currentTarget.style.background = '';
  e.currentTarget.style.borderLeft = '';
  if(cadDraggedIdx === null) return;

  var s = cadenaState;
  var ex = s.pool[s.idx];
  var step = ex.steps[cadDraggedIdx];

  // If slot is already occupied, return the previous chip to bank
  if(s.currentSlots[slotIdx] !== null) {
    var prevIdx = s.currentSlots[slotIdx];
    cadReturnToBank(prevIdx);
  }

  // Place chip in slot
  s.currentSlots[slotIdx] = cadDraggedIdx;

  // Remove chip from bank (if it came from bank)
  var bank = document.getElementById('cadena-bank');
  var chips = bank.querySelectorAll('.cadena-chip');
  chips.forEach(function(chip){
    if(parseInt(chip.getAttribute('data-origidx')) === cadDraggedIdx) {
      chip.remove();
    }
  });

  // Update slot visual
  var slot = document.querySelector('.cadena-slot[data-slot="' + slotIdx + '"]');
  if(slot) {
    var content = slot.querySelector('.cadena-slot-content');
    var reasonEl = slot.querySelector('.cadena-slot-reason');
    if(content) {
      content.innerHTML = '<div class="cadena-placed-chip" data-origidx="' + cadDraggedIdx + '" data-slot="' + slotIdx + '" '
        + 'style="display:inline-flex;align-items:center;gap:.4rem;background:var(--blue-light);border:1.5px solid var(--blue);border-radius:6px;'
        + 'padding:.3rem .7rem;font-size:.88rem;font-weight:600;color:var(--blue);cursor:pointer;" '
        + 'title="Clic para devolver al banco">'
        + step.formula
        + ' <span style="font-size:.7rem;opacity:.6;">✕</span>'
        + '</div>';

      // Attach click-to-return
      content.querySelector('.cadena-placed-chip').addEventListener('click', function(){
        var oi = parseInt(this.getAttribute('data-origidx'));
        var si = parseInt(this.getAttribute('data-slot'));
        cadRemoveFromSlot(si, oi);
      });
    }
    if(reasonEl) reasonEl.textContent = step.reason;
  }

  cadDraggedIdx = null;
}

function cadRemoveFromSlot(slotIdx, origIdx) {
  var s = cadenaState;
  s.currentSlots[slotIdx] = null;

  // Clear slot visual
  var slot = document.querySelector('.cadena-slot[data-slot="' + slotIdx + '"]');
  if(slot) {
    var content = slot.querySelector('.cadena-slot-content');
    var reasonEl = slot.querySelector('.cadena-slot-reason');
    if(content) content.innerHTML = '<span style="font-size:.78rem;color:#94a3b8;font-style:italic;">Arrastra un paso aquí...</span>';
    if(reasonEl) reasonEl.textContent = '';
    slot.style.background = '';
    slot.style.borderLeft = '';
  }

  cadReturnToBank(origIdx);
}

function cadReturnToBank(origIdx) {
  var s = cadenaState;
  var ex = s.pool[s.idx];
  var step = ex.steps[origIdx];
  var bank = document.getElementById('cadena-bank');
  if(!bank) return;

  var chip = document.createElement('div');
  chip.className = 'cadena-chip';
  chip.draggable = true;
  chip.setAttribute('data-origidx', origIdx);
  chip.style.cssText = 'display:inline-flex;align-items:center;gap:.5rem;background:white;border:1.5px solid var(--border);border-radius:8px;padding:.5rem .9rem;cursor:grab;font-size:.88rem;font-weight:500;color:var(--navy);box-shadow:var(--shadow);margin:.25rem;transition:all .15s;user-select:none;';
  chip.innerHTML = step.formula + (s.hints === 'si' ? '<span style="font-size:.7rem;color:var(--slate);font-style:italic;margin-left:.3rem;" title="' + step.hint + '">💡</span>' : '');
  chip.addEventListener('dragstart', function(e){ cadDragStart(e, origIdx); });
  chip.addEventListener('dragend', cadDragEnd);
  bank.appendChild(chip);
}

// ── Mobile touch support ────────────────────────────────────
var cadTouchChip = null;
var cadTouchOrigIdx = null;
var cadTouchClone = null;

function cadTouchStart(e) {
  cadTouchChip = e.currentTarget;
  cadTouchOrigIdx = parseInt(cadTouchChip.getAttribute('data-origidx'));
}

function cadTouchEnd(e) {
  if(!cadTouchChip) return;
  var touch = e.changedTouches[0];
  var el = document.elementFromPoint(touch.clientX, touch.clientY);
  // Find nearest slot
  var slot = el ? el.closest('.cadena-slot') : null;
  if(slot) {
    var slotIdx = parseInt(slot.getAttribute('data-slot'));
    cadDraggedIdx = cadTouchOrigIdx;
    cadDrop({ preventDefault: function(){}, currentTarget: slot }, slotIdx);
  }
  cadTouchChip = null;
  cadTouchOrigIdx = null;
}

// ── Verify ──────────────────────────────────────────────────
function verifyCadena() {
  var s = cadenaState;
  var ex = s.pool[s.idx];

  // Check all slots are filled
  var allFilled = s.currentSlots.every(function(v){ return v !== null; });
  if(!allFilled) {
    alert('Debes colocar todos los pasos antes de verificar.');
    return;
  }

  var results = s.currentSlots.map(function(origIdx, slotIdx){
    return { placed: origIdx, expected: slotIdx, correct: origIdx === slotIdx };
  });

  var allCorrect = results.every(function(r){ return r.correct; });
  if(allCorrect) {
    s.correct++;
    s.solved++;
  }

  // Build feedback
  var ex_steps = ex.steps;
  var feedbackRows = results.map(function(r, i){
    var lineNum = ex.premises.length + i + 1;
    var placedStep = ex_steps[r.placed];
    var expectedStep = ex_steps[r.expected];
    var bg = r.correct ? '#f0fdf4' : '#fef2f2';
    var borderLeft = r.correct ? '3px solid var(--green)' : '3px solid var(--red)';
    var icon = r.correct ? '&#9989;' : '&#10060;';
    var wrongMsg = r.correct ? '' : '<div style="font-size:.75rem;color:var(--red);margin-top:.2rem;">Aquí debía ir: <strong>' + expectedStep.formula + '</strong></div>';
    return '<div style="display:grid;grid-template-columns:36px 1fr;align-items:start;padding:.6rem 1rem;border-bottom:1px solid var(--border);background:' + bg + ';border-left:' + borderLeft + ';">'
      + '<div style="font-size:.75rem;color:var(--slate);font-weight:700;">' + lineNum + '</div>'
      + '<div>'
        + '<div style="display:flex;align-items:center;gap:.5rem;">'
          + '<span>' + icon + '</span>'
          + '<span style="font-size:.9rem;font-weight:600;">' + placedStep.formula + '</span>'
          + '<span style="font-size:.75rem;color:var(--slate);">— ' + placedStep.reason + '</span>'
        + '</div>'
        + wrongMsg
      + '</div>'
      + '</div>';
  }).join('');

  var isLast = s.idx + 1 >= s.pool.length;
  var feedbackEl = document.getElementById('cadena-feedback');
  if(!feedbackEl) return;

  feedbackEl.style.display = 'block';
  feedbackEl.innerHTML =
    '<div style="background:' + (allCorrect ? 'var(--green-light)' : '#fff') + ';border:1px solid ' + (allCorrect ? '#bbf7d0' : 'var(--border)') + ';border-radius:12px;overflow:hidden;">'
    + '<div style="padding:.85rem 1.25rem;background:' + (allCorrect ? 'var(--green)' : 'var(--red)') + ';color:white;font-weight:700;font-size:.95rem;">'
      + (allCorrect ? '&#9989; ¡Cadena perfecta! Todos los pasos en el orden correcto.' : '&#10060; Hay pasos fuera de orden. Revisa el detalle:')
    + '</div>'
    + '<div>' + feedbackRows + '</div>'
    + '<div style="padding:.9rem 1.25rem;display:flex;gap:.75rem;flex-wrap:wrap;">'
      + '<button class="btn btn-primary" id="cad-next-btn" style="' + (isLast ? 'background:var(--green);' : '') + '">' + (isLast ? '🏁 Ver resultados' : 'Siguiente →') + '</button>'
      + (!allCorrect ? '<button class="btn btn-outline" id="cad-retry-btn">&#8617; Reintentar</button>' : '')
      + '<button class="btn btn-outline" id="cad-back-btn2">&#8617; Nueva configuración</button>'
    + '</div>'
    + '</div>';

  // Disable verify and reset buttons
  var vBtn = document.getElementById('cadena-verify-btn');
  var rBtn = document.getElementById('cadena-reset-btn');
  if(vBtn) vBtn.disabled = true;
  if(rBtn) rBtn.disabled = true;

  // Attach feedback button listeners
  var nextBtn = document.getElementById('cad-next-btn');
  var retryBtn = document.getElementById('cad-retry-btn');
  var backBtn2 = document.getElementById('cad-back-btn2');
  if(nextBtn) nextBtn.addEventListener('click', function(){ s.idx++; renderCadena(); });
  if(retryBtn) retryBtn.addEventListener('click', function(){ renderCadena(); });
  if(backBtn2) backBtn2.addEventListener('click', cadenaRestart);

  // Scroll to feedback
  feedbackEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

  trackLogro('cadena_played');
  if(allCorrect) trackLogro('cadena_perfect');
}

function endCadenaGame() {
  var s = cadenaState;
  var pct = Math.round(s.correct / s.pool.length * 100);
  var emoji = pct === 100 ? '🏆' : pct >= 75 ? '⛓️' : pct >= 50 ? '🔗' : '📚';
  var label = pct === 100 ? '¡Perfecto! Dominas la construcción de pruebas formales.'
    : pct >= 75 ? '¡Muy bien! Sigue practicando las cadenas más largas.'
    : pct >= 50 ? 'Vas bien. Repasa las reglas de encadenamiento (SH, MP, Con).'
    : 'Necesitas más práctica. Revisa cómo se conectan las reglas en una prueba.';

  var dColors = {facil:'var(--green)', medio:'#d97706', dificil:'var(--red)'};
  var dLabels = {facil:'🟢 Fácil', medio:'🟡 Medio', dificil:'🔴 Difícil'};
  var byDiff = {facil:{c:0,t:0}, medio:{c:0,t:0}, dificil:{c:0,t:0}};
  s.pool.forEach(function(ex, i){
    if(byDiff[ex.diff]){ byDiff[ex.diff].t++; if(s.correct > 0 && cadenaState.solved > 0) {} }
  });
  // Simpler: just show total
  var breakdownHtml = '<div style="font-size:.88rem;color:var(--text2);">Resolviste correctamente ' + s.correct + ' de ' + s.pool.length + ' cadenas.</div>';

  document.getElementById('cadena-game').style.display = 'none';
  document.getElementById('cadena-results').style.display = 'block';
  document.getElementById('cadena-results').innerHTML =
    '<div class="results-card">'
    + '<div style="font-size:3rem;margin-bottom:.75rem;">' + emoji + '</div>'
    + '<div style="font-size:2.5rem;font-weight:700;color:var(--navy);">' + s.correct + '<span style="font-size:1.5rem;color:var(--slate);">/' + s.pool.length + '</span></div>'
    + '<div style="font-size:1.1rem;color:var(--green);font-weight:600;margin:.25rem 0 .5rem;">' + pct + '% de cadenas perfectas</div>'
    + '<div style="color:var(--slate);margin-bottom:1.5rem;font-size:.92rem;">' + label + '</div>'
    + breakdownHtml
    + '<div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:1.5rem;">'
      + '<button class="btn btn-primary" id="cad-replay-btn">&#128260; Jugar de nuevo</button>'
      + '<button class="btn btn-outline" id="cad-goto-constructor">&#9999; Ir al Constructor</button>'
      + '<button class="btn btn-outline" id="cad-goto-reglas">&#128218; Repasar reglas</button>'
    + '</div>'
    + '</div>';

  document.getElementById('cad-replay-btn').addEventListener('click', cadenaRestart);
  document.getElementById('cad-goto-constructor').addEventListener('click', function(){ showPage('constructor'); });
  document.getElementById('cad-goto-reglas').addEventListener('click', function(){ showPage('reglas'); });
}

/* =========================================================
   PERSISTENCE HOOKS — Wrap existing functions to save stats
   ========================================================= */
(function() {
  // Theme button init
  var saved = localStorage.getItem('logica-theme');
  if(saved === 'dark') {
    var icon = document.getElementById('theme-icon');
    var label = document.getElementById('theme-label');
    if(icon) icon.textContent = '☀️';
    if(label) label.textContent = 'Día';
  }

  // Restore persisted records
  var sr = AppState.get('surv.record') || 0;
  if(sr > 0 && typeof survRecord !== 'undefined') { survRecord = sr; var e = document.getElementById('surv-record'); if(e) e.textContent = sr + ' preguntas'; }
  var cr = AppState.get('crl.record') || 0;
  if(cr > 0 && typeof crlRecord !== 'undefined') { crlRecord = cr; var e2 = document.getElementById('crl-record'); if(e2) e2.textContent = cr + ' puntos'; }
  var sc = AppState.get('solCount') || 0;
  if(sc > 0 && typeof solCount !== 'undefined') { solCount = sc; var e3 = document.getElementById('sol-count'); if(e3) e3.textContent = sc; var b = document.getElementById('sol-progress-bar'); if(b) b.style.width=(sc/20*100)+'%'; }

  // Hook: showQuizResults
  var _sqr = window.showQuizResults;
  window.showQuizResults = function() {
    if(_sqr) _sqr();
    AppState.inc('quiz.played');
    if(quizScore > (AppState.get('quiz.best')||0)) AppState.set('quiz.best', quizScore);
    AppState.inc('gamesPlayed');
    Achievements.check();
  };

  // Hook: endSurvival
  var _es = window.endSurvival;
  window.endSurvival = function() {
    if(survState && survState.idx > (AppState.get('surv.record')||0)) {
      AppState.set('surv.record', survState.idx);
      survRecord = survState.idx;
      var e = document.getElementById('surv-record'); if(e) e.textContent = survState.idx + ' preguntas';
    }
    AppState.inc('gamesPlayed');
    Achievements.check();
    if(_es) _es();
  };

  // Hook: endCRL
  var _ec = window.endCRL;
  window.endCRL = function() {
    if(crlState && crlState.score > (AppState.get('crl.record')||0)) {
      AppState.set('crl.record', crlState.score);
      crlRecord = crlState.score;
      var e = document.getElementById('crl-record'); if(e) e.textContent = crlState.score + ' puntos';
    }
    AppState.inc('gamesPlayed');
    Achievements.check();
    if(_ec) _ec();
  };

  // Hook: toggleExSolution (persist exercise count)
  var _tes = window.toggleExSolution;
  window.toggleExSolution = function(solId, btnId) {
    if(_tes) _tes(solId, btnId);
    AppState.set('solCount', solCount || 0);
    Achievements.check();
  };

  // Enhanced buildLogros
  var _bl = window.buildLogros;
  window.buildLogros = function() {
    var grid = document.getElementById('logros-grid');
    var statsEl = document.getElementById('logros-stats');
    if(!grid) { if(_bl) _bl(); return; }

    var all = Achievements.getAll();
    var prog = Achievements.getProgress();
    grid.innerHTML = '';
    all.forEach(function(a) {
      var c = document.createElement('div');
      c.style.cssText = 'background:'+(a.unlocked?'white':'#f1f5f9')+';border:1.5px solid '+(a.unlocked?'var(--accent)':'var(--border)')+';border-radius:12px;padding:1.1rem;text-align:center;box-shadow:'+(a.unlocked?'var(--shadow)':'none')+';opacity:'+(a.unlocked?'1':'.45')+';transition:all .2s;';
      c.innerHTML = '<div style="font-size:2.2rem;margin-bottom:.4rem;">'+a.icon+'</div>'
        +'<div style="font-weight:600;font-size:.88rem;color:var(--navy);">'+a.name+'</div>'
        +'<div style="font-size:.76rem;color:var(--slate);margin-top:.2rem;">'+a.desc+'</div>'
        +(a.unlocked?'<div style="margin-top:.5rem;font-size:.7rem;color:var(--green);font-weight:700;">✅ DESBLOQUEADO</div>':'<div style="margin-top:.5rem;font-size:.7rem;color:var(--slate);">🔒 Bloqueado</div>');
      grid.appendChild(c);
    });

    if(statsEl) {
      var items = [
        {l:'Logros',v:prog.unlocked+'/'+prog.total},
        {l:'Quiz mejor',v:(AppState.get('quiz.best')||0)+'/20'},
        {l:'Récord Superv.',v:(AppState.get('surv.record')||0)+' preg.'},
        {l:'Récord CRL',v:(AppState.get('crl.record')||0)+' pts'},
        {l:'Ejercicios',v:(AppState.get('solCount')||0)+'/20'},
        {l:'Partidas',v:AppState.get('gamesPlayed')||0},
      ];
      statsEl.innerHTML = '';
      items.forEach(function(s) {
        var d = document.createElement('div');
        d.style.cssText = 'background:var(--slate-light);border:1px solid var(--border);border-radius:8px;padding:.65rem .8rem;text-align:center;';
        d.innerHTML = '<div style="font-family:\'DM Serif Display\',serif;font-size:1.15rem;color:var(--navy);">'+s.v+'</div><div style="font-size:.7rem;color:var(--slate);text-transform:uppercase;letter-spacing:.05em;">'+s.l+'</div>';
        statsEl.appendChild(d);
      });
    }
  };

  // Export student progress as PDF
  window.exportStudentPDF = function() {
    var p = Achievements.getProgress();
    var all = Achievements.getAll();
    var html = '<div style="font-family:Arial,sans-serif;max-width:700px;margin:0 auto;padding:2rem;">'
      +'<h1 style="text-align:center;color:#0f172a;border-bottom:3px solid #0f172a;padding-bottom:1rem;">📊 Reporte de Progreso — Lógica Proposicional</h1>'
      +'<p style="text-align:center;color:#64748b;">'+new Date().toLocaleDateString('es-DO',{year:'numeric',month:'long',day:'numeric'})+'</p>'
      +'<div style="display:flex;gap:1rem;justify-content:center;margin:1.5rem 0;">'
      +'<div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:1rem 2rem;text-align:center;"><div style="font-size:2rem;font-weight:700;color:#16a34a;">'+p.unlocked+'/'+p.total+'</div><div style="font-size:.8rem;color:#15803d;">Logros</div></div>'
      +'<div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;padding:1rem 2rem;text-align:center;"><div style="font-size:2rem;font-weight:700;color:#2563eb;">'+(AppState.get('quiz.best')||0)+'/20</div><div style="font-size:.8rem;color:#1d4ed8;">Quiz</div></div>'
      +'<div style="background:#fff7ed;border:1px solid #fed7aa;border-radius:10px;padding:1rem 2rem;text-align:center;"><div style="font-size:2rem;font-weight:700;color:#f97316;">'+(AppState.get('surv.record')||0)+'</div><div style="font-size:.8rem;color:#ea580c;">Supervivencia</div></div>'
      +'</div>'
      +'<h2 style="font-size:1.1rem;margin:1.5rem 0 .5rem;border-bottom:1px solid #e2e8f0;padding-bottom:.3rem;">🏆 Logros</h2>'
      +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem;">';
    all.forEach(function(a) {
      html += '<div style="padding:.4rem .6rem;border-radius:6px;background:'+(a.unlocked?'#f0fdf4':'#f8fafc')+';border:1px solid '+(a.unlocked?'#bbf7d0':'#e2e8f0')+';opacity:'+(a.unlocked?'1':'.5')+';font-size:.85rem;">'+a.icon+' '+a.name+(a.unlocked?' ✅':'')+'</div>';
    });
    html += '</div></div>';
    var w = window.open('','_blank','width=800,height=600');
    w.document.write('<!DOCTYPE html><html><head><title>Reporte</title></head><body>'+html+'<scr'+'ipt>setTimeout(function(){window.print()},300)</'+'script></body></html>');
    w.document.close();
  };

  // First check
  Achievements.check();
})();

</script>
</body>
</html>
