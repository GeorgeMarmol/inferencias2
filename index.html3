let currentExampleIdx = null;
let currentChallenge = null;

function loadExample(idx) {
  currentExampleIdx = idx;
  const ex = PROOF_EXAMPLES[idx];
  const ruleColors = ['#3b82f6','#dc2626','#7c3aed','#f97316','#16a34a','#0891b2','#0d9488','#b45309','#9333ea','#be123c'];
  const col = ruleColors[idx] || 'var(--navy)';
  document.getElementById('preview-title').innerHTML = `
    <span style="background:${col};color:white;border-radius:6px;padding:.15rem .55rem;font-size:.75rem;font-weight:700;margin-right:.6rem;">${idx+1}/10</span>
    ${ex.title}
  `;

  // Context & legend
  const legendHtml = Object.entries(ex.legend).map(([k,v]) =>
    `<div style="display:flex;align-items:baseline;gap:.5rem;padding:.2rem 0;"><span style="font-family:'DM Mono',monospace;font-weight:700;color:var(--navy);min-width:20px;">${k}</span><span style="color:var(--slate);font-size:.85rem;">= ${v}</span></div>`
  ).join('');

  document.getElementById('preview-context').innerHTML = `
    <div style="background:var(--blue-light);border:1px solid #bfdbfe;border-radius:10px;padding:1rem;">
      <div style="font-weight:600;font-size:.82rem;color:var(--blue);margin-bottom:.5rem;text-transform:uppercase;letter-spacing:.06em;">🔍 Situación</div>
      <p style="font-size:.88rem;color:var(--text2);line-height:1.6;">${ex.context}</p>
    </div>
    <div style="background:var(--accent-light);border:1px solid #fed7aa;border-radius:10px;padding:1rem;">
      <div style="font-weight:600;font-size:.82rem;color:var(--accent);margin-bottom:.5rem;text-transform:uppercase;letter-spacing:.06em;">📌 Variables</div>
      ${legendHtml}
      <div style="margin-top:.5rem;font-family:'DM Mono',monospace;font-size:.85rem;color:#92400e;">Meta: ${ex.goal}</div>
    </div>
  `;

  // Table
  const rowsHtml = ex.steps.map((s, i) => `
    <div style="display:grid;grid-template-columns:44px 1fr 1fr;padding:.55rem 1rem;border-bottom:1px solid var(--border);${s.isPremise ? 'background:#fafafa;' : 'background:white;'}${i === ex.steps.length-1 ? 'border-bottom:none;background:var(--green-light);' : ''}">
      <div style="font-size:.78rem;color:var(--slate);font-weight:600;">${i+1}</div>
      <div style="font-family:'DM Mono',monospace;font-size:.88rem;color:${i === ex.steps.length-1 ? 'var(--green)' : 'var(--navy)'};font-weight:${i === ex.steps.length-1 ? '700' : '500'};">${s.formula}${i === ex.steps.length-1 ? ' ✓' : ''}</div>
      <div style="font-size:.8rem;color:${s.isPremise ? 'var(--slate)' : 'var(--blue)'};font-style:${s.isPremise ? 'italic' : 'normal'};">${s.justification}</div>
    </div>
  `).join('');

  document.getElementById('preview-table').innerHTML = `
    <div style="display:grid;grid-template-columns:44px 1fr 1fr;background:var(--navy);padding:.5rem 1rem;">
      <div style="font-size:.72rem;color:#94a3b8;font-weight:600;">#</div>
      <div style="font-size:.72rem;color:#94a3b8;font-weight:600;">FÓRMULA</div>
      <div style="font-size:.72rem;color:#94a3b8;font-weight:600;">JUSTIFICACIÓN</div>
    </div>
    ${rowsHtml}
  `;

  document.getElementById('preview-explanation').innerHTML = `<strong>💡 Explicación:</strong> ${ex.explanation}`;
  document.getElementById('example-preview').style.display = 'block';
  document.getElementById('example-preview').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function activateExample() {
  const ex = PROOF_EXAMPLES[currentExampleIdx];
  document.getElementById('proof-name').value = ex.name;
  document.getElementById('proof-premises').value = ex.premises.join('\n');
  document.getElementById('proof-goal').value = ex.goal;
  document.getElementById('example-preview').style.display = 'none';
  initProof();
  // Add all derived steps automatically
  setTimeout(() => {
    ex.steps.filter(s => !s.isPremise).forEach(s => {
      proofLines.push({ formula: s.formula, justification: s.justification, isPremise: false });
    });
    renderProofLines();
    // Show success
    setTimeout(() => checkProof(), 100);
  }, 200);
}

function openProofChallenge() {
  const ch = CHALLENGES[Math.floor(Math.random() * CHALLENGES.length)];
  currentChallenge = ch;
  const legendHtml = Object.entries(ch.legend).map(([k,v]) =>
    `<span style="font-family:'DM Mono',monospace;font-weight:700;">${k}</span> = ${v}`
  ).join(' &nbsp;|&nbsp; ');

  document.getElementById('challenge-body').innerHTML = `
    <div style="margin-bottom:1rem;">
      <div style="font-size:.82rem;color:var(--purple);font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-bottom:.4rem;">${ch.title}</div>
      <p style="font-size:.92rem;color:var(--text2);margin-bottom:.75rem;">${ch.description}</p>
      <div style="font-size:.82rem;color:var(--slate);margin-bottom:.75rem;">${legendHtml}</div>
    </div>
    <div style="background:var(--slate-light);border:1px solid var(--border);border-radius:10px;padding:1rem;font-family:'DM Mono',monospace;font-size:.9rem;margin-bottom:1rem;">
      ${ch.premises.map((p,i) => `<div>P${i+1}: ${p}</div>`).join('')}
      <div style="border-top:1px solid var(--border);margin-top:.5rem;padding-top:.5rem;color:var(--red);font-weight:600;">∴ ${ch.goal}</div>
    </div>
    <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
      <button class="btn btn-accent" onclick="loadChallenge()">✏️ Abrir en el Constructor</button>
      <button class="btn btn-outline" onclick="showChallengeHint()">💡 Ver pista</button>
      <button class="btn btn-outline" onclick="showChallengeSolution()">👁 Ver solución</button>
    </div>
    <div id="challenge-hint-area" style="display:none;margin-top:1rem;"></div>
  `;
  document.getElementById('challenge-modal').style.display = 'block';
  document.getElementById('challenge-modal').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function loadChallenge() {
  const ch = currentChallenge;
  document.getElementById('proof-name').value = ch.title;
  document.getElementById('proof-premises').value = ch.premises.join('\n');
  document.getElementById('proof-goal').value = ch.goal;
  document.getElementById('challenge-modal').style.display = 'none';
  initProof();
  const hint = document.getElementById('proof-hint');
  hint.style.display = 'block';
  document.getElementById('proof-hint-text').textContent = ch.hint;
}

function showChallengeHint() {
  const area = document.getElementById('challenge-hint-area');
  area.style.display = 'block';
  area.innerHTML = `<div class="alert alert-info">💡 <strong>Pista:</strong> ${currentChallenge.hint}</div>`;
}

function showChallengeSolution() {
  const area = document.getElementById('challenge-hint-area');
  area.style.display = 'block';
  const allSteps = [
    ...currentChallenge.premises.map((p,i) => ({ num: i+1, formula: p, just: 'Premisa', isPremise: true })),
    ...currentChallenge.solution.map((s,i) => ({ num: currentChallenge.premises.length + i + 1, formula: s.formula, just: s.justification, isPremise: false }))
  ];
  const rows = allSteps.map(s => `
    <div style="display:grid;grid-template-columns:36px 1fr 1fr;padding:.4rem .75rem;border-bottom:1px solid var(--border);${!s.isPremise && s.num === allSteps.length ? 'background:var(--green-light);' : s.isPremise ? 'background:#fafafa;' : ''}">
      <span style="font-size:.75rem;color:var(--slate);">${s.num}</span>
      <span style="font-family:'DM Mono',monospace;font-size:.82rem;color:${!s.isPremise && s.num === allSteps.length ? 'var(--green)' : 'var(--navy)'};">${s.formula}</span>
      <span style="font-size:.78rem;color:${s.isPremise ? 'var(--slate)' : 'var(--blue)'};">${s.just}</span>
    </div>
  `).join('');
  area.innerHTML = `
    <div class="alert alert-success" style="margin-bottom:.75rem;">✅ Solución del reto:</div>
    <div style="border:1px solid var(--border);border-radius:10px;overflow:hidden;">${rows}</div>
  `;
}

function showProofHint() {
  if(!currentChallenge) {
    const hint = document.getElementById('proof-hint');
    hint.style.display = 'block';
    document.getElementById('proof-hint-text').textContent = 'Empieza identificando qué fórmulas tienes disponibles y qué regla conecta las premisas existentes con tu meta.';
    return;
  }
  const hint = document.getElementById('proof-hint');
  hint.style.display = 'block';
  document.getElementById('proof-hint-text').textContent = currentChallenge.hint;
}

function initProof() {
  const premisesRaw = document.getElementById('proof-premises').value.trim();
  if(!premisesRaw) { alert('Por favor ingresa al menos una premisa.'); return; }

  const premises = premisesRaw.split('\n').filter(p => p.trim());
  proofLines = [];
  proofPremisesCount = premises.length;

  premises.forEach((p) => {
    proofLines.push({ formula: p.trim(), justification: 'Premisa', isPremise: true });
  });

  const goal = document.getElementById('proof-goal').value.trim();
  document.getElementById('proof-display-name').textContent = document.getElementById('proof-name').value || 'Mi Demostración';
  document.getElementById('proof-display-goal').textContent = goal || '(no definida)';

  document.getElementById('proof-area').style.display = 'block';
  document.getElementById('proof-message').style.display = 'none';
  document.getElementById('proof-hint').style.display = 'none';
  renderProofLines();
  document.getElementById('proof-area').scrollIntoView({ behavior: 'smooth' });
}

function renderProofLines() {
  const c = document.getElementById('proof-lines');
  c.innerHTML = '';
  const goal = document.getElementById('proof-goal').value.trim();
  proofLines.forEach((line, i) => {
    const isGoal = !line.isPremise && line.formula.trim() === goal && goal !== '';
    const div = document.createElement('div');
    div.style.cssText = `display:grid;grid-template-columns:44px 1fr 200px 44px;align-items:center;padding:.6rem 1rem;border-bottom:1px solid var(--border);${line.isPremise ? 'background:#fafafa;' : ''}${isGoal ? 'background:var(--green-light);' : ''}`;
    div.innerHTML = `
      <div style="font-size:.78rem;color:var(--slate);font-weight:600;">${i + 1}</div>
      <div style="font-family:'DM Mono',monospace;font-size:.9rem;font-weight:500;color:${isGoal ? 'var(--green)' : 'var(--navy)'};">${line.formula}${isGoal ? ' ✓' : ''}</div>
      <div style="font-size:.78rem;color:${line.isPremise ? 'var(--slate)' : 'var(--blue)'};font-style:${line.isPremise ? 'italic' : 'normal'};">${line.justification}</div>
      <button onclick="deleteProofLine(${i})" ${line.isPremise ? 'disabled' : ''} style="background:none;border:none;color:${line.isPremise ? 'var(--border)' : '#cbd5e1'};cursor:${line.isPremise ? 'default' : 'pointer'};font-size:.95rem;border-radius:4px;transition:color .15s;padding:2px;" onmouseover="if(!this.disabled)this.style.color='var(--red)'" onmouseout="this.style.color='#cbd5e1'">✕</button>
    `;
    c.appendChild(div);
  });
  const cnt = document.getElementById('proof-line-count');
  if(cnt) cnt.textContent = `${proofLines.length} línea${proofLines.length !== 1 ? 's' : ''}`;
}

function addProofLine() {
  const formula = document.getElementById('new-formula').value.trim();
  const rule = document.getElementById('new-rule').value;
  if(!formula) { alert('Escribe la fórmula antes de agregar.'); return; }
  if(!rule) { alert('Selecciona la regla de justificación.'); return; }

  proofLines.push({ formula, justification: rule, isPremise: false });
  document.getElementById('new-formula').value = '';
  document.getElementById('new-rule').value = '';
  renderProofLines();
}

function deleteProofLine(idx) {
  if(idx < proofPremisesCount) return;
  proofLines.splice(idx, 1);
  renderProofLines();
}

function clearProof() {
  if(!confirm('¿Limpiar todas las líneas derivadas?')) return;
  proofLines = proofLines.slice(0, proofPremisesCount);
  renderProofLines();
}

function checkProof() {
  const goal = document.getElementById('proof-goal').value.trim();
  const msg = document.getElementById('proof-message');
  msg.style.display = 'block';

  if(!goal) {
    msg.className = 'alert alert-info';
    msg.innerHTML = '💡 Define una meta en el campo "Meta" arriba para poder verificar automáticamente tu prueba.';
    return;
  }

  if(proofLines.length <= proofPremisesCount) {
    msg.className = 'alert alert-warning';
    msg.innerHTML = `<strong>⚠️ Aún no hay pasos derivados.</strong> Agrega líneas de deducción usando el área de abajo. La meta es llegar a: <code style="font-family:'DM Mono',monospace;">${goal}</code>`;
    return;
  }

  const lastFormula = proofLines[proofLines.length - 1]?.formula.trim();
  if(lastFormula === goal) {
    msg.className = 'alert alert-success';
    msg.innerHTML = `<strong>✅ ¡Prueba completa y correcta!</strong> Tu prueba llega exitosamente a "<code style="font-family:'DM Mono',monospace;">${goal}</code>" en ${proofLines.length} líneas. ¡Excelente trabajo! Q.E.D.`;
    renderProofLines();
  } else {
    const derivedFormulas = proofLines.map(l => l.formula.trim());
    const goalFound = derivedFormulas.includes(goal);
    if(goalFound) {
      msg.className = 'alert alert-warning';
      msg.innerHTML = `<strong>⚠️ La meta aparece en la prueba pero no es la última línea.</strong> Mueve o reorganiza tus pasos para que "<code style="font-family:'DM Mono',monospace;">${goal}</code>" sea el último paso derivado.`;
    } else {
      msg.className = 'alert alert-warning';
      msg.innerHTML = `<strong>⚠️ Prueba incompleta.</strong> Tu última línea es "<code style="font-family:'DM Mono',monospace;">${lastFormula}</code>" pero la meta es "<code style="font-family:'DM Mono',monospace;">${goal}</code>". Continúa derivando. Tienes disponibles: ${derivedFormulas.map(f => `<code style="font-family:'DM Mono',monospace;">${f}</code>`).join(', ')}.`;
    }
  }
}

